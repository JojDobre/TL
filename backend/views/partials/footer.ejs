<!-- interaktivita navbaru: téma, dropdowny (zvonček, avatar) -->
<script>
(function () {
  // téma
  var savedTheme = localStorage.getItem('tl-theme') || 'dark';
  document.documentElement.setAttribute('data-theme', savedTheme);
  document.addEventListener('click', function (e) {
    var tt = e.target.closest('[data-theme-toggle]');
    if (tt) {
      var next = document.documentElement.getAttribute('data-theme') === 'light' ? 'dark' : 'light';
      localStorage.setItem('tl-theme', next);
      document.documentElement.setAttribute('data-theme', next);
      return;
    }
    var bell = e.target.closest('[data-bell]');
    var avatar = e.target.closest('[data-avatar]');
    var bp = document.querySelector('[data-bell-panel]');
    var ap = document.querySelector('[data-avatar-panel]');
    if (bell) { if (bp) bp.toggleAttribute('hidden'); if (ap) ap.setAttribute('hidden',''); return; }
    if (avatar) { if (ap) ap.toggleAttribute('hidden'); if (bp) bp.setAttribute('hidden',''); return; }
    if (!e.target.closest('.dropdown')) { if (bp) bp.setAttribute('hidden',''); if (ap) ap.setAttribute('hidden',''); }
  });
})();
</script>
<!-- animácie zo šablóny (reveal, glow, count-up...) -->
<script src="/js/enhance.js"></script>
</body>
</html>
