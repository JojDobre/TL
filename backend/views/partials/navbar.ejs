<!-- views/partials/navbar.ejs
     Navbar prenesený zo šablóny (shell.js buildNav) do EJS. Logiku „guest vs
     prihlásený" a „admin link len pre admina" rieši server cez currentUserId /
     currentUserRole (z res.locals v index.js). Žiadne generovanie cez JS.

     Parametre: `active` = id aktívnej položky (home/seasons/leaderboards/...). -->
<% const nav = typeof active !== 'undefined' ? active : ''; %>
<div class="nav"><div class="wrap nav-inner">
<%- include('brand-lockup', { variant: 'horizontal', size: 36, fontSize: 20, href: '/' }) %>
  
  <nav class="nav-links">
    <a class="nav-link <%= nav==='home'?'active':'' %>" href="/">Domov</a>
    <% if (currentUserId) { %>
      <a class="nav-link <%= nav==='moje'?'active':'' %>" href="/my">Moje</a>
    <% } %>
    <a class="nav-link <%= nav==='seasons'?'active':'' %>" href="/seasons">Sezóny</a>
    <a class="nav-link <%= nav==='leaderboards'?'active':'' %>" href="/leaderboards">Rebríčky</a>
    <a class="nav-link <%= nav==='blog'?'active':'' %>" href="/blog">Blog</a>
    <a class="nav-link <%= nav==='navody'?'active':'' %>" href="/navody">Wiki</a>
    <% if (currentUserRole === 'admin') { %>
      <a class="nav-link admin <%= nav==='admin'?'active':'' %>" href="/admin">Admin</a>
    <% } %>
  </nav>

  <div class="nav-actions">
    <button class="btn btn-ghost btn-icon" data-theme-toggle aria-label="Téma">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4 12H2M22 12h-2M5 5l1.4 1.4M17.6 17.6L19 19M19 5l-1.4 1.4M6.4 17.6L5 19"/></svg>
    </button>

    <% if (!currentUserId) { %>
      <a class="btn btn-ghost btn-sm nav-guest-text" href="/login">Prihlásiť sa</a>
      <a class="btn btn-primary btn-sm nav-guest-text" href="/register">Registrovať</a>
      <a class="btn btn-ghost btn-icon nav-guest-icon" href="/login" aria-label="Prihlásiť sa">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4 4-6 8-6s8 2 8 6"/></svg>
      </a>
    <% } else { %>
      <div style="position:relative">
        <button class="btn btn-ghost btn-icon bell" data-bell aria-label="Notifikácie" style="position:relative">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.7 21a2 2 0 0 1-3.4 0"/></svg>
          <span class="bell-badge" data-bell-badge hidden style="position:absolute;top:2px;right:2px;min-width:16px;height:16px;padding:0 4px;border-radius:99px;background:var(--danger,#e5484d);color:#fff;font-size:10px;font-weight:800;line-height:16px;text-align:center"></span>
        </button>
        <div class="dropdown" data-bell-panel hidden style="right:0;min-width:300px">
          <div class="dd-head">Notifikácie</div>
          <div data-bell-list><div class="dd-link" style="color:var(--text-4)">Načítavam…</div></div>
          <div class="dd-sep"></div>
          <a class="dd-link" href="/notifications">Zobraziť všetky</a>
        </div>
      </div>
      <div style="position:relative">
        <button class="row g-2" data-avatar style="background:none;border:none;padding:2px;border-radius:99px">
          <%- include('avatar', { image: (typeof currentUserImage !== 'undefined' ? currentUserImage : ''), initials: (currentUserName || 'U').substring(0,2).toUpperCase(), cls: 'avatar-md avatar-ring' }) %>
        </button>
        <div class="dropdown" data-avatar-panel hidden style="right:0">
          <div class="dd-head"><%= currentUserName || 'Účet' %></div>
          <a class="dd-link" href="/profile">Profil</a>
          <a class="dd-link" href="/my">Moje súťaže</a>
          <a class="dd-link" href="/settings">Nastavenia</a>
          <% if (currentUserRole === 'admin') { %>
            <div class="dd-sep"></div>
            <a class="dd-link" href="/admin">Admin panel</a>
          <% } %>
          <div class="dd-sep"></div>
          <a class="dd-link danger" href="/logout">Odhlásiť sa</a>
        </div>
      </div>
    <% } %>
  </div>
</div></div>

<% if (currentUserId) { %>
<script>
(function(){
  // Naplnenie zvončeka: počet neprečítaných (badge) + posledné notifikácie (dropdown).
  var badge = document.querySelector('[data-bell-badge]');
  var list = document.querySelector('[data-bell-list]');
  var panel = document.querySelector('[data-bell-panel]');
  function icon(t){
    return ({new_round:'🏒',deadline:'⏰',result:'🎯',achievement:'🏆',rank:'📈',member:'👥',canceled:'🚫'})[t] || '🔔';
  }
  function esc(s){ var d=document.createElement('div'); d.textContent=s==null?'':String(s); return d.innerHTML; }
  
  // vykreslí prázdny stav do dropdownu
  function renderEmpty(){
    if (list) list.innerHTML = '<div class="dd-link" style="color:var(--text-4)">Žiadne notifikácie</div>';
  }

  // počiatočné načítanie badge počtu
  fetch('/api/notifications/unread-count', { headers:{ 'Accept':'application/json' } })
    .then(function(r){ return r.ok ? r.json() : null; })
    .then(function(d){ if(d && d.count > 0 && badge){ badge.textContent = d.count > 99 ? '99+' : d.count; badge.hidden = false; } })
    .catch(function(){});
    
  // počiatočné načítanie posledných notifikácií do dropdownu
  fetch('/api/notifications/recent', { headers:{ 'Accept':'application/json' } })
    .then(function(r){ return r.ok ? r.json() : null; })
    .then(function(d){
      if(!list) return;
      if(!d || !d.items || !d.items.length){ renderEmpty(); return; }
      list.innerHTML = d.items.map(function(n){
        var href = n.link || '/notifications';
        var dot = n.read ? '' : '<span style="display:inline-block;width:6px;height:6px;border-radius:50%;background:var(--brand);margin-right:6px;vertical-align:middle"></span>';
        return '<a class="dd-link" data-notif-item data-notif-id="'+n.id+'" href="'+href+'" style="white-space:normal;line-height:1.4">'+dot+'<span style="margin-right:6px">'+icon(n.type)+'</span>'+esc(n.title||'Notifikácia')+'</a>';
      }).join('');
    })
    .catch(function(){});

    
  // Pri OTVORENÍ zvončeka: skry badge a označ všetky ako prečítané (trvalo).
  var markedOnOpen = false;
  document.addEventListener('click', function(e){
    var bell = e.target.closest('[data-bell]');
    if (bell) {
      // dropdown sa prepína vo footri; tu len vyčistíme počítadlo pri otvorení
      // (malý timeout, aby sme reagovali až po prepnutí 'hidden')
      setTimeout(function(){
        var open = panel && !panel.hasAttribute('hidden');
        if (open && !markedOnOpen) {
          markedOnOpen = true;
          if (badge) { badge.hidden = true; badge.textContent = ''; }
          fetch('/notifications/read-all', { method:'POST', headers:{ 'Accept':'application/json' } }).catch(function(){});
        }
      }, 0);
      return;
    }

    // Klik na konkrétnu notifikáciu v dropdowne: označ prečítanú a odober z okienka.
    var item = e.target.closest('[data-notif-item]');
    if (item) {
      var id = item.getAttribute('data-notif-id');
      if (id) {
        // označ prečítanú (na pozadí; navigácia na href prebehne normálne)
        fetch('/notifications/'+id+'/read', { method:'POST', headers:{ 'Accept':'application/json' } }).catch(function(){});
        // odober z dropdownu hneď
        if (item.remove) item.remove(); else if (item.parentNode) item.parentNode.removeChild(item);
        if (list && !list.querySelector('[data-notif-item]')) renderEmpty();
      }
      // necháme prebehnúť prirodzenú navigáciu na n.link
      return;
    }
  });

})();
</script>
<% } %>
