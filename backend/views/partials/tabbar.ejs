<!-- views/partials/tabbar.ejs
     Mobilný dolný tab bar (zobrazený len na mobile cez CSS .tabbar). Prenesený
     zo šablóny (shell.js buildTabbar). Guest vs prihlásený rieši server cez
     currentUserId. Aktívna karta podľa `active` (rovnaké id ako navbar).
     SVG ikony sú 1:1 zo šablóny. -->
<% const t = typeof active !== 'undefined' ? active : ''; %>
<nav class="tabbar" aria-label="Mobilná navigácia">
  <a class="tab-item <%= t==='home'?'active':'' %>" href="/">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 10.5L12 3l9 7.5"/><path d="M5 9.5V20h14V9.5"/><path d="M9.5 20v-5h5v5"/></svg>
    <span>Domov</span>
  </a>
  <a class="tab-item <%= t==='seasons'?'active':'' %>" href="/seasons">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 4h10v3a5 5 0 0 1-10 0z"/><path d="M7 5H4v2a3 3 0 0 0 3 3M17 5h3v2a3 3 0 0 1-3 3"/><path d="M12 12v4M9 20h6M10 16h4"/></svg>
    <span>Sezóny</span>
  </a>
  <a class="tab-item <%= t==='leaderboards'?'active':'' %>" href="/leaderboards">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 21V10M12 21V4M19 21v-7"/></svg>
    <span>Rebríček</span>
  </a>
  <% if (currentUserId) { %>
    <a class="tab-item <%= t==='moje'?'active':'' %>" href="/my">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7.5" height="7.5" rx="1.8"/><rect x="13.5" y="3" width="7.5" height="7.5" rx="1.8"/><rect x="3" y="13.5" width="7.5" height="7.5" rx="1.8"/><rect x="13.5" y="13.5" width="7.5" height="7.5" rx="1.8"/></svg>
      <span>Moje</span>
    </a>
    <a class="tab-item <%= t==='profile'?'active':'' %>" href="/profile">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="3.4"/><path d="M5.5 20a6.5 6.5 0 0 1 13 0"/></svg>
      <span>Profil</span>
    </a>
  <% } else { %>
    <a class="tab-item <%= t==='blog'?'active':'' %>" href="/blog">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 3.5h11l3 3V20.5H5z"/><path d="M15 3.5V7h3.5"/><path d="M8.5 12h7M8.5 15.5h7M8.5 8.5h3"/></svg>
      <span>Blog</span>
    </a>
    <a class="tab-item <%= t==='login'?'active':'' %>" href="/login">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="3.4"/><path d="M5.5 20a6.5 6.5 0 0 1 13 0"/></svg>
      <span>Prihlásiť</span>
    </a>
  <% } %>
</nav>
