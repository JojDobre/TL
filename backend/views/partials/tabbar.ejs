<!-- views/partials/tabbar.ejs
     Mobilný dolný tab bar (zobrazený len na mobile cez CSS .tabbar).
     Guest vs prihlásený rieši server cez currentUserId. Aktívna karta podľa
     `active` (rovnaké id ako navbar).
     Prihlásený: Centrum / Sezóny / Rebríček / Blog / Ostatné (bottom sheet).
     Guest: Domov / Sezóny / Rebríček / Blog / Prihlásiť. -->
<% const t = typeof active !== 'undefined' ? active : ''; %>
<nav class="tabbar" aria-label="Mobilná navigácia">
  <% if (currentUserId) { %>
    <a class="tab-item <%= t==='moje'?'active':'' %>" href="/my">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7.5" height="7.5" rx="1.8"/><rect x="13.5" y="3" width="7.5" height="7.5" rx="1.8"/><rect x="3" y="13.5" width="7.5" height="7.5" rx="1.8"/><rect x="13.5" y="13.5" width="7.5" height="7.5" rx="1.8"/></svg>
      <span>Centrum</span>
    </a>
    <a class="tab-item <%= t==='seasons'?'active':'' %>" href="/seasons">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 4h10v3a5 5 0 0 1-10 0z"/><path d="M7 5H4v2a3 3 0 0 0 3 3M17 5h3v2a3 3 0 0 1-3 3"/><path d="M12 12v4M9 20h6M10 16h4"/></svg>
      <span>Sezóny</span>
    </a>
    <a class="tab-item <%= t==='leaderboards'?'active':'' %>" href="/leaderboards">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 21V10M12 21V4M19 21v-7"/></svg>
      <span>Rebríček</span>
    </a>
    <a class="tab-item <%= t==='blog'?'active':'' %>" href="/blog">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 3.5h11l3 3V20.5H5z"/><path d="M15 3.5V7h3.5"/><path d="M8.5 12h7M8.5 15.5h7M8.5 8.5h3"/></svg>
      <span>Blog</span>
    </a>
    <button class="tab-item tab-more" type="button" data-more-toggle aria-haspopup="dialog" aria-controls="more-sheet" aria-expanded="false">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="5" cy="12" r="1.6"/><circle cx="12" cy="12" r="1.6"/><circle cx="19" cy="12" r="1.6"/></svg>
      <span>Ostatné</span>
    </button>
  <% } else { %>
    <a class="tab-item <%= t==='home'?'active':'' %>" href="/">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 10.5L12 3l9 7.5"/><path d="M5 9.5V20h14V9.5"/><path d="M9.5 20v-5h5v5"/></svg>
      <span>Domov</span>
    </a>
    <a class="tab-item <%= t==='seasons'?'active':'' %>" href="/seasons">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 4h10v3a5 5 0 0 1-10 0z"/><path d="M7 5H4v2a3 3 0 0 0 3 3M17 5h3v2a3 3 0 0 1-3 3"/><path d="M12 12v4M9 20h6M10 16h4"/></svg>
      <span>Sezóny</span>
    </a>
    <a class="tab-item <%= t==='leaderboards'?'active':'' %>" href="/leaderboards">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 21V10M12 21V4M19 21v-7"/></svg>
      <span>Rebríček</span>
    </a>
    <a class="tab-item <%= t==='blog'?'active':'' %>" href="/blog">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 3.5h11l3 3V20.5H5z"/><path d="M15 3.5V7h3.5"/><path d="M8.5 12h7M8.5 15.5h7M8.5 8.5h3"/></svg>
      <span>Blog</span>
    </a>
    <a class="tab-item <%= t==='login'?'active':'' %>" href="/login">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="3.4"/><path d="M5.5 20a6.5 6.5 0 0 1 13 0"/></svg>
      <span>Prihlásiť</span>
    </a>
  <% } %>
</nav>

<% if (currentUserId) { %>
<!-- „Ostatné" bottom sheet (len mobil; otvára tab-more) -->
<div class="scrim" id="more-sheet" data-more-sheet hidden>
  <div class="dialog more-sheet" role="dialog" aria-modal="true" aria-label="Ostatné odkazy">
    <div class="more-grab" aria-hidden="true"></div>
    <div class="more-grid">
      <a class="more-link" href="/join"><span class="more-ic"></span>Pripojiť sa cez ID</a>
      <a class="more-link" href="/discover"><span class="more-ic"></span>Objaviť</a>
      <a class="more-link" href="/navody"><span class="more-ic"></span>Návody</a>
      <a class="more-link" href="/achievements"><span class="more-ic"></span>Achievementy</a>
      <a class="more-link" href="/stats"><span class="more-ic"></span>Štatistiky</a>
      <a class="more-link" href="/tip-history"><span class="more-ic"></span>História tipov</a>
      <a class="more-link" href="/about"><span class="more-ic"></span>O nás</a>
      <a class="more-link" href="/kontakt"><span class="more-ic"></span>Kontakt</a>
      <a class="more-link" href="/podmienky"><span class="more-ic"></span>Podmienky</a>
      <a class="more-link" href="/sukromie"><span class="more-ic"></span>Súkromie</a>
    </div>
  </div>
</div>
<script>
(function(){
  var sheet = document.querySelector('[data-more-sheet]');
  var btn = document.querySelector('[data-more-toggle]');
  if (!sheet || !btn) return;
  function open(){ sheet.removeAttribute('hidden'); btn.setAttribute('aria-expanded','true'); btn.classList.add('active'); document.body.style.overflow='hidden'; }
  function close(){ sheet.setAttribute('hidden',''); btn.setAttribute('aria-expanded','false'); btn.classList.remove('active'); document.body.style.overflow=''; }
  btn.addEventListener('click', function(){ sheet.hasAttribute('hidden') ? open() : close(); });
  sheet.addEventListener('click', function(e){
    if (e.target === sheet) { close(); return; }           // klik na scrim
    if (e.target.closest('.more-link')) close();            // klik na odkaz (navigácia prebehne)
  });
  document.addEventListener('keydown', function(e){ if (e.key === 'Escape' && !sheet.hasAttribute('hidden')) close(); });
})();
</script>
<% } %>
