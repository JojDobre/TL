<%- include('partials/head', { title: 'Sezóny', page: 'seasons', active: 'seasons', pageStyle: `
  .se-head { padding:34px 0 22px; }
  .se-search { display:grid; grid-template-columns:1fr auto auto; gap:12px; margin:22px 0 8px; }
  .grid-cards, .blk-head { scroll-margin-top:84px; }
  .page-in { animation:pageIn .45s cubic-bezier(.22,.61,.36,1) both; }
  @keyframes pageIn { from { opacity:0; transform:translateY(14px) scale(.98); } to { opacity:1; transform:none; } }
  @media (prefers-reduced-motion: reduce) { .page-in { animation:none; } }
  .grid-cards { display:grid; gap:18px; }
  .g3 { grid-template-columns:repeat(3,1fr); }
  .g4 { grid-template-columns:repeat(4,1fr); }
  .season-cover { height:120px; position:relative; display:flex; align-items:flex-end; padding:14px; }
  .season-cover.has-img::after { content:""; position:absolute; inset:0; background:linear-gradient(180deg, rgba(8,10,18,.72) 0%, rgba(8,10,18,.25) 38%, rgba(8,10,18,.22) 60%, rgba(8,10,18,.72) 100%); pointer-events:none; }
  .season-cover .tag { position:relative; z-index:1; }
  .season-cover > .tag:first-child { position:absolute; top:12px; left:12px; }
  .season-meta { display:flex; gap:14px; font-size:var(--fs-sm); color:var(--text-3); flex-wrap:wrap; }
  .season-meta b { color:var(--text-1); font-family:var(--num); white-space:nowrap; }
  .blk-head { display:flex; align-items:flex-end; justify-content:space-between; gap:14px; margin:36px 0 18px; flex-wrap:wrap; }
  .blk-head h2 { font-size:var(--fs-h3); }
  @media (max-width:900px){ .g3,.g4 { grid-template-columns:1fr 1fr; } .se-search { grid-template-columns:1fr !important; } }
  @media (max-width:560px){ .g3,.g4 { grid-template-columns:1fr; } .se-search { grid-template-columns:1fr !important; } }
` }) %>

<%
  const GRADS = ['135deg,#0b4ea2,#1a1340','135deg,#2b0a4a,#5b3fd6','135deg,#0a3d2e,#15543a','135deg,#7a1f06,#c2410c','135deg,#1b3f72,#3a7bd5','135deg,#522963,#8e44ad'];
  const grad = (id) => GRADS[(Number(id)||0) % GRADS.length];
%>

<div class="wrap se-head">
  <div class="between wrap-gap" style="gap:16px">
    <div>
      <div class="eyebrow">Sezóny</div>
      <h1 style="font-size:clamp(2rem,3.4vw,2.8rem)">Nájdi sezónu a začni tipovať</h1>
      <p class="muted" style="margin-top:6px">Oficiálne sezóny s globálnym rebríčkom alebo komunitné súťaže pre tvoju partiu.</p>
    </div>
    <div class="row g-2 wrap-gap">
      <button class="btn btn-secondary" data-open-join>Pripojiť sa</button>
      <a href="/seasons/create" class="btn btn-primary">+ Vytvoriť sezónu</a>
    </div>
  </div>
</div>

<div class="wrap" style="padding-bottom:64px">
  <!-- OFFICIAL -->
  <div class="blk-head" style="margin-top:8px"><div><div class="eyebrow">Oficiálne sezóny</div><h2>Veľké oficiálne sezóny</h2></div></div>
  <div class="grid-cards g3">
    <% if (official.length === 0) { %>
      <p class="muted" style="grid-column:1/-1">Zatiaľ tu nie sú žiadne oficiálne sezóny.</p>
    <% } %>
    <% official.forEach(function (s) { %>
    <a href="/seasons/<%= s.id %>" class="card card-hover official-card" style="overflow:hidden">
      <div class="season-cover<% if (s.image) { %> has-img<% } %>" style="background:linear-gradient(<%= grad(s.id) %>)<% if (s.image) { %>;background-image:url('<%= s.image %>');background-size:cover;background-position:center<% } %>"><span class="tag tag-brand">Oficiálna</span><% if (s.status === 'ended') { %><span class="tag tag-muted" style="position:absolute;top:12px;right:12px">Ukončená</span><% } else if (s.status === 'upcoming') { %><span class="tag tag-info" style="position:absolute;top:12px;right:12px">Pripravovaná</span><% } else { %><span class="tag tag-live" style="position:absolute;top:12px;right:12px"><span class="dot"></span>Live</span><% } %></div>
      <div class="card-pad"><h4 style="margin-bottom:6px"><%= s.name %></h4><p class="muted" style="font-size:var(--fs-sm);margin-bottom:14px"><%= s.description || '' %></p><div class="season-meta"><span><b><%= s.participantsCount != null ? s.participantsCount : '—' %></b> hráčov</span><span><b><%= s.leaguesCount != null ? s.leaguesCount : '—' %></b> líg</span><span><b><%= s.matchesCount != null ? s.matchesCount : '—' %></b> zápasov</span></div></div>
    </a>
    <% }); %>
  </div>
  <div class="row g-2" id="officialPager" hidden style="justify-content:center;margin-top:18px">
    <button type="button" class="btn btn-secondary btn-sm" id="opPrev">← Predošlé</button>
    <span class="muted" id="opInfo" style="font-size:var(--fs-sm);align-self:center"></span>
    <button type="button" class="btn btn-secondary btn-sm" id="opNext">Ďalšie →</button>
  </div>

  <!-- COMMUNITY SEARCH -->
  <div class="card card-pad" style="margin-top:40px;background:linear-gradient(120deg,color-mix(in srgb,var(--gold) 7%,var(--surface-1)),var(--surface-1))">
    <div class="eyebrow" style="color:var(--gold)">Komunitné sezóny</div>
    <h3 style="margin:6px 0 16px">Hľadaj verejné sezóny alebo sa pripoj cez ID</h3>
    <div class="se-search" style="grid-template-columns:1fr auto">
      <div class="input-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4" stroke-linecap="round"/></svg><input class="input" id="seasonSearch" placeholder="Hľadať podľa názvu alebo ID…"></div>
      <a href="/discover" class="btn btn-secondary">Objaviť všetky →</a>
    </div>
  </div>

  <div class="blk-head"><div><div class="eyebrow">Komunitné sezóny</div><h2>Verejné sezóny vytvorené komunitov</h2></div><a href="/seasons/create" class="btn btn-ghost btn-sm">Vytvoriť sezónu →</a></div>
  <div class="grid-cards g4">
    <% if (community.length === 0) { %>
      <p class="muted" style="grid-column:1/-1">Zatiaľ tu nie sú žiadne komunitné sezóny.</p>
    <% } %>
    <% community.forEach(function (s) { %>
    <a href="/seasons/<%= s.id %>" class="card card-hover season-card" data-name="<%= (s.name || '').toLowerCase() %>" data-code="<%= (s.inviteCode || '').toLowerCase() %>" style="overflow:hidden"><div class="season-cover<% if (s.image) { %> has-img<% } %>" style="background:linear-gradient(<%= grad(s.id) %>);height:88px<% if (s.image) { %>;background-image:url('<%= s.image %>');background-size:cover;background-position:center<% } %>"><span class="tag tag-gold">Community</span><% if (s.hasPassword) { %><span class="tag tag-muted" style="position:absolute;top:44px;left:12px;z-index:1">🔒</span><% } %><% if (s.status === 'ended') { %><span class="tag tag-muted" style="position:absolute;top:12px;right:12px">Ukončená</span><% } else if (s.status === 'upcoming') { %><span class="tag tag-info" style="position:absolute;top:12px;right:12px">Pripravovaná</span><% } else { %><span class="tag tag-live" style="position:absolute;top:12px;right:12px"><span class="dot"></span>Live</span><% } %></div><div class="card-pad"><h4 style="font-size:var(--fs-h4);margin-bottom:4px"><%= s.name %></h4><p class="muted" style="font-size:var(--fs-xs);margin-bottom:12px"><%= s.description || '' %></p><div class="row between"><span class="season-meta"><b><%= s.participantsCount != null ? s.participantsCount : '—' %></b> hráčov</span><span class="tag <%= s.hasPassword ? 'tag-gold' : 'tag-muted' %>"><%= s.hasPassword ? '🔒 Súkromná' : 'Verejná' %></span></div></div></a>
    <% }); %>
  </div>
  <div class="row g-2" id="seasonPager" hidden style="justify-content:center;margin-top:18px">
    <button type="button" class="btn btn-secondary btn-sm" id="spPrev">← Predošlé</button>
    <span class="muted" id="spInfo" style="font-size:var(--fs-sm);align-self:center"></span>
    <button type="button" class="btn btn-secondary btn-sm" id="spNext">Ďalšie →</button>
  </div>
</div>

<!-- ===== JOIN DIALOG ===== -->
<div class="scrim" data-join hidden>
  <form class="dialog" action="/seasons/join" method="POST" data-join-form>
    <div class="between" style="margin-bottom:6px"><div class="dialog-title">Pripojiť sa cez ID</div><button type="button" class="btn btn-ghost btn-icon" data-close-join>✕</button></div>
    <p class="muted" style="font-size:var(--fs-sm);margin-bottom:20px">Zadaj 6-miestne ID sezóny alebo turnaja, ktoré ti poslal jeho zakladateľ.</p>
    <div class="field" style="margin-bottom:14px">
      <label class="label">ID</label>
      <input class="input num" name="inviteCode" placeholder="napr. HK4F2X" style="letter-spacing:.3em;text-transform:uppercase;font-weight:700" maxlength="6" required>
    </div>
    <div class="field" data-join-pw hidden style="margin-bottom:14px">
      <label class="label">Heslo</label>
      <input class="input" type="password" name="password" placeholder="Heslo súťaže" autocomplete="off">
    </div>
    <div class="field-error" data-join-error hidden style="color:var(--danger);font-size:var(--fs-sm);margin-bottom:14px"></div>
    <div class="row g-2" style="justify-content:flex-end"><button type="button" class="btn btn-secondary" data-close-join>Zrušiť</button><button type="submit" class="btn btn-primary">Pripojiť sa</button></div>
  </form>
</div>

<script>
  // join dialóg
  document.addEventListener('click', function (e) {
    var dlg = document.querySelector('[data-join]'); if (!dlg) return;
    if (e.target.closest('[data-open-join]')) { dlg.removeAttribute('hidden'); var _je=dlg.querySelector('[data-join-error]'); if(_je){_je.setAttribute('hidden','');_je.textContent='';} var _jp=dlg.querySelector('input[type=password]'); if(_jp){_jp.value='';} var _jf=dlg.querySelector('[data-join-pw]'); if(_jf){_jf.setAttribute('hidden','');} }
    else if (e.target.closest('[data-close-join]') || e.target === dlg) dlg.setAttribute('hidden','');
  });
  // odoslanie join dialógu cez fetch — chyba (zlé ID/heslo/skončená) sa zobrazí v modáli
  (function () {
    var form = document.querySelector('[data-join-form]');
    if (!form) return;
    var errBox = form.querySelector('[data-join-error]');
    var submitBtn = form.querySelector('button[type="submit"]');
    form.addEventListener('submit', function (e) {
      e.preventDefault();
      if (errBox) { errBox.setAttribute('hidden', ''); errBox.textContent = ''; }
      if (submitBtn) submitBtn.disabled = true;
      var body = new URLSearchParams(new FormData(form));
      fetch(form.getAttribute('action'), {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'fetch', 'Accept': 'application/json' },
        body: body.toString(),
      }).then(function (r) { return r.json().catch(function () { return {}; }); })
        .then(function (d) {
          if (submitBtn) submitBtn.disabled = false;
          if (d && d.success) { window.location.href = d.redirect || window.location.href; return; }
          if (d && d.needPassword) {
            var pw = form.querySelector('[data-join-pw]');
            if (pw) { pw.removeAttribute('hidden'); var pi = pw.querySelector('input'); if (pi) pi.focus(); }
          }
          if (errBox) { errBox.textContent = (d && d.message) || 'Nepodarilo sa pripojiť. Skús to znova.'; errBox.removeAttribute('hidden'); }
        })
        .catch(function () {
          if (submitBtn) submitBtn.disabled = false;
          if (errBox) { errBox.textContent = 'Chyba spojenia. Skús to znova.'; errBox.removeAttribute('hidden'); }
        });
    });
  })();
  // search komunitných sezón podľa názvu ALEBO ID + stránkovanie po 12
  (function () {
    var PAGE = 12;
    var cards = Array.prototype.slice.call(document.querySelectorAll('.season-card'));
    var pager = document.getElementById('seasonPager');
    var info = document.getElementById('spInfo');
    var prev = document.getElementById('spPrev');
    var next = document.getElementById('spNext');
    var ss = document.getElementById('seasonSearch');
    var page = 1, q = '';

    function matches(c) {
      if (!q) return true;
      return (c.getAttribute('data-name') || '').indexOf(q) >= 0
          || (c.getAttribute('data-code') || '').indexOf(q) >= 0;
    }
    function render() {
      var vis = cards.filter(matches);
      var pages = Math.max(1, Math.ceil(vis.length / PAGE));
      if (page > pages) page = pages;
      cards.forEach(function (c) { c.style.display = 'none'; });
      vis.slice((page - 1) * PAGE, page * PAGE).forEach(function (c, i) {
        c.style.display = '';
        c.classList.remove('page-in'); void c.offsetWidth;
        c.style.animationDelay = (i * 40) + 'ms';
        c.classList.add('page-in');
      });
      if (pager) {
        pager.hidden = vis.length <= PAGE;
        if (info) info.textContent = 'Strana ' + page + ' / ' + pages;
        if (prev) prev.disabled = page <= 1;
        if (next) next.disabled = page >= pages;
      }
    }
    function scrollTop() {
      var first = cards.find(matches);
      var grid = first ? first.parentElement : null;
      var target = grid && grid.previousElementSibling ? grid.previousElementSibling : grid;
      if (target && target.getBoundingClientRect().top < 0) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
    if (prev) prev.addEventListener('click', function () { if (page > 1) { page--; render(); scrollTop(); } });
    if (next) next.addEventListener('click', function () { page++; render(); scrollTop(); });
    if (ss) ss.addEventListener('input', function () { q = this.value.trim().toLowerCase(); page = 1; render(); });
    render();
  })();
  // stránkovanie oficiálnych sezón po 6
  (function () {
    var PAGE = 6;
    var cards = Array.prototype.slice.call(document.querySelectorAll('.official-card'));
    var pager = document.getElementById('officialPager');
    var info = document.getElementById('opInfo');
    var prev = document.getElementById('opPrev');
    var next = document.getElementById('opNext');
    var page = 1;
    function render() {
      var pages = Math.max(1, Math.ceil(cards.length / PAGE));
      if (page > pages) page = pages;
      cards.forEach(function (c) { c.style.display = 'none'; });
      cards.slice((page - 1) * PAGE, page * PAGE).forEach(function (c, i) {
        c.style.display = '';
        c.classList.remove('page-in'); void c.offsetWidth;
        c.style.animationDelay = (i * 40) + 'ms';
        c.classList.add('page-in');
      });
      if (pager) {
        pager.hidden = cards.length <= PAGE;
        if (info) info.textContent = 'Strana ' + page + ' / ' + pages;
        if (prev) prev.disabled = page <= 1;
        if (next) next.disabled = page >= pages;
      }
    }
    function scrollTop() {
      var grid = cards.length ? cards[0].parentElement : null;
      var target = grid && grid.previousElementSibling ? grid.previousElementSibling : grid;
      if (target && target.getBoundingClientRect().top < 0) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
    if (prev) prev.addEventListener('click', function () { if (page > 1) { page--; render(); scrollTop(); } });
    if (next) next.addEventListener('click', function () { page++; render(); scrollTop(); });
    render();
  })();
</script>

<%- include('partials/footer') %>
