<%- include('partials/head', { title: league.name, page: 'seasons', active: 'seasons', pageStyle: `
  .season-hero { position:relative; overflow:hidden; border-bottom:1px solid var(--line); }
  .season-hero-bg { position:absolute; inset:0; background:linear-gradient(120deg,#7c5cff,#1a1340 70%); opacity:.55; }
  .season-hero-bg::after { content:""; position:absolute; inset:0; background:linear-gradient(180deg, transparent, var(--bg)); }
  .season-hero-inner { position:relative; padding:40px 0 30px; }
  .sh-meta { display:flex; gap:26px; flex-wrap:wrap; margin-top:18px; }
  .sh-meta .n { font-family:var(--num); font-weight:700; font-size:1.6rem; color:var(--text-1); white-space:nowrap; }
  .sh-meta .l { font-size:var(--fs-xs); text-transform:uppercase; letter-spacing:.08em; color:var(--text-4); font-weight:700; }

  .sec-layout { display:grid; grid-template-columns: 1fr 330px; gap:28px; align-items:start; padding:32px 0 64px; }
  .blk { margin-bottom:34px; }
  .blk-head { display:flex; align-items:flex-end; justify-content:space-between; gap:14px; margin-bottom:16px; flex-wrap:wrap; }
  .blk-head h2 { font-size:var(--fs-h3); }

  #rounds, #news, #rules { scroll-margin-top: calc(var(--nav-h) + 54px + 8px); }
  @media (max-width: 980px){ #rounds, #news, #rules { scroll-margin-top: calc(var(--nav-h) + 8px); } }

  .round-item { display:grid; grid-template-columns:auto 1fr auto auto; gap:16px; align-items:center; padding:15px 18px; }
  .round-n { width:46px; height:46px; border-radius:var(--r-md); background:var(--surface-2); border:1px solid var(--line); display:flex; align-items:center; justify-content:center; font-family:var(--num); font-weight:700; font-size:1.1rem; color:var(--text-1); flex:none; }
  .round-n.active { background:var(--brand-soft); border-color:var(--brand-line); color:var(--brand-bright); }

  .id-chip { font-family:var(--num); font-weight:700; letter-spacing:.2em; background:var(--surface-3); border:1px dashed var(--line-strong); padding:6px 12px; border-radius:var(--r-sm); color:var(--text-1); cursor:pointer; }

  .rules-list { counter-reset:r; }
  .rule { display:flex; gap:14px; padding:13px 0; border-bottom:1px solid var(--line); }
  .rule:last-child { border:none; }
  .rule-n { counter-increment:r; font-family:var(--num); font-weight:700; color:var(--brand-bright); flex:none; width:26px; }
  .rule-n::before { content:counter(r,decimal-leading-zero); }

  .news-item { display:flex; gap:14px; padding:14px 0; border-bottom:1px solid var(--line); }
  .news-item:last-child { border:none; }
  .news-date { font-family:var(--num); font-size:var(--fs-xs); color:var(--text-4); width:60px; flex:none; font-weight:700; }
  .sticky-side { position:sticky; top:128px; }
  .sticky-side > * + * { margin-top:18px; }
  @media (max-width: 980px){ .sec-layout { grid-template-columns:1fr; } .sticky-side { position:static; } }

  @media (max-width: 600px){
    .season-hero-inner .row.g-3.wrap-gap { width:100%; flex-direction:column; align-items:stretch; gap:10px; }
    .season-hero-inner .row.g-3.wrap-gap .btn { width:100%; padding:14px 20px; font-size:var(--fs-base); }
    .sh-meta { gap:18px; }
    .sh-meta .n { font-size:1.4rem; }
    .round-item { grid-template-columns:auto 1fr; column-gap:14px; row-gap:10px; align-items:center; }
    .round-item > div { grid-column:2; }
    .round-item .rnd-pts { grid-column:2; justify-self:start; }
    .round-item .rnd-btn { grid-column:1 / -1; justify-self:stretch; text-align:center; }
  }
` }) %>

<%
  // dáta sezóny pre hero (predáva leagueDetailPage pri _standaloneView); fallback na league
  const sea = (typeof standaloneSeason !== 'undefined' && standaloneSeason) ? standaloneSeason : null;
  const heroName = league.name;
  const heroDesc = (sea && sea.description) || league.description || '';
  const heroImage = sea && sea.image ? sea.image : null;
  const heroStatus = sea ? sea.status : (league.ended ? 'ended' : 'active');
  const inviteId = league.joinCode || (sea && sea.inviteCode) || '—';
  const fmtName = (u) => u.firstName ? (u.firstName + ' ' + (u.lastName ? u.lastName[0] + '.' : '')).trim() : (u.username || 'Hráč');
  const initials = (u) => { const n = [u.firstName,u.lastName].filter(Boolean).join(' ') || u.username || '?'; return n.split(' ').map(w=>w[0]).filter(Boolean).slice(0,2).join('').toUpperCase(); };
  const roundAbbr = (name) => { const t = (name || '').trim(); if (!t) return '?'; const w = t.split(/\s+/); if (w.length > 1) return w.map(x=>x[0]).filter(Boolean).slice(0,3).join('').toUpperCase(); return t.substring(0,3).toUpperCase(); };
  const GR = ['135deg,var(--gold-bright),var(--gold-dim)','135deg,#3a7bd5,#1b3f72','135deg,#e0935a,#a45c28','135deg,#16a085,#0c5f4d','135deg,#7c5cff,#5b3fd6'];
  const s = league.scoringSystem || {};
%>

<!-- standalone subnav: turnaj nemá medzistupeň líg, len Prehľad + Rebríček -->
<div class="subnav"><div class="wrap subnav-inner">
  <a href="/seasons/<%= league.seasonId %>" class="row g-2" style="font-weight:700;color:var(--text-1);white-space:nowrap;padding-right:8px">
    <span class="team-logo" style="width:26px;height:26px;font-size:11px;background:linear-gradient(135deg,#7c5cff,#3b1f8a)"><%= (heroName||'T').substring(0,2).toUpperCase() %></span>
    <%= heroName %>
  </a>
  <span style="width:1px;height:22px;background:var(--line)"></span>
  <a class="subnav-link active" href="/seasons/<%= league.seasonId %>">Prehľad</a>
  <a class="subnav-link" href="/seasons/<%= league.seasonId %>/leaderboard">Rebríček</a>
</div></div>

<!-- ===== HERO ===== -->
<header class="season-hero">
  <div class="season-hero-bg"<% if (heroImage) { %> style="background-image:url('<%= heroImage %>');background-size:cover;background-position:center;opacity:0.45"<% } %>></div>
  <div class="wrap season-hero-inner">
    <div class="row g-2 wrap-gap" style="margin-bottom:14px">
      <span class="tag tag-gold">Samostatná liga</span>
      <% if (league.hasPassword) { %><span class="tag tag-muted">🔒 Heslo</span><% } %>
      <% if (heroStatus === 'ended') { %><span class="tag tag-muted">Ukončená</span>
      <% } else if (heroStatus === 'upcoming') { %><span class="tag tag-info">Pripravovaná</span>
      <% } else { %><span class="tag tag-live"><span class="dot"></span>Prebieha</span><% } %>
    </div>
    <div class="between wrap-gap" style="gap:20px;align-items:flex-end">
      <div>
        <h1 style="font-size:clamp(2.2rem,4vw,3.2rem)"><%= heroName %></h1>
        <p class="muted" style="margin-top:8px;max-width:54ch"><%= heroDesc %></p>
        <div class="sh-meta">
          <div><div class="n"><%= league.membersCount != null ? league.membersCount : '—' %></div><div class="l">hráčov</div></div>
          <div><div class="n"><%= rounds.length %></div><div class="l">kôl</div></div>
          <div><div class="n" style="cursor:pointer" data-copy data-copy-val="<%= inviteId %>" title="Kopírovať ID"><%= inviteId %></div><div class="l">ID turnaja</div></div>
        </div>
      </div>
      <div class="row g-3 wrap-gap">
        <% if (typeof canManage !== 'undefined' && canManage) { %>
          <a href="/seasons/<%= league.seasonId %>/manage" class="btn btn-secondary">Spravovať</a>
        <% } %>
        <% if (typeof isMember !== 'undefined' && isMember && !isCreator) { %>
          <form action="/leagues/<%= league.id %>/leave" method="POST" onsubmit="return confirm('Naozaj opustiť tento turnaj?')" style="display:inline">
            <button type="submit" class="btn btn-secondary">Opustiť turnaj</button>
          </form>
        <% } %>
        <% if (heroStatus !== 'ended') { %>
          <% if (typeof isMember !== 'undefined' && isMember) { %>
            <a href="/seasons/<%= league.seasonId %>/zapasy" class="btn btn-primary btn-lg">Tipovať zápasy →</a>
          <% } else if (typeof currentUserId !== 'undefined' && currentUserId) { %>
            <button class="btn btn-primary btn-lg" data-open-join>Pripojiť sa</button>
          <% } else { %>
            <a href="/login" class="btn btn-primary btn-lg">Pripojiť sa</a>
          <% } %>
        <% } %>
      </div>
    </div>
  </div>
</header>

<div class="wrap sec-layout">
  <main>
    <!-- upozornenie: turnaj nemá tímy (len pre správcu, ak nie je zo šablóny) -->
    <% if (typeof canManage !== 'undefined' && canManage && !league.templateId && typeof teamsCount !== 'undefined' && teamsCount === 0) { %>
    <div class="card card-pad" style="border-color:var(--warning-line,rgba(245,180,80,.4));margin-bottom:16px;display:flex;gap:12px;align-items:flex-start">
      <span style="font-size:18px">⚠️</span>
      <div>
        <b class="hi">Turnaj nemá žiadne tímy</b>
        <p class="muted" style="font-size:var(--fs-sm);margin-top:4px">Bez tímov nevieš vytvárať zápasy. Prirad ich v <a href="/seasons/<%= league.seasonId %>/manage" style="text-decoration:underline">správe turnaja</a>.</p>
      </div>
    </div>
    <% } %>

    <!-- KOLÁ -->
    <section class="blk" id="rounds">
      <div class="blk-head">
        <div><div class="eyebrow">Kolá turnaja</div><h2><%= rounds.length %> kôl · tipuj zápasy</h2></div>
        <% if (typeof canManage !== 'undefined' && canManage && !league.templateId && !league.ended) { %><a href="/rounds/create?league=<%= league.id %>" class="btn btn-brand btn-sm">+ Vytvoriť kolo</a><% } %>
      </div>
      <div class="stack g-3">
        <% if (rounds.length === 0) { %>
          <p class="muted">V tomto turnaji zatiaľ nie sú žiadne kolá.</p>
        <% } %>
        <% rounds.forEach(function (r) { %>
          <% if (r.status === 'open') { %>
          <div class="card round-item" style="border-color:var(--brand-line)">
            <span class="round-n active"><%= roundAbbr(r.name) %></span>
            <div><div class="row g-2 wrap-gap"><b class="hi"><%= r.description || r.name %></b><span class="tag tag-warning"><span class="dot"></span>Otvorené</span></div><div class="muted" style="font-size:var(--fs-sm)"><%= r.matchesCount %> zápasov · uzávierka <%= new Date(r.endDate).toLocaleDateString('sk-SK') %></div></div>
            <span class="rnd-pts muted" style="font-size:var(--fs-sm)"><% if (isMember) { %>tipuješ <b class="hi"><%= r.myTips %>/<%= r.matchesCount %></b><% } %></span>
            <a href="/rounds/<%= r.id %>" class="rnd-btn btn <%= isMember ? 'btn-primary' : 'btn-secondary' %> btn-sm"><%= isMember ? 'Tipovať' : 'Pozrieť' %></a>
          </div>
          <% } else if (r.status === 'finished') { %>
          <div class="card round-item">
            <span class="round-n"><%= roundAbbr(r.name) %></span>
            <div><div class="row g-2 wrap-gap"><b class="hi"><%= r.description || r.name %></b><span class="tag tag-success"><span class="dot"></span>Ukončené</span></div><div class="muted" style="font-size:var(--fs-sm)"><%= r.matchesCount %> zápasov · <%= new Date(r.endDate).toLocaleDateString('sk-SK') %></div></div>
            <span class="rnd-pts muted" style="font-size:var(--fs-sm)"></span>
            <a href="/rounds/<%= r.id %>" class="rnd-btn btn btn-secondary btn-sm">Výsledky</a>
          </div>
          <% } else { %>
          <div class="card round-item" style="opacity:.6">
            <span class="round-n"><%= roundAbbr(r.name) %></span>
            <div><div class="row g-2 wrap-gap"><b class="hi"><%= r.description || r.name %></b><span class="tag tag-info">Naplánované</span></div><div class="muted" style="font-size:var(--fs-sm)">Otvorí sa <%= new Date(r.startDate).toLocaleDateString('sk-SK') %></div></div>
            <span class="rnd-pts muted" style="font-size:var(--fs-sm)">—</span>
            <span class="rnd-btn btn btn-ghost btn-sm" aria-disabled="true">Čaká</span>
          </div>
          <% } %>
        <% }); %>
      </div>
    </section>

    <!-- CENY -->
    <% var _pz = []; try { _pz = JSON.parse((sea && sea.prizes) || '[]'); } catch (e) { _pz = []; } %>
    <% if (sea && sea.showPrizes !== false && _pz.length) { %>
    <section class="blk" id="prizes">
      <div class="blk-head"><div><div class="eyebrow" style="color:var(--gold)">Ceny</div><h2>O čo sa hrá</h2></div></div>
      <div class="card card-pad">
        <div class="stack g-2">
          <% _pz.forEach(function (p, i) { %>
          <div class="row between prize-item" style="padding:12px 14px;border-radius:var(--r-sm);background:<%= i === 0 ? 'linear-gradient(90deg,rgba(212,175,55,.14),transparent)' : i === 1 ? 'linear-gradient(90deg,rgba(160,174,192,.12),transparent)' : i === 2 ? 'linear-gradient(90deg,rgba(176,112,60,.12),transparent)' : 'var(--surface-2)' %>">
            <span class="row g-3" style="align-items:center">
              <span style="width:34px;height:34px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-family:var(--num);flex:none;background:<%= i === 0 ? 'linear-gradient(135deg,#f6d365,#b8860b)' : i === 1 ? 'linear-gradient(135deg,#e2e8f0,#94a3b8)' : i === 2 ? 'linear-gradient(135deg,#e0a878,#8c5a2b)' : 'var(--surface-3, var(--line))' %>;color:<%= i < 3 ? '#0b0b12' : 'var(--text-2)' %>"><%= p.place %></span>
              <span class="muted" style="font-size:var(--fs-sm)"><%= p.place %>. miesto</span>
            </span>
            <b class="hi" style="font-size:var(--fs-md)"><%= p.prize %></b>
          </div>
          <% }); %>
        </div>
      </div>
    </section>
    <% } %>

    <!-- AKTUALITY -->
    <% if (!sea || sea.showNews !== false) { %>
    <section class="blk" id="news">
      <div class="blk-head"><div><div class="eyebrow">Aktuality</div><h2>Novinky v turnaji</h2></div></div>
      <div class="card card-pad">
        <% var newsList = (typeof news !== 'undefined' && news) ? news : []; %>
        <% if (newsList.length === 0) { %>
          <p class="muted" style="font-size:var(--fs-sm)">Zatiaľ žiadne novinky. Keď pribudne kolo, otvorí sa tipovanie alebo sa vyhodnotí kolo, objaví sa to tu.</p>
        <% } else { %>
        <% newsList.forEach(function(n){ %>
        <div class="news-item">
          <span class="news-date"><%= n.at ? new Date(n.at).toLocaleDateString('sk-SK',{day:'numeric',month:'short'}) : '' %></span>
          <div>
            <div class="row g-2 wrap-gap" style="margin-bottom:3px"><span class="tag <%= n.tagClass %>"><%= n.tagText %></span><b class="hi"><%= n.title %></b></div>
            <p class="muted" style="font-size:var(--fs-sm)"><%= n.desc %></p>
          </div>
        </div>
        <% }); %>
        <% } %>
      </div>
    </section>
    <% } %>

    <!-- PRAVIDLÁ -->
    <% if (!sea || sea.showRules !== false) { %>
    <div class="blk-head" id="rules"><div><div class="eyebrow">Pravidlá</div><h2>Ako sa hrá a boduje</h2></div></div>
    <div class="card card-pad">
      <div class="rules-list">
        <div class="rule"><span class="rule-n"></span><p>Tipuješ <b class="hi">presný výsledok</b> každého zápasu pred uzávierkou kola. Po uzávierke už tip nezmeníš.</p></div>
        <div class="rule"><span class="rule-n"></span><p>Body sa prideľujú automaticky po zadaní výsledku administrátorom turnaja.</p></div>
        <div class="rule"><span class="rule-n"></span><p>Zrušený zápas neprideľuje žiadne body — nikomu (ani za správny tip víťaza).</p></div>
        <div class="rule"><span class="rule-n"></span><p>Pri rovnosti bodov rozhoduje vyšší počet presných výsledkov, potom skorší dátum registrácie.</p></div>
      </div>
      <div class="hr" style="margin:18px 0"></div>
      <div class="score-grid">
        <div class="card stat" style="background:var(--surface-2);padding:12px 16px"><div class="stat-value max" style="font-size:1.5rem;color:var(--success)">+<%= s.exactScore != null ? s.exactScore : 10 %></div><div class="stat-label">presný výsledok</div></div>
        <div class="card stat" style="background:var(--surface-2);padding:12px 16px"><div class="stat-value" style="font-size:1.5rem">+<%= s.correctWinner != null ? s.correctWinner : 3 %></div><div class="stat-label">víťaz / remíza</div></div>
        <div class="card stat" style="background:var(--surface-2);padding:12px 16px"><div class="stat-value" style="font-size:1.5rem">+<%= s.goalDifference != null ? s.goalDifference : 2 %></div><div class="stat-label">gólový rozdiel</div></div>
        <div class="card stat" style="background:var(--surface-2);padding:12px 16px"><div class="stat-value" style="font-size:1.5rem">+<%= s.correctGoals != null ? s.correctGoals : 1 %></div><div class="stat-label">góly tímu</div></div>
      </div>
    </div>
    <% } %>
  </main>

  <!-- ===== SIDE ===== -->
  <aside class="sticky-side">
    <% if (typeof isMember !== 'undefined' && isMember) { %>
    <div class="card card-pad">
      <div class="stat-label" style="margin-bottom:14px">Tvoj progress v turnaji</div>
      <div class="row g-3" style="margin-bottom:14px">
        <div style="flex:1;text-align:center"><div class="stat-value brand" style="font-size:1.6rem"><%= myRank ? '#' + myRank : '—' %></div><div class="stat-label">pozícia<%= leaderboard.length ? ' z ' + leaderboard.length : '' %></div></div>
        <div style="flex:1;text-align:center"><div class="stat-value gold" style="font-size:1.6rem"><%= myPoints %></div><div class="stat-label">body</div></div>
      </div>
      <div class="ms-prog-row between" style="font-size:var(--fs-xs);color:var(--text-3);margin-bottom:6px"><span>Odohraných kôl</span><b class="hi num"><%= playedRounds %> / <%= rounds.length %></b></div>
      <div class="progress"><i style="width:<%= rounds.length > 0 ? Math.round((playedRounds / rounds.length) * 100) : 0 %>%"></i></div>
    </div>
    <% } %>

    <div class="card card-pad">
      <div class="between" style="margin-bottom:12px"><div class="stat-label" style="margin:0">Rebríček turnaja</div><a href="/seasons/<%= league.seasonId %>/leaderboard" class="faint" style="font-size:var(--fs-xs)">Celý →</a></div>
      <div class="lb">
        <% if (leaderboard.length === 0) { %>
          <p class="muted" style="font-size:var(--fs-sm)">Rebríček je zatiaľ prázdny.</p>
        <% } %>
        <% leaderboard.slice(0,8).forEach(function (entry, i) { var u = entry.user || entry; var meRow = (typeof currentUserId !== 'undefined' && currentUserId && u.id === currentUserId); %>
        <div class="lb-row" data-player-link="<%= u.id %>" data-me="<%= meRow ? '1' : '0' %>"><span class="lb-rank <%= i===0?'top1':i===1?'top2':i===2?'top3':'' %>"><%= i+1 %></span><div class="lb-user"><%- include('partials/avatar', { image: u.profileImage || '', initials: initials(u), cls: 'avatar-sm', grad: 'linear-gradient('+GR[i % GR.length]+')', ink: (i===0?'var(--gold-ink)':'#fff') }) %><span class="lb-name"><%= fmtName(u) %></span></div><span class="lb-pts <%= i===0?'gold':'' %>"><%= entry.totalPoints != null ? entry.totalPoints : 0 %></span></div>
        <% }); %>
      </div>
    </div>

    <div class="card card-pad">
      <div class="stat-label" style="margin-bottom:10px">Bodovanie v turnaji</div>
      <div class="stack g-2" style="font-size:var(--fs-sm)">
        <div class="between"><span class="muted">Presný výsledok</span><span class="pts-pill max">+<%= s.exactScore != null ? s.exactScore : 10 %></span></div>
        <div class="between"><span class="muted">Víťaz / remíza</span><span class="pts-pill">+<%= s.correctWinner != null ? s.correctWinner : 3 %></span></div>
        <div class="between"><span class="muted">Gólový rozdiel</span><span class="pts-pill">+<%= s.goalDifference != null ? s.goalDifference : 2 %></span></div>
        <div class="between"><span class="muted">Góly tímu</span><span class="pts-pill">+<%= s.correctGoals != null ? s.correctGoals : 1 %></span></div>
      </div>
    </div>

    <div class="card card-pad" style="background:linear-gradient(135deg,var(--surface-1),color-mix(in srgb,var(--gold) 8%,var(--surface-1)))">
      <b class="hi" style="display:block;margin-bottom:6px">Pozvi kamošov</b>
      <p class="muted" style="font-size:var(--fs-sm);margin-bottom:10px">Pošli kamošom ID turnaja.</p>
      <div class="row g-2"><span class="id-chip" data-copy data-copy-val="<%= inviteId %>" style="flex:1;text-align:center"><%= inviteId %></span><button class="btn btn-primary btn-sm" data-copy data-copy-val="<%= inviteId %>">Kopírovať</button></div>
    </div>
  </aside>
</div>

<!-- ===== JOIN DIALOG ===== -->
<div class="scrim" data-join hidden>
  <form class="dialog" action="/leagues/join" method="POST" data-join-form>
    <div class="between" style="margin-bottom:6px"><div class="dialog-title">Pripojiť sa do turnaja</div><button type="button" class="btn btn-ghost btn-icon" data-close-join>✕</button></div>
    <input type="hidden" name="joinCode" value="<%= league.joinCode %>">
    <% if (league.hasPassword) { %>
    <div class="field" style="margin-bottom:14px">
      <label class="label">Heslo turnaja</label>
      <input class="input" type="password" name="password" placeholder="••••••" required>
    </div>
    <% } else { %>
    <p class="muted" style="font-size:var(--fs-sm);margin-bottom:14px">Pripojíš sa do turnaja „<%= league.name %>".</p>
    <% } %>
    <div class="field-error" data-join-error hidden style="color:var(--danger);font-size:var(--fs-sm);margin-bottom:14px"></div>
    <div class="row g-2" style="justify-content:flex-end"><button type="button" class="btn btn-secondary" data-close-join>Zrušiť</button><button type="submit" class="btn btn-primary">Pripojiť sa</button></div>
  </form>
</div>

<script>
  // otvorenie/zatvorenie join dialógu + kopírovanie ID
  document.addEventListener('click', function (e) {
    var copy = e.target.closest('[data-copy]');
    if (copy) {
      var val = copy.getAttribute('data-copy-val') || copy.textContent.trim();
      if (navigator.clipboard) navigator.clipboard.writeText(val);
      var t = document.createElement('div');
      t.textContent = 'Skopírované ✓';
      t.style.cssText = 'position:fixed;bottom:24px;left:50%;transform:translateX(-50%);background:var(--success,#2e9e5b);color:#fff;padding:9px 16px;border-radius:10px;z-index:300;font-size:14px;box-shadow:0 4px 16px rgba(0,0,0,.3)';
      document.body.appendChild(t);
      setTimeout(function(){ t.remove(); }, 1600);
    }
    var dlg = document.querySelector('[data-join]');
    if (!dlg) return;
    if (e.target.closest('[data-open-join]')) { dlg.removeAttribute('hidden'); var _je=dlg.querySelector('[data-join-error]'); if(_je){_je.setAttribute('hidden','');_je.textContent='';} var _jp=dlg.querySelector('input[type=password]'); if(_jp){_jp.value='';} }
    else if (e.target.closest('[data-close-join]')) { dlg.setAttribute('hidden',''); }
  });

  // Pripojenie cez fetch — zlé heslo zobrazí chybu priamo v modáli.
  (function () {
    var form = document.querySelector('[data-join-form]');
    if (!form) return;
    var errBox = form.querySelector('[data-join-error]');
    var submitBtn = form.querySelector('button[type="submit"]');
    form.addEventListener('submit', function (e) {
      e.preventDefault();
      if (errBox) { errBox.setAttribute('hidden', ''); errBox.textContent = ''; }
      if (submitBtn) submitBtn.disabled = true;
      var body = new URLSearchParams(new FormData(form));
      fetch('/leagues/join', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-Requested-With': 'fetch', 'Accept': 'application/json' },
        body: body.toString(),
      }).then(function (r) { return r.json().catch(function () { return {}; }).then(function (d) { return { status: r.status, d: d }; }); })
        .then(function (res) {
          if (submitBtn) submitBtn.disabled = false;
          if (res.d && res.d.success) { window.location.href = res.d.redirect || window.location.href; return; }
          if (errBox) { errBox.textContent = (res.d && res.d.message) || 'Nepodarilo sa pripojiť. Skús to znova.'; errBox.removeAttribute('hidden'); }
        })
        .catch(function () {
          if (submitBtn) submitBtn.disabled = false;
          if (errBox) { errBox.textContent = 'Chyba spojenia. Skús to znova.'; errBox.removeAttribute('hidden'); }
        });
    });
  })();
</script>

