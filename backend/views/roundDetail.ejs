<%- include('partials/head', { title: round.name, page: 'seasons', active: 'seasons', pageStyle: `
  .round-layout { display:grid; grid-template-columns: 1fr 340px; gap:26px; align-items:start; padding:28px 0 60px; }
  .round-head { padding:26px 0 18px; }
  .crumb { font-size:var(--fs-sm); color:var(--text-4); margin-bottom:12px; }
  .crumb a { color:var(--text-3); } .crumb a:hover { color:var(--brand-bright); }
  .sticky-side > * + * { margin-top:18px; }
  .sticky-side { position:sticky; top:138px; }

  .match-list > * + * { margin-top:14px; }
  .match-row { padding:18px 20px; }
  .match-row.tipped { border-color: var(--brand-line); box-shadow: 0 0 0 1px var(--brand-line); }
  .onex2-pick { display:flex; gap:8px; }
  .onex2-btn { width:52px; height:48px; border-radius:12px; border:1px solid var(--line); background:var(--surface-2); color:var(--text-2); font-weight:800; font-size:1.2rem; cursor:pointer; transition:all .15s; }
  .onex2-btn:hover:not(:disabled) { border-color:var(--brand-line); color:var(--text-1); }
  .onex2-btn.sel { background:var(--brand); border-color:var(--brand); color:#fff; }
  .onex2-btn:disabled { opacity:.5; cursor:not-allowed; }
  .tip-num:disabled { opacity:.45; cursor:not-allowed; background:var(--surface-2); }
  .tip-num.hit { border-color:var(--success); box-shadow:0 0 0 1px var(--success); }
  .match-row.locked { opacity:.72; }
  .card-pts { font-size:var(--fs-sm); font-weight:700; }
  .card-pts.zero { color:var(--text-4); }

  .others { margin-top:14px; padding-top:14px; border-top:1px solid var(--line); display:none; }
  .others.open { display:block; }
  .other-tip { display:flex; align-items:center; gap:10px; padding:7px 0; }
  .other-tip .nm { font-weight:600; color:var(--text-2); font-size:var(--fs-sm); flex:1; }
  .toggle-others { font-size:var(--fs-sm); font-weight:600; color:var(--brand-bright); background:none; border:none; padding:0; margin-top:12px; }

  .savebar { position:sticky; bottom:0; z-index:30; margin-top:16px;
    background: color-mix(in srgb, var(--surface-1) 92%, transparent); backdrop-filter:blur(12px);
    border:1px solid var(--line-strong); border-radius: var(--r-lg); padding:14px 18px;
    display:flex; align-items:center; justify-content:space-between; gap:14px; box-shadow:var(--shadow-lg); }

  .toast-wrap { position:fixed; bottom:24px; right:24px; z-index:200; display:flex; flex-direction:column; gap:10px; }

  .mini-lb .lb-row { grid-template-columns: 30px 1fr auto; padding:9px 8px; }

  @media (max-width: 980px){
    .round-layout { grid-template-columns:1fr; }
    .sticky-side { position:static; }
  }
  @media (max-width: 900px){
    /* keep the sticky save bar above the bottom tab bar (60px) */
    .savebar { bottom: calc(64px + env(safe-area-inset-bottom, 0px)); border-radius: var(--r-lg); flex-direction:column; align-items:stretch; gap:10px; }
    .savebar .row.g-2 { width:100%; }
    .savebar .row.g-2 .btn { flex:1; }
    .toast-wrap { bottom: calc(74px + env(safe-area-inset-bottom, 0px)); right:12px; left:12px; }
    .round-head { padding-top: 16px; }
    /* header: countdown card spans full width below the title */
    .round-head .between { flex-direction:column; align-items:stretch; gap:14px; }
    .round-head .between > .card { width:100%; text-align:center; }
    .round-head .between > .card .countdown { justify-content:center; }
    /* tab segment full width */
    .round-head .segment { display:flex; }
    .round-head .segment button { flex:1; text-align:center; padding-inline:8px; }
  }
  @media (max-width: 480px){
    /* tighten match cards so team names fit on one/two lines */
    .match-row { padding:16px; }
    .match-row .match-teams { gap:8px; }
    .match-row .team-name { font-size:var(--fs-xs); line-height:1.15; text-align:center; white-space:normal; overflow:visible; text-overflow:clip; max-width:none; word-break:normal; }
    .match-row .tip-inputs { gap:5px; }
    .match-row .tip-num { width:42px; height:46px; font-size:1.2rem; }
  }
` }) %>

<%- include('partials/season-subnav', { seasonId: league.seasonId, seasonName: (league.Season && league.Season.name) || 'Sezóna', active: 'leagues' }) %>

<%
  function fmtDT(d){ if(!d) return ''; var dt=new Date(d); return dt.toLocaleDateString('sk-SK',{day:'numeric',month:'short'})+' · '+dt.toLocaleTimeString('sk-SK',{hour:'2-digit',minute:'2-digit'}); }
  function initials(n){ return (n||'?').split(' ').map(function(w){return w[0];}).filter(Boolean).slice(0,2).join('').toUpperCase(); }
  var s = scoring || {};
  var deadline = new Date(round.endDate);
  var isClone = typeof isClone !== 'undefined' ? isClone : false;
  var seasonLocked = typeof seasonLocked !== 'undefined' ? seasonLocked : false;
%>

<div class="wrap round-head">
  <div class="crumb"><a href="/seasons/<%= league.seasonId %>"><%= (league.Season && league.Season.name) || 'Sezóna' %></a> › <a href="/leagues/<%= league.id %>"><%= league.name %></a> › <%= round.name %></div>
  <div class="between wrap-gap" style="gap:16px">
    <div>
      <div class="row g-3 wrap-gap" style="margin-bottom:10px">
        <h1 style="font-size:clamp(1.9rem,3vw,2.5rem)"><%= round.name %><% if (round.description) { %> — <%= round.description %><% } %></h1>
        <% if (seasonLocked) { %><span class="tag tag-muted"><span class="dot"></span>Sezóna ukončená</span>
        <% } else if (round.status === 'open') { %><span class="tag tag-warning"><span class="dot"></span>Otvorené na tipovanie</span>
        <% } else if (round.status === 'finished') { %><span class="tag tag-success"><span class="dot"></span>Ukončené</span>
        <% } else { %><span class="tag tag-info">Naplánované</span><% } %>
      </div>
      <p class="muted" style="margin:0"><%= matches.length %> zápasov · tipuj presný výsledok · uzávierka <%= fmtDT(round.endDate) %></p>
      <% if (typeof isManager !== 'undefined' && isManager && !isClone) { %>
      <div class="row g-2 wrap-gap" style="margin-top:12px">
        <a href="/rounds/<%= round.id %>/matches/create" class="btn btn-secondary btn-sm">+ Pridať zápasy</a>
        <a href="/rounds/<%= round.id %>/evaluate" class="btn btn-brand btn-sm">Vyhodnotiť zápasy</a>
      </div>
      <% } %>
    </div>
    <% if (round.status === 'open' && !seasonLocked) { %>
    <div class="card card-pad" style="padding:14px 18px;background:var(--surface-2)">
      <div class="stat-label" style="margin-bottom:8px">Uzávierka o</div>
      <span class="countdown" id="countdown" data-deadline="<%= deadline.toISOString() %>">
        <span class="cd-box"><div class="cd-num" data-d>00</div><div class="cd-lbl">dni</div></span>
        <span class="cd-box"><div class="cd-num" data-h>00</div><div class="cd-lbl">hod</div></span>
        <span class="cd-box"><div class="cd-num" data-m>00</div><div class="cd-lbl">min</div></span>
        <span class="cd-box"><div class="cd-num" data-s>00</div><div class="cd-lbl">sek</div></span>
      </span>
    </div>
    <% } %>
  </div>
</div>

<div class="wrap round-layout">
  <main>
    <% if (round.status === 'scheduled' && !seasonLocked) { %>
      <div class="card card-pad" style="text-align:center;padding:48px"><p class="muted">Toto kolo sa otvorí <%= fmtDT(round.startDate) %>. Tipovanie zatiaľ nie je možné.</p></div>
    <% } else if (round.status === 'open' && !seasonLocked) { %>
    <!-- OTVORENÉ — TIPOVANIE -->
    <section>
      <div class="between" style="margin-bottom:16px">
        <h3 style="font-size:var(--fs-h4)">Zápasy na tip</h3>
        <span class="muted" style="font-size:var(--fs-sm)"><b class="hi" id="tippedCount"><%= tippedCount %></b> / <%= matches.length %> vyplnených</span>
      </div>
      <% if (matches.length === 0) { %>
        <div class="card card-pad" style="text-align:center;padding:40px"><p class="muted">V tomto kole zatiaľ nie sú žiadne zápasy.</p></div>
      <% } %>
      <div class="match-list" id="matchList">
        <% matches.forEach(function (m) {
             var isWinner = m.tipType === 'winner';
             var tipped = m.myTip && (isWinner ? m.myTip.winner : m.myTip.homeScore != null);
             var started = new Date(m.matchTime) <= new Date();
             var evaluated = m.status === 'finished';
             var canceled = m.status === 'canceled';
             var locked = started || (m.status && m.status !== 'scheduled');
             var myPts = m.myTip && m.myTip.points != null ? m.myTip.points : null;
        %>
        <div class="match match-row<%= tipped ? ' tipped' : '' %><%= locked ? ' locked' : '' %>" data-match data-match-id="<%= m.id %>" data-type="<%= isWinner ? 'winner' : 'exact' %>"<%= locked ? ' data-locked' : '' %>>
          <div class="match-head">
            <span class="match-meta"><%= fmtDT(m.matchTime) %><%= isWinner ? ' · tip: víťaz (1 X 2)' : '' %></span>
            <% if (evaluated) { %><span class="tag tag-success"><span class="dot"></span>Vyhodnotené</span>
            <% } else if (canceled) { %><span class="tag tag-muted"><span class="dot"></span>Zrušený</span>
            <% } else if (locked) { %><span class="tag tag-warning"><span class="dot"></span>Uzavretý</span>
            <% } else { %><span class="tag tag-info"><span class="dot"></span>Naplánovaný</span><% } %>
          </div>
          <div class="match-teams">
            <div class="team"><span class="team-logo" style="background:var(--surface-3)"><%= m.homeAbbr %></span><span class="team-name"><%= m.homeTeam ? m.homeTeam.name : '—' %></span></div>
            <% if (isWinner) { %>
              <div class="onex2-pick" role="group">
                <button type="button" class="onex2-btn<%= m.myTip && m.myTip.winner === 'home' ? ' sel' : '' %>" data-w="home"<%= locked ? ' disabled' : '' %>>1</button>
                <button type="button" class="onex2-btn<%= m.myTip && m.myTip.winner === 'draw' ? ' sel' : '' %>" data-w="draw"<%= locked ? ' disabled' : '' %>>X</button>
                <button type="button" class="onex2-btn<%= m.myTip && m.myTip.winner === 'away' ? ' sel' : '' %>" data-w="away"<%= locked ? ' disabled' : '' %>>2</button>
              </div>
            <% } else {
                 // zelený obrys, ak hráč trafil počet gólov daného tímu (len pri vyhodnotenom zápase)
                 var hitHome = evaluated && m.myTip && m.myTip.homeScore != null && m.myTip.homeScore === m.homeScore;
                 var hitAway = evaluated && m.myTip && m.myTip.awayScore != null && m.myTip.awayScore === m.awayScore;
            %>
              <div class="tip-inputs"><input class="tip-num<%= hitHome ? ' hit' : '' %>" data-home inputmode="numeric" maxlength="2" value="<%= m.myTip && m.myTip.homeScore != null ? m.myTip.homeScore : '' %>" placeholder="–"<%= locked ? ' disabled' : '' %>><span class="tip-sep">:</span><input class="tip-num<%= hitAway ? ' hit' : '' %>" data-away inputmode="numeric" maxlength="2" value="<%= m.myTip && m.myTip.awayScore != null ? m.myTip.awayScore : '' %>" placeholder="–"<%= locked ? ' disabled' : '' %>></div>
            <% } %>
            <div class="team away"><span class="team-logo" style="background:var(--surface-3)"><%= m.awayAbbr %></span><span class="team-name"><%= m.awayTeam ? m.awayTeam.name : '—' %></span></div>
          </div>
          <% if (evaluated) { %>
            <div class="between" style="margin-top:12px;padding-top:12px;border-top:1px solid var(--line)">
              <span class="muted" style="font-size:var(--fs-sm)">Konečný výsledok: <b class="hi"><%= m.homeScore %> : <%= m.awayScore %></b></span>
              <span class="card-pts<%= myPts ? '' : ' zero' %>"><%= myPts != null ? '+' + myPts + ' b' : '—' %></span>
            </div>
          <% } else if (locked && m.status === 'scheduled') { %>
            <div class="muted" style="font-size:var(--fs-xs);margin-top:8px;text-align:center">Tipovanie tohto zápasu je už uzavreté.</div>
          <% } %>
        </div>
        <% }); %>
      </div>
      <% if (matches.length > 0) { %>
      <div class="savebar">
        <span class="muted" style="font-size:var(--fs-sm)">Tipy môžeš meniť až do začiatku každého zápasu. <b class="hi"><span id="tippedCount2"><%= tippedCount %></span>/<%= matches.length %></b> vyplnených</span>
        <div class="row g-2"><button class="btn btn-primary" id="saveTips">Uložiť tipy</button></div>
      </div>
      <% } %>
    </section>
    <% } else { %>
    <!-- UKONČENÉ — VÝSLEDKY -->
    <section>
      <div class="between" style="margin-bottom:16px">
        <h3 style="font-size:var(--fs-h4)"><%= round.name %> — výsledky &amp; body</h3>
        <span class="pts-pill max">Tvoje kolo: +<%= myPoints %> pts</span>
      </div>
      <div class="match-list">
        <% matches.forEach(function (m) { var canceled = m.status === 'canceled'; var done = m.status === 'finished';
             var isWin = m.tipType === 'winner';
             var hitHome = done && !isWin && m.myTip && m.myTip.homeScore != null && m.myTip.homeScore === m.homeScore;
             var hitAway = done && !isWin && m.myTip && m.myTip.awayScore != null && m.myTip.awayScore === m.awayScore;
        %>
        <div class="match"<%= canceled ? ' style=\"opacity:.78\"' : (m.myTip && m.myTip.points >= (s.exactScore||10) ? ' style=\"border-color:var(--brand-line)\"' : '') %>>
          <div class="match-head"><span class="match-meta"><%= fmtDT(m.matchTime) %></span>
            <% if (canceled) { %><span class="tag tag-muted"><span class="dot"></span>Zrušený</span><% } else if (done) { %><span class="tag tag-success"><span class="dot"></span>Vyhodnotené</span><% } else { %><span class="tag tag-warning"><span class="dot"></span>Čaká na výsledok</span><% } %>
          </div>
          <div class="match-teams">
            <div class="team"><span class="team-logo" style="background:var(--surface-3)"><%= m.homeAbbr %></span><span class="team-name"><%= m.homeTeam ? m.homeTeam.name : '—' %></span></div>
            <div class="match-score"<%= canceled ? ' style=\"color:var(--text-4)\"' : '' %>><span<%= hitHome ? ' style=\"color:var(--success)\"' : '' %>><%= m.homeScore != null ? m.homeScore : '—' %></span> : <span<%= hitAway ? ' style=\"color:var(--success)\"' : '' %>><%= m.awayScore != null ? m.awayScore : '—' %></span></div>
            <div class="team away"><span class="team-logo" style="background:var(--surface-3)"><%= m.awayAbbr %></span><span class="team-name"><%= m.awayTeam ? m.awayTeam.name : '—' %></span></div>
          </div>
          <div class="between" style="margin-top:14px;padding-top:14px;border-top:1px solid var(--line)">
            <% var winLbl = function(w){ return w==='home'?'1 (domáci)':w==='draw'?'X (remíza)':w==='away'?'2 (hosť)':'—'; };
               var isWin = m.tipType === 'winner';
               var hasMy = m.myTip && (isWin ? m.myTip.winner : m.myTip.homeScore != null);
               var full = m.myTip && m.myTip.points >= (isWin ? (s.correctWinner||3) : (s.exactScore||10)); %>
            <% if (canceled) { %>
              <span class="muted" style="font-size:var(--fs-sm)">Zápas zrušený — body sa neprideľujú</span><span class="pts-pill zero">0 pts</span>
            <% } else if (hasMy) { %>
              <span class="muted" style="font-size:var(--fs-sm)">Tvoj tip: <b class="<%= full ? 'tip-correct' : 'hi' %>"><%= isWin ? winLbl(m.myTip.winner) : (m.myTip.homeScore + ' : ' + m.myTip.awayScore) %></b></span><span class="pts-pill<%= full ? ' max' : (m.myTip.points ? '' : ' zero') %>">+<%= m.myTip.points || 0 %></span>
            <% } else { %>
              <span class="muted" style="font-size:var(--fs-sm)">Netipoval si tento zápas</span><span class="pts-pill zero">0</span>
            <% } %>
          </div>
          <% if (m.others && m.others.length > 0) { %>
          <button class="toggle-others" data-others>Zobraziť tipy ostatných (<%= m.others.length %>) ▾</button>
          <div class="others">
            <% m.others.forEach(function (o) { %>
            <div class="other-tip"><span class="avatar avatar-sm" style="background:var(--surface-3)"><%= initials(o.name) %></span><span class="nm"><%= o.name %></span><b class="<%= o.points >= (m.tipType === 'winner' ? (s.correctWinner||3) : (s.exactScore||10)) ? 'tip-correct' : 'hi' %>"><%= m.tipType === 'winner' ? (o.winner==='home'?'1':o.winner==='draw'?'X':o.winner==='away'?'2':'–') : ((o.homeScore != null ? o.homeScore : '–') + ' : ' + (o.awayScore != null ? o.awayScore : '–')) %></b><span class="pts-pill<%= o.points >= (m.tipType === 'winner' ? (s.correctWinner||3) : (s.exactScore||10)) ? ' max' : (o.points ? '' : ' zero') %>">+<%= o.points || 0 %></span></div>
            <% }); %>
          </div>
          <% } %>
        </div>
        <% }); %>
      </div>
    </section>
    <% } %>
  </main>

  <aside class="sticky-side">
    <% if (round.status === 'open' && !seasonLocked) { %>
    <div class="card card-pad">
      <div class="stat-label">Tvoj progres v kole</div>
      <div class="row g-3" style="margin:12px 0 4px"><span class="stat-value brand" style="font-size:2.2rem" id="progNum"><%= tippedCount %></span><span class="muted" style="font-size:var(--fs-sm)">zo <%= matches.length %> zápasov<br>vyplnených</span></div>
      <div class="progress" style="margin-top:10px"><i id="progBar" style="width:<%= matches.length ? Math.round(tippedCount/matches.length*100) : 0 %>%"></i></div>
    </div>
    <% } %>

    <div class="card card-pad" id="rules">
      <div class="between" style="margin-bottom:12px"><div class="stat-label" style="margin:0">Bodovanie</div><a href="/leagues/<%= league.id %>" class="faint" style="font-size:var(--fs-xs)">Pravidlá →</a></div>
      <div class="stack g-2" style="font-size:var(--fs-sm)">
        <div class="between"><span class="muted">Presný výsledok</span><span class="pts-pill max">+<%= s.exactScore != null ? s.exactScore : 10 %></span></div>
        <div class="between"><span class="muted">Víťaz / remíza</span><span class="pts-pill">+<%= s.correctWinner != null ? s.correctWinner : 3 %></span></div>
        <div class="between"><span class="muted">Gólový rozdiel</span><span class="pts-pill">+<%= s.goalDifference != null ? s.goalDifference : 2 %></span></div>
        <div class="between"><span class="muted">Presný počet gólov tímu</span><span class="pts-pill">+<%= s.correctGoals != null ? s.correctGoals : 1 %></span></div>
      </div>
    </div>

    <div class="card card-pad mini-lb">
      <div class="between" style="margin-bottom:8px"><div class="stat-label" style="margin:0">Rebríček kola</div></div>
      <div class="lb">
        <% if (leaderboard.length === 0) { %><p class="muted" style="font-size:var(--fs-sm)">Zatiaľ bez bodov.</p><% } %>
        <% leaderboard.slice(0,6).forEach(function (e, i) { var u=e.user; var me = currentUserId && u.id === currentUserId; var nm = [u.firstName,u.lastName].filter(Boolean).join(' ')||u.username; %>
        <div class="lb-row<%= me ? ' me' : '' %>"><span class="lb-rank <%= i===0?'top1':i===1?'top2':i===2?'top3':'' %>"><%= i+1 %></span><div class="lb-user"><span class="avatar avatar-sm<%= me ? ' avatar-ring' : '' %>" style="background:<%= i===0?'linear-gradient(135deg,var(--gold-bright),var(--gold-dim));color:var(--gold-ink)':'var(--surface-3)' %>"><%= initials(nm) %></span><span class="lb-name"><%= me ? 'Ty' : nm %></span></div><span class="lb-pts"><%= e.totalPoints %></span></div>
        <% }); %>
      </div>
    </div>
  </aside>
</div>

<div class="toast-wrap" id="toastWrap" style="position:fixed;bottom:24px;right:24px;z-index:200;display:flex;flex-direction:column;gap:10px"></div>

<script>
(function () {
  function toast(msg, ok){ var t=document.createElement('div'); t.textContent=msg; t.style.cssText='background:'+(ok?'var(--success)':'var(--surface-2)')+';color:'+(ok?'#fff':'var(--text-1)')+';border:1px solid var(--line);padding:10px 14px;border-radius:10px'; document.getElementById('toastWrap').appendChild(t); setTimeout(function(){t.remove();},2500); }

  // countdown
  var cd = document.getElementById('countdown');
  if (cd) {
    var dl = new Date(cd.getAttribute('data-deadline')).getTime();
    function tick(){ var diff=dl-Date.now(); if(diff<0)diff=0; var d=Math.floor(diff/86400000),h=Math.floor(diff%86400000/3600000),m=Math.floor(diff%3600000/60000),s=Math.floor(diff%60000/1000); function p(n){return String(n).padStart(2,'0');} cd.querySelector('[data-d]').textContent=p(d); cd.querySelector('[data-h]').textContent=p(h); cd.querySelector('[data-m]').textContent=p(m); cd.querySelector('[data-s]').textContent=p(s); if(diff<3600000)cd.classList.add('cd-urgent'); }
    tick(); setInterval(tick,1000);
  }

  // je riadok vyplnený? (podľa typu)
  function rowFilled(row){
    if (row.hasAttribute('data-locked')) return row.classList.contains('tipped');
    if (row.getAttribute('data-type') === 'winner') return !!row.querySelector('.onex2-btn.sel');
    var h=row.querySelector('[data-home]'), a=row.querySelector('[data-away]');
    return h && a && h.value!=='' && a.value!=='';
  }
  // stav tlačidla: "Uložené" (neaktívne) keď niet zmien, "Uložiť tipy" (aktívne) keď sú
  var save = document.getElementById('saveTips');
  var dirty = false;
  // počiatočný stav: ak má hráč aspoň jeden tip, tlačidlo je "Uložené"; inak "Uložiť tipy"
  function setSaved(){ dirty=false; if(save){ save.disabled=true; save.textContent='Uložené'; } }
  function setDirty(){ if(!dirty){ dirty=true; if(save){ save.disabled=false; save.textContent='Uložiť tipy'; } } }

  // počítadlo vyplnených
  function recount(){ var n=0; document.querySelectorAll('[data-match]').forEach(function(row){ if(rowFilled(row)){n++;row.classList.add('tipped');}else{row.classList.remove('tipped');} });
    var els=[document.getElementById('tippedCount'),document.getElementById('tippedCount2'),document.getElementById('progNum')]; els.forEach(function(e){if(e)e.textContent=n;});
    var total=document.querySelectorAll('[data-match]').length; var bar=document.getElementById('progBar'); if(bar)bar.style.width=(total?Math.round(n/total*100):0)+'%'; }
  document.querySelectorAll('.tip-num').forEach(function(inp){ inp.addEventListener('input',function(){ this.value=this.value.replace(/[^0-9]/g,'').substring(0,2); recount(); setDirty(); }); });

  // 1 X 2 výber
  document.querySelectorAll('.onex2-pick').forEach(function(grp){
    grp.addEventListener('click', function(e){ var b=e.target.closest('.onex2-btn'); if(!b||b.disabled)return; grp.querySelectorAll('.onex2-btn').forEach(function(x){x.classList.remove('sel');}); b.classList.add('sel'); recount(); setDirty(); });
  });

  // uloženie tipov
  if (save) save.addEventListener('click', function () {
    if (save.disabled) return;
    var rows = document.querySelectorAll('[data-match]'); var ops=[];
    rows.forEach(function(row){
      if (row.hasAttribute('data-locked')) return; // uzavreté preskoč
      var id=Number(row.getAttribute('data-match-id'));
      if (row.getAttribute('data-type') === 'winner') {
        var sel=row.querySelector('.onex2-btn.sel'); if(sel){ ops.push(fetch('/api/tips',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({matchId:id,winner:sel.getAttribute('data-w')})}).then(function(r){return r.json();})); }
      } else {
        var h=row.querySelector('[data-home]').value, a=row.querySelector('[data-away]').value;
        if(h!==''&&a!==''){ ops.push(fetch('/api/tips',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({matchId:id,homeScore:Number(h),awayScore:Number(a)})}).then(function(r){return r.json();})); }
      }
    });
    if(ops.length===0){ toast('Vyplň aspoň jeden tip.'); return; }
    save.disabled=true; save.textContent='Ukladám…';
    Promise.all(ops).then(function(res){ var fail=res.filter(function(r){return r&&r.success===false;}); if(fail.length){ toast(fail[0].message||'Niektoré tipy sa neuložili.'); save.disabled=false; save.textContent='Uložiť tipy'; } else { toast('Tipy uložené ✓', true); setSaved(); } }).catch(function(){ toast('Chyba pri ukladaní.'); save.disabled=false; save.textContent='Uložiť tipy'; });
  });

  // tipy ostatných toggle
  document.addEventListener('click', function (e) {
    var b = e.target.closest('[data-others]'); if(!b) return;
    var others = b.nextElementSibling; if(others){ var open=others.style.display==='block'; others.style.display=open?'none':'block'; b.textContent = b.textContent.replace(/[▾▴]/, open?'▾':'▴'); }
  });

  recount();
  // počiatočný stav tlačidla: ak má hráč aspoň jeden uložený tip → "Uložené",
  // inak nech môže uložiť
  (function(){ var any=false; document.querySelectorAll('[data-match]').forEach(function(row){ if(row.classList.contains('tipped')) any=true; }); if(any){ setSaved(); } else if(save){ save.disabled=false; save.textContent='Uložiť tipy'; } })();
})();
</script>

