<%- include('partials/auth-head', { title: 'Registrácia', pageStyle: `
  .auth { min-height:100vh; display:grid; grid-template-columns: 1fr 1.05fr; }
  .auth-brand { position:relative; overflow:hidden; padding:48px; display:flex; flex-direction:column; justify-content:space-between;
    background: linear-gradient(150deg,#0a1130,#1d1140 50%,#140a2e); border-left:1px solid var(--line); order:2; }
  .auth-brand::before { content:""; position:absolute; inset:0; background:
    radial-gradient(600px 400px at 80% 10%, rgba(124,92,255,.35), transparent 60%),
    radial-gradient(500px 360px at 10% 90%, rgba(31,212,151,.12), transparent 55%); }
  .auth-brand > * { position:relative; z-index:1; }
  .auth-logo { display:flex; align-items:center; gap:11px; }
  .auth-form { display:flex; align-items:center; justify-content:center; padding:40px 24px; }
  .auth-card { width:100%; max-width:420px; }
  .auth-card h1 { font-size:1.9rem; }
  .field-row { display:grid; grid-template-columns:1fr 1fr; gap:14px; }
  .pw-meter { height:6px; background:var(--surface-3); border-radius:99px; overflow:hidden; margin-top:8px; display:flex; gap:3px; }
  .pw-meter i { flex:1; background:var(--surface-4); border-radius:99px; transition:background .2s; }
  .step-card { display:flex; gap:13px; align-items:flex-start; padding:14px 0; border-bottom:1px solid rgba(255,255,255,.08); }
  .step-card:last-child { border:none; }
  .step-n { width:30px; height:30px; border-radius:50%; flex:none; display:flex; align-items:center; justify-content:center; font-family:var(--num); font-weight:700; background:rgba(255,255,255,.1); color:#fff; font-size:14px; }
  @media (max-width: 860px){ .auth { grid-template-columns:1fr; } .auth-brand { display:none; } }
` }) %>

<div class="auth">
  <!-- FORM -->
  <div class="auth-form">
    <div class="auth-card">
      <div style="margin-bottom:26px"><%- include('partials/brand-lockup', { variant: 'horizontal', size: 38, fontSize: 20, href: '/' }) %></div>
      <h1>Vytvor si účet</h1>
      <p class="muted" style="margin:8px 0 26px">Zadarmo, za 30 sekúnd. Žiadna platobná karta.</p>
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="tag tag-danger" style="display:block;padding:10px 12px;margin-bottom:16px"><%= error %></div>
      <% } %>
      <form action="/register" method="POST">
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
        <div class="field-row" style="margin-bottom:16px">
          <div class="field"><label class="label">Meno</label><input class="input" name="firstName" placeholder="Martin"></div>
          <div class="field"><label class="label">Priezvisko</label><input class="input" name="lastName" placeholder="Novák"></div>
        </div>
        <div class="field" style="margin-bottom:16px"><label class="label">Prezývka</label><input class="input" name="username" placeholder="martinn" required><span class="hint">Pod týmto menom ťa uvidia ostatní v rebríčkoch.</span></div>
        <div class="field" style="margin-bottom:16px"><label class="label">E-mail</label><input class="input" type="email" name="email" placeholder="martin.novak@email.sk" required></div>
        <div class="field" style="margin-bottom:20px">
          <label class="label">Heslo</label>
          <input class="input" type="password" name="password" placeholder="Aspoň 8 znakov" id="pw" required>
          <div class="pw-meter" id="meter"><i></i><i></i><i></i><i></i></div>
        </div>
        <label class="check" style="margin-bottom:22px;align-items:flex-start"><input type="checkbox" name="agree" required> <span style="font-size:var(--fs-sm)">Súhlasím s <a href="#" class="brand">podmienkami</a> a <a href="#" class="brand">zásadami súkromia</a>.</span></label>
        <button class="btn btn-primary btn-lg btn-block" type="submit">Vytvoriť účet</button>
      </form>
      <p class="muted center" style="margin-top:24px;font-size:var(--fs-sm)">Už máš účet? <a href="/login" class="brand" style="font-weight:700">Prihlás sa</a></p>
    </div>
  </div>

  <!-- BRAND PANEL -->
  <div class="auth-brand">
    <a class="auth-logo" href="/">
      <span style="font-family:var(--font-display);font-weight:700;font-size:18px;color:rgba(255,255,255,.7)">Pripoj sa k 14 280 tipérom</span>
    </a>
    <div>
      <div style="font-family:var(--font-display);font-weight:700;font-size:clamp(1.8rem,2.6vw,2.5rem);line-height:1.1;color:#fff;letter-spacing:-.02em;margin-bottom:8px">Tri kroky a tipuješ</div>
      <div style="max-width:380px;margin-top:18px">
        <div class="step-card"><span class="step-n">1</span><div><b style="color:#fff">Vytvor si účet</b><div style="color:rgba(255,255,255,.6);font-size:var(--fs-sm)">Stačí e-mail a prezývka — žiadne zložitosti.</div></div></div>
        <div class="step-card"><span class="step-n">2</span><div><b style="color:#fff">Pridaj sa do ligy</b><div style="color:rgba(255,255,255,.6);font-size:var(--fs-sm)">Oficiálna sezóna alebo komunitná liga cez 6-miestne ID.</div></div></div>
        <div class="step-card"><span class="step-n">3</span><div><b style="color:#fff">Tipuj a vyhrávaj</b><div style="color:rgba(255,255,255,.6);font-size:var(--fs-sm)">Zbieraj body, stúpaj v rebríčku, odomykaj odznaky.</div></div></div>
      </div>
      <div class="card card-pad" style="margin-top:28px;background:rgba(255,255,255,.06);border-color:rgba(255,255,255,.12)">
        <div class="row g-2" style="margin-bottom:8px"><span class="avatar avatar-sm" style="background:linear-gradient(135deg,var(--gold-bright),var(--gold-dim));color:var(--gold-ink)">LV</span><b style="color:#fff">Lucia V.</b><span class="tag tag-gold" style="margin-left:auto">#1 hráčka</span></div>
        <p style="color:rgba(255,255,255,.75);font-size:var(--fs-sm);font-style:italic">„Najlepšia tipovacia liga na hokej. S kolegami máme vlastnú ligu už druhú sezónu."</p>
      </div>
    </div>
    <div style="color:rgba(255,255,255,.4);font-size:var(--fs-sm)">© 2026 tifo.sk</div>
  </div>
</div>
<script>
  const pw = document.getElementById('pw'), meter = document.getElementById('meter').children;
  pw.addEventListener('input', () => {
    let s = 0;
    if (pw.value.length >= 8) s++;
    if (/[A-Z]/.test(pw.value)) s++;
    if (/[0-9]/.test(pw.value)) s++;
    if (/[^A-Za-z0-9]/.test(pw.value)) s++;
    const colors = ['var(--danger)','var(--warning)','var(--warning)','var(--success)'];
    [...meter].forEach((b,i) => b.style.background = i < s ? colors[s-1] : 'var(--surface-4)');
  });
</script>
<script src="/js/enhance.js"></script>
</body>
</html>
