<%- include('partials/head', { title: round.name + ' — výsledky', page: 'seasons', active: 'seasons', pageStyle: `
  .rr-head { padding:24px 0 16px; }
  .crumb { font-size:var(--fs-sm); color:var(--text-4); margin-bottom:12px; }
  .crumb a { color:var(--text-3); } .crumb a:hover { color:var(--brand-bright); }
  .rr-layout { display:grid; grid-template-columns:1fr 320px; gap:26px; align-items:start; padding-bottom:64px; }
  .res-match { padding:0; overflow:hidden; margin-bottom:14px; }
  .res-top { display:grid; grid-template-columns:1fr auto 1fr; gap:16px; align-items:center; padding:18px 22px; }
  .res-team { display:flex; align-items:center; gap:12px; }
  .res-team.r { flex-direction:row-reverse; }
  .res-team .nm { font-family:var(--font-display); font-weight:700; font-size:var(--fs-lg); color:var(--text-1); }
  .res-scoreline { text-align:center; }
  .res-score { font-family:var(--num); font-weight:700; font-size:2rem; line-height:1; }
  .res-final { font-size:var(--fs-xs); color:var(--text-4); text-transform:uppercase; letter-spacing:.08em; margin-top:4px; }
  .your-tip-bar { display:flex; align-items:center; justify-content:space-between; gap:14px; padding:12px 22px; background:var(--surface-2); border-top:1px solid var(--line); flex-wrap:wrap; }
  .others { padding:14px 22px; border-top:1px solid var(--line); }
  .others-grid { display:flex; gap:8px; flex-wrap:wrap; margin-top:10px; }
  .other-tip { display:flex; align-items:center; gap:7px; padding:6px 11px; border-radius:var(--r-pill); background:var(--surface-1); border:1px solid var(--line); font-size:var(--fs-sm); }
  .other-tip .sc { font-family:var(--num); font-weight:700; }
  @media (max-width:980px){ .rr-layout { grid-template-columns:1fr; } }
  @media (max-width:560px){
    .res-top { grid-template-columns:1fr auto 1fr; gap:10px; padding:18px 14px; align-items:start; }
    .res-team { flex-direction:column; align-items:center; text-align:center; gap:7px; }
    .res-team.r { flex-direction:column; }
    .res-team .nm { font-size:var(--fs-sm); line-height:1.15; }
    .res-scoreline { align-self:center; }
    .res-score { font-size:1.6rem; }
  }
` }) %>
<%
  function scoreStr(h,a){ return (h!=null && a!=null) ? (h+' : '+a) : '—'; }
  function tipStr(t, tipType){
    if(!t) return '—';
    if(tipType === 'winner') return t.winner==='home'?'1':t.winner==='away'?'2':t.winner==='draw'?'X':'—';
    return (t.homeScore!=null && t.awayScore!=null) ? (t.homeScore+':'+t.awayScore) : '—';
  }
  function otherStr(o, tipType){
    if(tipType === 'winner') return o.winner==='home'?'1':o.winner==='away'?'2':o.winner==='draw'?'X':'—';
    return (o.homeScore!=null && o.awayScore!=null) ? (o.homeScore+':'+o.awayScore) : '—';
  }
  // farba avatara z mena (deterministicky)
  var AV=['#3a7bd5','#16a085','#d35400','#8e44ad','#7c5cff','#0e7a5f','#c2410c','#0369a1'];
  function avColor(s){ var h=0; for(var i=0;i<(s||'').length;i++) h=(h*31+s.charCodeAt(i))>>>0; return AV[h%AV.length]; }
%>

<div class="wrap rr-head">
  <div class="crumb"><a href="/leagues/<%= league.id %>"><%= league.name %></a> › <%= round.name %></div>
  <div class="between wrap-gap" style="gap:16px">
    <div>
      <div class="row g-2 wrap-gap">
        <h1 style="font-size:clamp(1.7rem,2.8vw,2.3rem)"><%= round.name %></h1>
        <% if (round.status === 'finished') { %><span class="tag tag-success"><span class="dot"></span>Vyhodnotené</span>
        <% } else if (round.status === 'open') { %><span class="tag tag-live"><span class="dot"></span>Prebieha</span>
        <% } else { %><span class="tag tag-info">Čoskoro</span><% } %>
      </div>
      <p class="muted" style="margin-top:6px"><%= totalMatches %> zápasov<% if (evaluatedCount > 0) { %> · vyhodnotených <%= evaluatedCount %><% } %><% if (meId) { %> · získal si <b class="ok">+<%= myPoints %> bodov</b><% } %></p>
    </div>
    <div class="row g-2"><a href="/rounds/<%= round.id %>" class="btn btn-secondary btn-sm">Detail kola →</a></div>
  </div>
</div>

<div class="wrap rr-layout">
  <main>
    <% if (matches.length === 0) { %>
      <div class="card card-pad center" style="text-align:center;padding:48px 24px"><p class="muted">Toto kolo zatiaľ nemá žiadne zápasy.</p></div>
    <% } %>
    <% matches.forEach(function(m){
       var border = m.quality === 'exact' ? 'border-color:var(--success-line)' : '';
    %>
      <div class="card res-match" style="<%= border %>">
        <div class="res-top">
          <div class="res-team"><span class="team-logo" style="width:40px;height:40px;font-size:12px;background:linear-gradient(135deg,#3a7bd5,#1b3f72)"><%= m.homeAbbr %></span><span class="nm"><%= m.home %></span></div>
          <div class="res-scoreline">
            <% if (m.status === 'finished') { %>
              <div class="res-score" <%= m.quality==='exact' ? 'style="color:var(--success)"' : '' %>><%= scoreStr(m.homeScore, m.awayScore) %></div>
              <div class="res-final">koniec</div>
            <% } else if (m.status === 'canceled') { %>
              <div class="res-score muted">—</div><div class="res-final">zrušený</div>
            <% } else { %>
              <div class="res-score muted">vs</div><div class="res-final">nehrané</div>
            <% } %>
          </div>
          <div class="res-team r"><span class="team-logo" style="width:40px;height:40px;font-size:12px;background:linear-gradient(135deg,#d52b1e,#8a1610)"><%= m.awayAbbr %></span><span class="nm"><%= m.away %></span></div>
        </div>

        <!-- môj tip -->
        <div class="your-tip-bar">
          <span class="row g-2">
            <span class="muted" style="font-size:var(--fs-sm)">Tvoj tip:</span>
            <% if (m.myTip) { %>
              <b class="num <%= m.quality==='exact' ? 'tip-correct' : m.quality==='zero' ? 'tip-wrong' : '' %>"><%= tipStr(m.myTip, m.tipType) %></b>
              <% if (m.status === 'finished') { %>
                <% if (m.quality==='exact') { %><span class="tag tag-success">Presný výsledok!</span>
                <% } else if (m.quality==='partial') { %><span class="tag" style="background:var(--brand-soft);color:var(--brand-bright)">Čiastočné body</span>
                <% } else if (m.quality==='zero') { %><span class="tag tag-danger">Nepresný</span><% } %>
              <% } %>
            <% } else { %>
              <b class="num muted">—</b><span class="muted" style="font-size:var(--fs-sm)">netipované</span>
            <% } %>
          </span>
          <% if (m.status === 'finished' && m.myTip) { %>
            <span class="pts-pill <%= m.quality==='exact' ? 'max' : m.quality==='zero' ? 'zero' : '' %>"><%= (m.myTip.points||0) %> bodov</span>
          <% } else if (m.status === 'canceled') { %>
            <span class="tag tag-muted">Zrušený</span>
          <% } %>
        </div>

        <!-- tipy ostatných (len po uzávierke / pre správcu) -->
        <% if (m.revealAll) { %>
          <div class="others">
            <span class="muted" style="font-size:var(--fs-xs);font-weight:600">Tipy ostatných (<%= m.othersCount %>)</span>
            <% if (m.othersCount === 0) { %>
              <div class="others-grid"><span class="other-tip muted">Nikto iný netipoval</span></div>
            <% } else { %>
              <div class="others-grid">
                <% m.others.forEach(function(o){ %>
                  <span class="other-tip"><span class="avatar avatar-sm" style="width:20px;height:20px;font-size:9px;background:<%= avColor(o.name) %>;color:#fff"><%= o.abbr %></span><span class="sc <%= o.exact ? 'tip-correct' : '' %>"><%= otherStr(o, m.tipType) %></span></span>
                <% }); %>
                <% if (m.othersMore > 0) { %><span class="other-tip muted">+<%= m.othersMore %> ďalších</span><% } %>
              </div>
            <% } %>
          </div>
        <% } else { %>
          <div class="others"><span class="muted" style="font-size:var(--fs-xs)">Tipy ostatných sa zobrazia po uzávierke kola.</span></div>
        <% } %>
      </div>
    <% }); %>
  </main>

  <aside style="position:sticky;top:140px">
    <div class="card card-pad card-glow">
      <div class="stat-label">Tvoj zisk v kole</div>
      <div class="stat-value gold" style="font-size:2.8rem;margin:6px 0">+<%= myPoints %></div>
      <p class="muted" style="font-size:var(--fs-sm)">bodov<% if (myExactCount || myPartialCount) { %> · <%= myExactCount %>× presný výsledok, <%= myPartialCount %>× čiastočné body<% } %></p>
      <% if (myRank) { %>
        <div class="hr" style="margin:14px 0"></div>
        <div class="between" style="font-size:var(--fs-sm)"><span class="muted">Pozícia v kole</span><b class="brand num">#<%= myRank %></b></div>
      <% } %>
    </div>

    <div class="card card-pad" style="margin-top:18px">
      <div class="stat-label" style="margin-bottom:12px">Rebríček <%= round.name %></div>
      <% if (leaderboard.length === 0) { %>
        <p class="muted" style="font-size:var(--fs-sm)">Zatiaľ žiadne body.</p>
      <% } else { %>
      <div class="lb">
        <% leaderboard.forEach(function(row, i){
           var name = [row.user.firstName, row.user.lastName].filter(Boolean).join(' ') || row.user.username || 'Hráč';
           var isMe = meId && row.user.id === meId;
           var ab = (name.match(/\b\w/g)||[]).join('').substring(0,2).toUpperCase();
           var rankCls = i===0?'top1':i===1?'top2':i===2?'top3':'';
        %>
          <div class="lb-row <%= isMe ? 'me' : '' %>">
            <span class="lb-rank <%= rankCls %>"><%= i+1 %></span>
            <div class="lb-user"><span class="avatar avatar-sm <%= isMe ? 'avatar-ring' : '' %>" style="background:<%= avColor(name) %>;color:#fff"><%= ab %></span><span class="lb-name"><%= isMe ? 'Ty ('+name+')' : name %></span></div>
            <span class="lb-pts <%= i===0 ? 'gold' : '' %>">+<%= row.totalPoints %></span>
          </div>
        <% }); %>
      </div>
      <% } %>
    </div>
  </aside>
</div>

<%- include('partials/footer') %>
