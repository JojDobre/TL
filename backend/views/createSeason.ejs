<%- include('partials/head', { title: 'Vytvoriť sezónu', page: 'seasons', active: 'seasons', pageStyle: `
  .form-head { padding:28px 0 8px; }
  .crumb { font-size:var(--fs-sm); color:var(--text-4); margin-bottom:12px; }
  .crumb a { color:var(--text-3); } .crumb a:hover { color:var(--brand-bright); }
  .form-layout { display:grid; grid-template-columns:1fr 340px; gap:28px; align-items:start; padding:20px 0 64px; }
  .form-card { padding:26px; }
  .form-card + .form-card { margin-top:18px; }
  .form-card h3 { font-size:var(--fs-h4); margin-bottom:4px; }
  .form-card .sub { color:var(--text-3); font-size:var(--fs-sm); margin-bottom:20px; }
  .field-row { display:grid; grid-template-columns:1fr 1fr; gap:16px; }
  .score-row { display:flex; align-items:center; gap:14px; padding:12px 0; border-bottom:1px solid var(--line); }
  .score-row:last-of-type { border:none; }
  .score-row .desc { flex:1; }
  .score-input { width:72px; }
  .score-input input { text-align:center; font-family:var(--num); font-weight:700; }
  .type-pick { display:grid; grid-template-columns:1fr 1fr; gap:14px; }
  .type-opt { padding:18px; border-radius:var(--r-md); border:1.5px solid var(--line); background:var(--surface-2); cursor:pointer; transition:all .15s; }
  .type-opt:hover { border-color:var(--line-strong); }
  .type-opt.sel { border-color:var(--brand); background:var(--brand-soft); }
  .type-opt .t-ic { font-size:22px; margin-bottom:8px; }
  .type-opt b { color:var(--text-1); display:block; margin-bottom:3px; }
  .upload { border:1.5px dashed var(--line-strong); border-radius:var(--r-md); padding:30px; text-align:center; background:var(--surface-2); cursor:pointer; transition:all .15s; }
  .upload:hover { border-color:var(--brand-line); background:var(--brand-soft); }
  .league-pick { display:flex; align-items:center; gap:12px; padding:11px 14px; border-radius:var(--r-sm); background:var(--surface-2); border:1px solid var(--line); margin-bottom:8px; }
  .preview-cover { height:120px; border-radius:var(--r-md); display:flex; align-items:flex-end; padding:14px; margin-bottom:14px; }
  .sticky-side { position:sticky; top:92px; }
  @media (max-width:980px){ .form-layout { grid-template-columns:1fr; } .sticky-side { position:static; } }
  @media (max-width:560px){ .field-row, .type-pick { grid-template-columns:1fr; } }
` }) %>

<div class="wrap form-head">
  <div class="crumb"><a href="/seasons">Sezóny</a> › Vytvoriť sezónu</div>
  <h1 style="font-size:clamp(1.8rem,3vw,2.4rem)">Vytvoriť novú sezónu</h1>
  <p class="muted" style="margin-top:6px">Sezóna je zastrešujúca súťaž, ktorá obsahuje ligy a kolá. Po vytvorení do nej môžeš pridávať ligy.</p>
</div>

<% if (typeof error !== 'undefined' && error) { %>
<div class="wrap"><div class="tag tag-danger" style="display:block;padding:12px 14px;margin-bottom:16px; text-wrap: auto;"><%= error %></div></div>
<% } %>

<form class="wrap form-layout" action="/seasons/create" method="POST">
  <% if (currentUserRole !== 'admin') { %><input type="hidden" name="type" value="community"><% } %>
  <main>
    <div class="card form-card">
      <h3>Druh súťaže</h3>
      <p class="sub">Vyber, či zakladáš klasickú sezónu s viacerými ligami, alebo jednoduchý samostatnú súťaž.</p>
      <div class="type-pick">
        <label class="type-opt sel" data-mode="classic"><input type="radio" name="mode" value="classic" hidden checked><div class="t-ic">📚</div><b>Klasická sezóna</b><span class="muted" style="font-size:var(--fs-sm)">Zastrešuje viacero líg a kôl. Hráči si vyberajú v rámci sezóny ligy, v ktorých budú súťažiť.</span></label>
        <label class="type-opt" data-mode="standalone"><input type="radio" name="mode" value="standalone" hidden><div class="t-ic">🎯</div><b>Samostatná liga</b><span class="muted" style="font-size:var(--fs-sm)">Jedna súťaž bez líg — rovno kolá a tipovanie. Jednoduchšie pre malé partie.</span></label>
      </div>

      <!-- info blok: prepína sa podľa zvoleného druhu -->
      <div class="card" id="modeInfo" style="background:var(--surface-2);padding:13px 15px;margin-top:16px;display:flex;gap:10px;align-items:flex-start">
        <span style="font-size:16px" id="modeInfoIcon">📚</span>
        <div>
          <b class="hi" id="modeInfoTitle" style="display:block;margin-bottom:3px">Klasická sezóna</b>
          <p class="muted" id="modeInfoText" style="font-size:var(--fs-sm)">Sezóna je zastrešujúca súťaž, ktorá obsahuje jednu alebo viac líg, každú s vlastnými kolami a bodovaním. Hodí sa, keď chceš mať pod jednou strechou viac samostatných tipovačiek (napr. rôzne druhy športov, oddelené futbalové ligy...) a spoločný prehľad. Po vytvorení do sezóny pridávaš ligy a v nich kolá.</p>
        </div>
      </div>
    </div>

    <div class="card form-card">
      <h3>Základné údaje</h3>
      <p class="sub">Ako sa sezóna volá a o čo v nej ide.</p>
      <div class="stack g-4">
        <div class="field"><label class="label">Názov sezóny</label><input class="input" id="nm" name="name" placeholder="napr. Futbalová sezóna 2026/2027" required oninput="document.getElementById('pvName').textContent=this.value||'Názov sezóny'"></div>
        <div class="field"><label class="label">Popis</label><textarea class="textarea" name="description" placeholder="Krátky popis sezóny, ktorý uvidia hráči…"></textarea></div>
      </div>
    </div>

    <% if (currentUserRole === 'admin') { %>
    <div class="card form-card">
      <h3>Typ sezóny</h3>
      <p class="sub">Oficiálne sezóny sú verejné s globálnym rebríčkom. Community sezóny vytvárajú a spravujú používatelia.</p>
      <div class="type-pick">
        <label class="type-opt sel" data-type="official"><input type="radio" name="type" value="official" hidden checked><div class="t-ic">🏆</div><b>Oficiálna</b><span class="muted" style="font-size:var(--fs-sm)">Verejná, globálny rebríček, overené turnaje. Iba pre adminov.</span></label>
        <label class="type-opt" data-type="community"><input type="radio" name="type" value="community" hidden><div class="t-ic">👥</div><b>Community</b><span class="muted" style="font-size:var(--fs-sm)">Vlastná sezóna pre tvoju partiu. Verejná alebo súkromná cez ID.</span></label>
      </div>
    </div>
    <% } %>

    <div class="card form-card">
      <h3>Trvanie sezóny</h3>
      <p class="sub">Dátumy určujú, či je sezóna aktívna. Voliteľné — nechaj prázdne pre neobmedzené trvanie.</p>
      <div class="field-row" style="display:flex;gap:14px;flex-wrap:wrap">
        <div class="field" style="flex:1;min-width:180px"><label class="label">Začiatok <span class="faint">(voliteľné)</span></label><input class="input" type="datetime-local" name="startDate"></div>
        <div class="field" style="flex:1;min-width:180px"><label class="label">Koniec <span class="faint">(voliteľné)</span></label><input class="input" type="datetime-local" name="endDate"></div>
      </div>
    </div>

    <div class="card form-card">
      <h3>Obrázok sezóny</h3>
      <p class="sub">Odkaz na cover obrázok zobrazený na kartách sezóny (voliteľné).</p>
      <div class="field"><label class="label">URL obrázka</label><input class="input" type="url" name="image" placeholder="https://… odkaz na obrázok" oninput="var p=document.querySelector('.preview-cover'); if(p){ if(this.value){p.style.backgroundImage='url(\''+this.value+'\')';p.style.backgroundSize='cover';p.style.backgroundPosition='center';}else{p.style.backgroundImage='';} }"></div>
    </div>

    <!-- STANDALONE: nastavenia ligy (zobrazí sa len pri samostatnej lige) -->
    <div class="card form-card" id="leagueCard" hidden>
      <h3>Nastavenia ligy</h3>
      <p class="sub">Samostatná liga je rovno tipovací turnaj. Tieto nastavenia sa použijú pre jej ligu. Bodovanie a tímy doplníš neskôr v správe.</p>
      <!-- typ ligy sa NEVYBERÁ — dedí typ sezóny (official/community) -->
      <label class="check" style="display:flex;align-items:center;gap:10px;margin-bottom:14px"><input type="checkbox" id="lgPwToggle"> <span>Chrániť ligu heslom</span></label>
      <div class="field" id="lgPwField" hidden><label class="label">Heslo ligy</label><input class="input" type="text" name="leaguePassword" placeholder="napr. kava2026"><span class="hint">Hráči ho budú musieť zadať pri pripojení cez ID.</span></div>

      <% if (typeof templates !== 'undefined' && templates.length > 0) { %>
      <div style="margin-top:18px;border-top:1px solid var(--line);padding-top:18px">
        <label class="label">Šablóna <span class="faint">(voliteľné)</span></label>
        <p class="muted" style="font-size:var(--fs-sm);margin:2px 0 10px">Vyber oficiálnu šablónu — skopírujú sa jej kolá a zápasy. Výsledky spravuje admin a prejavia sa automaticky. Bez šablóny si kolá vytvoríš sám.</p>
        <select class="select" name="templateId" id="tplSelect">
          <option value="">— Bez šablóny (vlastný turnaj) —</option>
          <% templates.forEach(function(t){ %><option value="<%= t.id %>"><%= t.name %></option><% }); %>
        </select>
        <div class="field" id="tipTypeField" hidden style="margin-top:12px">
          <label class="label">Typ tipovania</label>
          <select class="select" name="tipType" id="tipTypeSelect">
            <option value="exact_score" selected>Presný výsledok (skóre)</option>
            <option value="winner">Víťaz — 1 / X / 2 (možná remíza)</option>
            <option value="winner_no_draw">Víťaz bez remízy — 1 / 2</option>
          </select>
          <span class="hint">Platí pre všetky zápasy skopírované zo šablóny. Pri type „Víťaz“ sa použije len bodovanie za správneho víťaza.</span>
        </div>
        <div class="card" style="background:var(--surface-2);padding:11px 14px;margin-top:12px;display:flex;gap:9px;align-items:flex-start">
          <span style="font-size:15px">ℹ️</span><span style="font-size:var(--fs-sm);color:var(--text-2)">Pri turnaji zo šablóny nemôžeš meniť výsledky zápasov — riadi ich admin. Bodovanie a názov ostávajú tvoje.</span>
        </div>
      </div>
      <% } %>

      <div style="margin-top:18px;border-top:1px solid var(--line);padding-top:18px">
        <label class="label">Bodovanie</label>
        <p class="muted" style="font-size:var(--fs-sm);margin:2px 0 12px">Nastav, koľko bodov sa prideľuje za jednotlivé presnosti tipu.</p>
        <div class="score-row score-exact"><div class="desc"><b class="hi">Presný výsledok</b><div class="muted" style="font-size:var(--fs-sm)">Trafený presný počet gólov oboch tímov</div></div><div class="field score-input"><input class="input" type="number" min="0" name="exactScore" value="10"></div></div>
        <div class="score-row"><div class="desc"><b class="hi">Víťaz / remíza</b><div class="muted" style="font-size:var(--fs-sm)">Správne určený víťaz alebo remíza</div></div><div class="field score-input"><input class="input" type="number" min="0" name="correctWinner" value="3"></div></div>
        <div class="score-row score-exact"><div class="desc"><b class="hi">Gólový rozdiel</b><div class="muted" style="font-size:var(--fs-sm)">Trafený rozdiel skóre (napr. +2)</div></div><div class="field score-input"><input class="input" type="number" min="0" name="goalDifference" value="2"></div></div>
        <div class="score-row score-exact"><div class="desc"><b class="hi">Presný počet gólov tímu</b><div class="muted" style="font-size:var(--fs-sm)">Za každý správne tipnutý tím</div></div><div class="field score-input"><input class="input" type="number" min="0" name="correctGoals" value="1"></div></div>
        <p class="muted" id="scoreWinnerNote" hidden style="font-size:var(--fs-sm);margin-top:10px">Pri tipovaní na víťaza sa hodnotí len správne určený víťaz — ostatné položky sa nepoužijú.</p>
      </div>
    </div>

    <div class="card form-card" id="privacyCard"<%= currentUserRole === 'admin' ? ' hidden' : '' %>>
      <h3>Súkromie</h3>
      <p class="sub">Súkromná sezóna je chránená heslom. Ľudia mimo sezónu nevidia jej ligy ani rebríčky — pripoja sa len cez ID a heslo.</p>
      <label class="check" style="display:flex;align-items:center;gap:10px;margin-bottom:14px"><input type="checkbox" id="privToggle" name="isPrivate"> <span>Súkromná sezóna (chránená heslom)</span></label>
      <div id="privFields" hidden>
        <div class="field" style="margin-bottom:14px"><label class="label">Heslo sezóny</label><input class="input" type="text" name="password" placeholder="napr. kamarati2026"></div>
        <label class="check" style="display:flex;align-items:center;gap:10px"><input type="checkbox" name="hidden"> <span>Skryť zo zoznamu sezón (pripojiť sa dá len cez ID + heslo)</span></label>
      </div>
    </div>
  </main>

  <aside class="sticky-side">
    <div class="card card-pad">
      <div class="stat-label" style="margin-bottom:12px">Náhľad</div>
      <div class="preview-cover" style="background:linear-gradient(135deg,#0b4ea2,#1a1340)"><span class="tag <%= currentUserRole === 'admin' ? 'tag-brand' : 'tag-gold' %>"><%= currentUserRole === 'admin' ? 'Oficiálna' : 'Community' %></span></div>
      <h4 id="pvName">Názov sezóny</h4>
      <div class="row g-3" style="font-size:var(--fs-sm);color:var(--text-3);margin-top:8px"><span><b class="hi num">0</b> hráčov</span><span><b class="hi num">0</b> kôl</span><span id="pvLeagueStat"><b class="hi num">1</b> liga</span></div>
    </div>
    <div class="card card-pad" style="margin-top:18px;background:var(--surface-2)">
      <b class="hi" style="display:block;margin-bottom:6px">💡 Tip</b>
      <p class="muted" style="font-size:var(--fs-sm)" id="sideTip">Po vytvorení sezóny pridaj ligy a v nich kolá so zápasmi. Hráči sa do sezóny pripoja cez 6-miestne ID.</p>
    </div>
    <div class="card card-pad" style="margin-top:18px">
      <button type="submit" class="btn btn-primary btn-block">Vytvoriť sezónu</button>
      <a href="/seasons" class="btn btn-ghost btn-block" style="margin-top:8px">Zrušiť</a>
    </div>
  </aside>
</form>

<% if (currentUserRole === 'admin') { %>
<script>
  // výber typu sezóny + náhľadový tag
  document.querySelectorAll('.type-opt[data-type]').forEach(function (opt) {
    opt.addEventListener('click', function (e) {
      e.preventDefault();
      document.querySelectorAll('.type-opt[data-type]').forEach(function (o) { o.classList.remove('sel'); });
      opt.classList.add('sel');
      var radio = opt.querySelector('input[type=radio]'); if (radio) radio.checked = true;
      var tag = document.querySelector('.preview-cover .tag');
      var isCommunity = opt.getAttribute('data-type') === 'community';
      if (isCommunity) { tag.textContent = 'Community'; tag.className = 'tag tag-gold'; }
      else { tag.textContent = 'Oficiálna'; tag.className = 'tag tag-brand'; }
      // súkromie má zmysel len pre community (oficiálne sú vždy verejné)
      // a len pre klasickú sezónu (standalone chráni heslo LIGY) — zdieľaná logika
      if (window.updatePrivacyCard) window.updatePrivacyCard();
    });
  });
</script>
<% } %>

<script>
  // toggle súkromie (len pre neadminov, kde existuje)
  var pt = document.getElementById('privToggle');
  if (pt) pt.addEventListener('change', function () {
    document.getElementById('privFields').toggleAttribute('hidden', !this.checked);
  });
</script>

<script>
  // ===== prepínanie Klasická / Samostatná liga =====
  (function () {
    var infoMap = {
      classic: {
        icon: '📚', title: 'Klasická sezóna',
        text: 'Sezóna je zastrešujúca súťaž, ktorá obsahuje jednu alebo viac líg, každú s vlastnými kolami a bodovaním. Hodí sa, keď chceš mať pod jednou strechou viac samostatných tipovačiek (napr. rôzne druhy športov, oddelené futbalové ligy...) a spoločný prehľad. Po vytvorení do sezóny pridávaš ligy a v nich kolá.'
      },
      standalone: {
        icon: '🎯', title: 'Samostatná liga (turnaj)',
        text: 'Samostatná liga je jeden turnaj bez medzistupňa líg — vytvorí sa rovno tipovacia liga, do ktorej hneď pridávaš kolá a zápasy. Hráči sa pripoja cez jedno ID a rovno tipujú. Ideálne, keď chceš len jednu tipovačku a nepotrebuješ sa preklikávať cez sezóny a ligy.'
      }
    };
    var icon = document.getElementById('modeInfoIcon');
    var title = document.getElementById('modeInfoTitle');
    var text = document.getElementById('modeInfoText');
    var leagueCard = document.getElementById('leagueCard');
    var submitBtn = document.querySelector('.sticky-side .btn-primary');

    // Karta „Súkromie" (heslo SEZÓNY) sa zobrazuje len pre community + klasickú
    // sezónu. Pri standalone ju backend ignoruje (heslo rieši LIGA) — zobrazenie
    // oboch by znamenalo 2x heslo, z toho jedno nefunkčné.
    window.updatePrivacyCard = function () {
      var pc = document.getElementById('privacyCard');
      if (!pc) return;
      var typeRadio = document.querySelector('input[name=type]:checked');
      var isCommunity = typeRadio ? typeRadio.value === 'community' : true; // neadmin = vždy community
      var modeRadio = document.querySelector('input[name=mode]:checked');
      var isStandalone = !!(modeRadio && modeRadio.value === 'standalone');
      var show = isCommunity && !isStandalone;
      pc.toggleAttribute('hidden', !show);
      if (!show) {
        var t = document.getElementById('privToggle'); if (t) t.checked = false;
        var f = document.getElementById('privFields');
        if (f) {
          f.setAttribute('hidden', '');
          var p = f.querySelector('input[name=password]'); if (p) p.value = '';
          var h = f.querySelector('input[name=hidden]'); if (h) h.checked = false;
        }
      }
    };

    function applyMode(mode) {
      var info = infoMap[mode] || infoMap.classic;
      if (icon) icon.textContent = info.icon;
      if (title) title.textContent = info.title;
      if (text) text.textContent = info.text;
      if (leagueCard) leagueCard.toggleAttribute('hidden', mode !== 'standalone');
      if (submitBtn) submitBtn.textContent = mode === 'standalone' ? 'Vytvoriť samostatnú ligu' : 'Vytvoriť sezónu';
      var tip = document.getElementById('sideTip');
      if (tip) tip.textContent = mode === 'standalone'
        ? 'Po vytvorení samostatnej ligy pridaj rovno tímy a kolá so zápasmi. Hráči sa pripoja cez 6-miestne ID.'
        : 'Po vytvorení sezóny pridaj ligy a v nich tímy akolá so zápasmi. Hráči sa do sezóny pripoja cez 6-miestne ID.';
      var ls = document.getElementById('pvLeagueStat');
      if (ls) ls.toggleAttribute('hidden', mode === 'standalone');
      window.updatePrivacyCard();
    }

    document.querySelectorAll('.type-opt[data-mode]').forEach(function (opt) {
      opt.addEventListener('click', function (e) {
        e.preventDefault();
        document.querySelectorAll('.type-opt[data-mode]').forEach(function (o) { o.classList.remove('sel'); });
        opt.classList.add('sel');
        var r = opt.querySelector('input[type=radio]'); if (r) r.checked = true;
        applyMode(opt.getAttribute('data-mode'));
      });
    });

    // typ tipovania sa ponúka len ak je vybraná šablóna
    var tplSelect = document.getElementById('tplSelect');
    var tipField = document.getElementById('tipTypeField');
    var tipSelect = document.getElementById('tipTypeSelect');
    var scoreNote = document.getElementById('scoreWinnerNote');

    function syncScoreRows() {
      // polia sa iba skryjú — hodnoty ostávajú a pri tipe na víťaza sa nepoužijú
      var winner = !!(tipField && !tipField.hasAttribute('hidden') && tipSelect
        && (tipSelect.value === 'winner' || tipSelect.value === 'winner_no_draw'));
      document.querySelectorAll('.score-exact').forEach(function (row) {
        row.style.display = winner ? 'none' : '';
      });
      if (scoreNote) scoreNote.toggleAttribute('hidden', !winner);
    }
    function syncTipField() {
      if (!tplSelect || !tipField) return;
      tipField.toggleAttribute('hidden', !tplSelect.value);
      syncScoreRows();
    }
    if (tplSelect) tplSelect.addEventListener('change', syncTipField);
    if (tipSelect) tipSelect.addEventListener('change', syncScoreRows);
    syncTipField();

    // heslo ligy toggle
    var lgPwToggle = document.getElementById('lgPwToggle');
    var lgPwField = document.getElementById('lgPwField');
    if (lgPwToggle) lgPwToggle.addEventListener('change', function () {
      lgPwField.toggleAttribute('hidden', !this.checked);
      if (!this.checked) { var i = lgPwField.querySelector('input'); if (i) i.value = ''; }
    });
  })();
</script>

<%- include('partials/footer') %>
