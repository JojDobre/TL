    .gd-toc-m .toc-panel { margin-top:6px; padding:8px; border-radius:var(--r-md); background:var(--surface-1); border:1px solid var(--line); max-height:60vh; overflow:auto; box-shadow:0 8px 24px rgba(0,0,0,.28); }
    .gd-toc-m .toc-panel a { display:block; padding:9px 12px; font-size:var(--fs-sm); color:var(--text-2); border-radius:var(--r-sm); text-decoration:none; }
    .gd-toc-m .toc-panel a:hover, .gd-toc-m .toc-panel a.active { background:var(--brand-soft); color:var(--brand-bright); }
    .gd-toc-m .toc-panel .toc-group-label { font-size:var(--fs-xs); text-transform:uppercase; letter-spacing:.07em; color:var(--text-4); font-weight:700; padding:8px 12px 2px; }
  }
` }) %>

