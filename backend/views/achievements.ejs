<%- include('partials/head', { title: 'Odznaky', page: '', active: '', pageStyle: `
  .ac-head { padding:30px 0 20px; }
  .ac-summary { display:grid; grid-template-columns:repeat(3,1fr); gap:16px; margin-bottom:30px; }
  .ach-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(220px,1fr)); gap:16px; }
  .ach { padding:20px; border-radius:var(--r-lg); border:1px solid var(--line); background:var(--surface-1); position:relative; overflow:hidden; transition:transform .18s var(--ease-out),border-color .18s; }
  .ach.earned:hover { transform:translateY(-3px); }
  .ach.earned { border-color:var(--brand-line); }
  .ach.earned::before { content:""; position:absolute; top:0; left:0; right:0; height:2px; background:linear-gradient(90deg,transparent,var(--brand),transparent); }
  .ach.locked { opacity:.62; }
  .ach-ico { width:58px; height:58px; border-radius:var(--r-md); display:flex; align-items:center; justify-content:center; font-size:28px; margin-bottom:14px; }
  .ach.locked .ach-ico { background:var(--surface-3); filter:grayscale(1); }
  .ach-name { font-family:var(--font-display); font-weight:700; color:var(--text-1); font-size:var(--fs-lg); margin-bottom:4px; }
  .ach-desc { font-size:var(--fs-sm); color:var(--text-3); margin-bottom:14px; min-height:38px; }
  .ach-foot { display:flex; align-items:center; justify-content:space-between; gap:8px; }
  .ach-date { font-size:var(--fs-xs); color:var(--text-4); font-family:var(--num); }
  .rarity { font-size:10px; font-weight:800; text-transform:uppercase; letter-spacing:.08em; padding:3px 7px; border-radius:var(--r-xs); }
  .r-common { color:var(--text-3); background:var(--surface-2); }
  .r-rare { color:var(--info); background:var(--info-soft); }
  .r-epic { color:var(--brand-bright); background:var(--brand-soft); }
  .r-legend { color:var(--gold); background:var(--gold-soft); }
  .ac-progress { margin:6px 0 0; }
  .filters { display:flex; gap:8px; flex-wrap:wrap; margin-bottom:22px; }
  @media (max-width:560px){
    .ac-summary { grid-template-columns:1fr; }
    .filters .segment { display:flex; width:100%; }
    .filters .segment button { flex:1; text-align:center; padding-inline:6px; }
  }
` }) %>
<%
  // mapovanie rarity -> CSS trieda + slovenský názov (1:1 zo šablóny)
  function rCls(r){ return r==='rare'?'r-rare':r==='epic'?'r-epic':r==='legendary'?'r-legend':'r-common'; }
  function rName(r){ return r==='rare'?'Rare':r==='epic'?'Epic':r==='legendary'?'Legendary':'Common'; }
  // farebné pozadie ikony podľa rarity (earned)
  function icoBg(r){
    if(r==='legendary'||r==='epic') return 'background:var(--brand-soft);color:var(--brand-bright)';
    if(r==='rare') return 'background:var(--info-soft);color:var(--info)';
    return 'background:var(--success-soft);color:var(--success)';
  }
  var SK_M=['jan','feb','mar','apr','máj','jún','júl','aug','sep','okt','nov','dec'];
  function fmtDate(d){ if(!d) return ''; var x=new Date(d); return x.getDate()+'. '+SK_M[x.getMonth()]+' '+x.getFullYear(); }
%>

<div class="wrap ac-head">
  <div class="eyebrow">Achievementy</div>
  <h1 style="font-size:clamp(2rem,3.2vw,2.6rem)">Galéria odznakov</h1>
  <p class="muted" style="margin-top:6px">Plň výzvy, zbieraj odznaky a odomykaj rarity. Získal si <b class="hi"><%= earnedCount %> z <%= total %></b> odznakov.</p>

  <div class="ac-summary" style="margin-top:22px">
    <div class="card card-pad">
      <div class="between"><div class="stat-label" style="margin:0">Celkový progres</div><b class="brand num"><%= overallPct %> %</b></div>
      <div class="progress ac-progress" style="margin-top:12px"><i style="width:<%= overallPct %>%"></i></div>
      <div class="muted" style="font-size:var(--fs-sm);margin-top:10px"><%= earnedCount %> odomknutých · <%= lockedCount %> zostáva</div>
    </div>
    <div class="card card-pad">
      <div class="stat-label">Najvzácnejší odznak</div>
      <% if (rarest) { %>
      <div class="row g-2" style="margin-top:8px"><span style="font-size:26px"><%= rarest.icon %></span><div><b class="hi"><%= rarest.name %></b><div class="rarity <%= rCls(rarest.rarity) %>" style="display:inline-block;margin-top:3px"><%= rName(rarest.rarity) %></div></div></div>
      <% } else { %>
      <div class="muted" style="margin-top:10px;font-size:var(--fs-sm)">Zatiaľ žiadny — získaj svoj prvý odznak.</div>
      <% } %>
    </div>
    <div class="card card-pad">
      <div class="stat-label">Najbližší cieľ</div>
      <% if (nextGoal) { %>
      <div class="row between" style="margin-top:8px"><b class="hi"><%= nextGoal.icon %> <%= nextGoal.name %></b><span class="muted num" style="font-size:var(--fs-sm)"><%= nextGoal.current %> / <%= nextGoal.target %></span></div>
      <div class="progress ac-progress" style="margin-top:10px"><i style="width:<%= nextGoal.pct %>%"></i></div>
      <% } else { %>
      <div class="muted" style="margin-top:10px;font-size:var(--fs-sm)">Skvelé! Všetky merateľné ciele máš splnené.</div>
      <% } %>
    </div>
  </div>

  <div class="filters">
    <div class="segment"><button class="active" data-f>Všetky</button><button data-f>Získané · <%= earnedCount %></button><button data-f>Zamknuté · <%= lockedCount %></button></div>
  </div>
</div>

<div class="wrap" style="padding-bottom:64px">
  <div class="ach-grid">
    <% items.forEach(function(a){ %>
      <% if (a.earned) { %>
        <div class="ach earned">
          <div class="ach-ico" style="<%= icoBg(a.rarity) %>"><%= a.icon %></div>
          <div class="ach-name"><%= a.name %></div>
          <div class="ach-desc"><%= a.description %></div>
          <div class="ach-foot"><span class="ach-date">Získané <%= fmtDate(a.dateAwarded) %></span><span class="rarity <%= rCls(a.rarity) %>"><%= rName(a.rarity) %></span></div>
        </div>
      <% } else { %>
        <div class="ach locked">
          <div class="ach-ico"><%= a.icon %></div>
          <div class="ach-name"><%= a.name %></div>
          <div class="ach-desc"><%= a.description %></div>
          <% if (a.measurable && a.target > 0) { %>
            <div class="ac-progress">
              <div class="row between" style="font-size:var(--fs-xs);margin-bottom:5px"><span class="muted">Progres</span><b class="num hi"><%= a.current %> / <%= a.target %></b></div>
              <div class="progress<%= a.pct >= 100 ? ' success' : '' %>"><i style="width:<%= a.pct %>%"></i></div>
            </div>
          <% } else { %>
            <div class="ach-foot"><span class="muted" style="font-size:var(--fs-xs)">Zamknuté</span><span class="rarity <%= rCls(a.rarity) %>"><%= rName(a.rarity) %></span></div>
          <% } %>
        </div>
      <% } %>
    <% }); %>
  </div>
</div>

<script>
  document.querySelectorAll('[data-f]').forEach(function(b){ b.addEventListener('click', function(){
    document.querySelectorAll('[data-f]').forEach(function(x){ x.classList.toggle('active', x === b); });
    var t = b.textContent;
    document.querySelectorAll('.ach').forEach(function(a){
      var earned = a.classList.contains('earned');
      a.style.display = t.indexOf('Získané') === 0 ? (earned?'':'none') : t.indexOf('Zamknuté') === 0 ? (earned?'none':'') : '';
    });
  }); });
</script>

<%- include('partials/footer') %>
