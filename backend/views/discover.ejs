<%- include('partials/head', { title: 'Objaviť', page: 'seasons', active: 'seasons', pageStyle: `
  .dc-head { padding:30px 0 14px; }
  .dc-bar { display:flex; gap:12px; flex-wrap:wrap; align-items:center; margin-bottom:18px; }
  .dc-bar .input-icon { flex:1; min-width:240px; }
  .dc-layout { display:grid; grid-template-columns:240px 1fr; gap:26px; align-items:start; padding-bottom:64px; }
  .filter-card { position:sticky; top:128px; }
  /* rozbaľovací filter (details/summary) */
  .fc-summary { list-style:none; display:flex; align-items:center; justify-content:space-between; cursor:pointer; user-select:none; }
  .fc-summary::-webkit-details-marker { display:none; }
  .fc-chev { transition:transform .18s ease; color:var(--text-4); font-size:14px; }
  details#dcFilterBox[open] .fc-chev { transform:rotate(180deg); }
  /* na PC je filter vždy otvorený a hlavička (summary) nie je klikacia/potrebná */
  @media (min-width:981px){
    .fc-summary { cursor:default; margin-bottom:6px; }
    .fc-chev { display:none; }
  }
  /* na mobile/tablete summary oddelíme od obsahu jemnou čiarou keď je otvorené */
  @media (max-width:980px){
    details#dcFilterBox[open] .fc-summary { margin-bottom:10px; padding-bottom:10px; border-bottom:1px solid var(--line); }
  }
  .fc-group { padding:14px 0; border-bottom:1px solid var(--line); }
  .fc-group:last-of-type { border:none; }
  .fc-title { font-size:var(--fs-xs); text-transform:uppercase; letter-spacing:.08em; color:var(--text-4); font-weight:700; margin-bottom:10px; }
  .results-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:18px; }
  .dc-cover { height:96px; position:relative; display:flex; align-items:flex-start; justify-content:space-between; padding:12px; }
  .dc-body { padding:16px 18px 18px; }
  .dc-meta { display:flex; gap:14px; font-size:var(--fs-sm); color:var(--text-3); margin-bottom:12px; }
  .dc-meta b { color:var(--text-1); font-family:var(--num); }
  .activity { font-size:var(--fs-xs); display:inline-flex; align-items:center; gap:6px; }
  .act-dot { width:7px; height:7px; border-radius:50%; display:inline-block; }
  .chips { display:flex; gap:8px; flex-wrap:wrap; align-items:center; }
  .dc-tags-left { display:inline-flex; flex-direction:column; align-items:flex-start; gap:6px; }
  @media (max-width:980px){ .dc-layout { grid-template-columns:1fr; } .filter-card { position:static; } .results-grid { grid-template-columns:1fr 1fr; } }
  @media (max-width:560px){ .results-grid { grid-template-columns:1fr; } .dc-bar { display:grid; grid-template-columns:1fr 1fr; } .dc-bar .input-icon { grid-column:1 / -1; } .dc-bar .select { width:100% !important; } }
` }) %>
<%
  var COVERS=['linear-gradient(135deg,#16a085,#0c5f4d)','linear-gradient(135deg,#0e7a5f,#06402f)','linear-gradient(135deg,#c2410c,#7a1f06)','linear-gradient(135deg,#0369a1,#06354f)','linear-gradient(135deg,#8e44ad,#522963)','linear-gradient(135deg,#3a7bd5,#1b3f72)','linear-gradient(135deg,#d35400,#8a3700)','linear-gradient(135deg,#7c5cff,#3b1f8a)'];
%>

<div class="wrap dc-head">
  <div class="between wrap-gap" style="gap:16px">
    <div>
      <div class="eyebrow">Objaviť</div>
      <h1 style="font-size:clamp(2rem,3.4vw,2.8rem)">Nájdi ideálnu sezónu</h1>
      <p class="muted" style="margin-top:6px">Prehľadaj komunitné a oficiálne sezóny podľa názvu — alebo sa pripoj cez ID.</p>
    </div>
    <a href="/join" class="btn btn-secondary">Mám ID →</a>
  </div>
</div>

<div class="wrap">
  <form method="GET" action="/discover" class="dc-bar" id="dcBar">
    <div class="input-icon">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4" stroke-linecap="round"/></svg>
      <input class="input" name="q" placeholder="Hľadať podľa názvu alebo ID…" value="<%= q %>">
    </div>
    <select class="select" style="width:auto" name="sort">
      <option value="players" <%= sort === 'players' ? 'selected' : '' %>>Najviac hráčov</option>
      <option value="newest" <%= sort === 'newest' ? 'selected' : '' %>>Najnovšie</option>
    </select>
    <button class="btn btn-secondary" type="submit">Hľadať</button>
  </form>
</div>

<div class="wrap dc-layout">
  <!-- FILTRE (rozbaľovacie) -->
  <details class="card card-pad filter-card" id="dcFilterBox" open>
    <summary class="fc-summary"><b class="hi">Filtre</b><span class="fc-chev">▾</span></summary>
    <form method="GET" action="/discover" id="dcFilters">
      <%# zachovaj aktuálne hľadanie a triedenie %>
      <input type="hidden" name="q" value="<%= q %>">
      <input type="hidden" name="sort" value="<%= sort %>">
      <input type="hidden" name="f" value="1">
      <div class="fc-group">
        <div class="fc-title">Typ</div>
        <div class="stack g-2">
          <label class="check" style="font-size:var(--fs-sm)"><input type="checkbox" name="type" value="community" <%= filters.showCommunity ? 'checked' : '' %>> Komunitné</label>
          <label class="check" style="font-size:var(--fs-sm)"><input type="checkbox" name="type" value="official" <%= filters.showOfficial ? 'checked' : '' %>> Oficiálne</label>
        </div>
      </div>
      <div class="fc-group">
        <div class="fc-title">Prístup</div>
        <div class="stack g-2">
          <label class="check" style="font-size:var(--fs-sm)"><input type="checkbox" name="access" value="pub" <%= filters.showPublic ? 'checked' : '' %>> Verejné (pripojiť hneď)</label>
          <label class="check" style="font-size:var(--fs-sm)"><input type="checkbox" name="access" value="pwd" <%= filters.showProtected ? 'checked' : '' %>> Chránené heslom</label>
        </div>
      </div>
      <div class="fc-group">
        <div class="fc-title">Stav</div>
        <div class="stack g-2">
          <label class="check" style="font-size:var(--fs-sm)"><input type="checkbox" name="status" value="active" <%= filters.showActive ? 'checked' : '' %>> Práve prebieha</label>
          <label class="check" style="font-size:var(--fs-sm)"><input type="checkbox" name="status" value="upcoming" <%= filters.showUpcoming ? 'checked' : '' %>> Čoskoro štartuje</label>
          <label class="check" style="font-size:var(--fs-sm)"><input type="checkbox" name="status" value="ended" <%= filters.showEnded ? 'checked' : '' %>> Ukončené</label>
        </div>
      </div>
    </form>
    <a href="/discover" class="faint" style="font-size:var(--fs-xs);display:inline-block;margin-top:12px">Vymazať filtre</a>
  </details>

  <!-- VÝSLEDKY -->
  <main>
    <div class="between wrap-gap" style="margin:0 0 18px">
      <span class="muted" style="font-size:var(--fs-sm)"><b class="hi num"><%= total %></b> výsledkov<% if (q) { %> pre „<%= q %>"<% } %></span>
    </div>

    <% if (seasons.length === 0) { %>
      <div class="card card-pad center" style="text-align:center;padding:48px 24px">
        <div style="font-size:38px;margin-bottom:10px">🔍</div>
        <h3 style="margin-bottom:6px">Nič sa nenašlo</h3>
        <p class="muted"><%= q ? 'Skús iný názov alebo sa pripoj cez ID.' : 'Zatiaľ tu nie sú žiadne verejné komunitné sezóny.' %> <a href="/seasons/create" class="brand">Založ vlastnú →</a></p>
      </div>
    <% } else { %>
    <div class="results-grid">
      <% seasons.forEach(function(s, i){ %>
        <a href="/seasons/<%= s.id %>" class="card card-hover" style="overflow:hidden">
          <div class="dc-cover" style="background:<%= COVERS[i % COVERS.length] %>">
            <span class="dc-tags-left">
              <% if (s.type === 'official') { %><span class="tag tag-brand">Oficiálna</span><% } else { %><span class="tag tag-gold">Community</span><% } %>
              <% if (s.hasPassword) { %><span class="tag tag-muted">🔒</span><% } %>
            </span>
            <% if (s.status === 'active') { %><span class="tag tag-live"><span class="dot"></span>Live</span>
            <% } else if (s.status === 'upcoming') { %><span class="tag tag-info">Čoskoro</span>
            <% } else { %><span class="tag tag-muted">Ukončená</span><% } %>
          </div>
          <div class="dc-body">
            <h4 style="font-size:var(--fs-h4);margin-bottom:3px"><%= s.name %></h4>
            <p class="muted" style="font-size:var(--fs-xs);margin-bottom:12px"><%= s.description ? s.description : '—' %></p>
            <div class="dc-meta"><span><b><%= s.participantsCount.toLocaleString('sk-SK') %></b> hráčov</span><span><b><%= s.leaguesCount %></b> líg</span></div>
            <div class="between">
              <span class="activity" style="color:<%= s.status==='active' ? 'var(--success)' : s.status==='upcoming' ? 'var(--info)' : 'var(--text-4)' %>">
                <span class="act-dot" style="background:<%= s.status==='active' ? 'var(--success)' : s.status==='upcoming' ? 'var(--info)' : 'var(--text-4)' %>"></span>
                <%= s.status==='active' ? 'Aktívna' : s.status==='upcoming' ? 'Čoskoro' : 'Ukončená' %>
              </span>
              <span class="btn btn-secondary btn-sm"><%= s.hasPassword ? 'Detail' : 'Pripojiť' %></span>
            </div>
          </div>
        </a>
      <% }); %>
    </div>
    <% } %>
  </main>
</div>

<script>
// auto-submit pri zmene triedenia a filtrov (bez inline onchange — kvôli CSP)
(function(){
  var bar = document.getElementById('dcBar');
  if (bar) {
    var sortSel = bar.querySelector('select[name="sort"]');
    if (sortSel) sortSel.addEventListener('change', function(){ bar.submit(); });
  }
  var filters = document.getElementById('dcFilters');
  if (filters) {
    // pri zmene filtra prenes aktuálne hľadanie a triedenie z horného formulára
    filters.addEventListener('change', function(){
      if (bar) {
        var q = bar.querySelector('input[name="q"]');
        var sort = bar.querySelector('select[name="sort"]');
        if (q) filters.querySelector('input[name="q"]').value = q.value;
        if (sort) filters.querySelector('input[name="sort"]').value = sort.value;
      }
      filters.submit();
    });
  }

  // Rozbaľovací filter: defaultne ZATVORENÝ na mobile/tablete (≤980px),
  // otvorený na PC. (HTML má `open` kvôli bezpečnému fallbacku bez JS.)
  var fbox = document.getElementById('dcFilterBox');
  if (fbox) {
    var mq = window.matchMedia('(max-width: 980px)');
    // pri načítaní zatvor, ak je úzka obrazovka
    if (mq.matches) fbox.removeAttribute('open');
    // pri prechode PC → mobil zatvor, mobil → PC otvor
    var onChange = function(e){ if (e.matches) fbox.removeAttribute('open'); else fbox.setAttribute('open',''); };
    if (mq.addEventListener) mq.addEventListener('change', onChange);
    else if (mq.addListener) mq.addListener(onChange);
    // na PC filter nezatváraj klikom na hlavičku
    var sm = fbox.querySelector('summary');
    if (sm) sm.addEventListener('click', function(ev){ if (!mq.matches) ev.preventDefault(); });
  }
})();
</script>

<%- include('partials/footer') %>
