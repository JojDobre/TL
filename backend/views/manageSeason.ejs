<%- include('partials/head', { title: 'Správa sezóny — ' + season.name, page: 'seasons', active: 'seasons', pageStyle: `
  .ad-head { padding:24px 0 16px; }
  .crumb { font-size:var(--fs-sm); color:var(--text-4); margin-bottom:12px; }
  .crumb a { color:var(--text-3); } .crumb a:hover { color:var(--brand-bright); }
  .ac-tabs { display:flex; gap:6px; margin:18px 0; flex-wrap:wrap; }
  .ac-layout { display:grid; grid-template-columns:1fr 320px; gap:26px; align-items:start; padding-bottom:64px; }
  .card-pad2 { padding:24px; }
  .card-pad2 + .card-pad2 { margin-top:18px; }
  .card-pad2 h3 { font-size:var(--fs-h4); margin-bottom:4px; }
  .card-pad2 .sub { color:var(--text-3); font-size:var(--fs-sm); margin-bottom:18px; }
  .mem-row { display:grid; grid-template-columns:auto 1fr 120px auto; gap:14px; align-items:center; padding:11px 0; border-bottom:1px solid var(--line); }
  .mem-row:last-child { border:none; }
  .mem-name { min-width:0; }
  .mem-actions { display:flex; align-items:center; gap:8px; }
  .danger-zone { border:1px solid rgba(240,71,106,.3); border-radius:var(--r-lg); padding:24px; margin-top:18px; background:color-mix(in srgb,var(--danger) 5%,var(--surface-1)); }
  [data-cpanel="settings"]:not([hidden]) { display:flex; flex-direction:column; gap:18px; }
  .danger-row { display:flex; align-items:center; justify-content:space-between; gap:16px; padding:14px 0; border-bottom:1px solid rgba(240,71,106,.15); flex-wrap:wrap; }
  .danger-row:last-child { border:none; }
  .mem-head { display:grid; grid-template-columns:1fr auto; align-items:center; gap:4px 14px; margin-bottom:14px; }
  .mem-title { grid-column:1; grid-row:1; }
  .mem-search { grid-column:2; grid-row:1; width:200px; }
  .mem-sub { grid-column:1 / -1; grid-row:2; margin:0; }
  .ac-lhead { display:flex; align-items:center; gap:16px; }
  .ac-logo { flex:none; }
  .ac-lhead-body { display:flex; flex-wrap:wrap; align-items:center; gap:6px 10px; }
  .ac-title { order:1; font-size:clamp(1.6rem,2.6vw,2.1rem); }
  .ac-tag { order:2; }
  .ac-desc { order:3; flex-basis:100%; font-size:var(--fs-sm); margin:0; }
  .field-row { display:grid; grid-template-columns:1fr 1fr; gap:16px; }
  @media (max-width:980px){ .ac-layout { grid-template-columns:1fr; } }
  @media (max-width:600px){
    .card-pad2 { padding:18px; } .field-row { grid-template-columns:1fr; }
    .ad-head .between { flex-direction:column; align-items:stretch; gap:14px; }
    .ac-lhead { flex-direction:column; align-items:center; text-align:center; gap:10px; }
    .ac-lhead-body { flex-direction:column; align-items:center; gap:6px; }
    .ac-tag { order:0; } .ac-title { order:1; } .ac-desc { order:2; }
    .ac-tabs.segment { display:flex !important; width:100%; }
    .ac-tabs.segment button { flex:1; padding-inline:6px; }
    .mem-head { grid-template-columns:1fr; gap:10px; }
    .mem-title, .mem-sub, .mem-search { grid-column:1; grid-row:auto; }
    .mem-search { width:100%; max-width:none; }
    .mem-row { grid-template-columns:auto 1fr; grid-template-areas:"av name" ". actions"; column-gap:12px; row-gap:10px; align-items:start; }
    .mem-row > .avatar { grid-area:av; } .mem-name { grid-area:name; } .mem-role { display:none; } .mem-actions { grid-area:actions; flex-wrap:wrap; }
  }
` }) %>

<%
  function initials(u){ var n=[u.firstName,u.lastName].filter(Boolean).join(' ')||u.username||'?'; return n.split(' ').map(function(w){return w[0];}).filter(Boolean).slice(0,2).join('').toUpperCase(); }
  function fullName(u){ return [u.firstName,u.lastName].filter(Boolean).join(' ')||u.username; }
  function fmtD(d){ if(!d) return ''; var x=new Date(d); return x.toLocaleDateString('sk-SK',{day:'numeric',month:'short'}); }
  function dInput(d){ if(!d) return ''; var x=new Date(d); if(isNaN(x)) return ''; return x.toISOString().slice(0,10); }
  var isCommunity = season.type === 'community';
%>

<div class="wrap ad-head">
  <div class="crumb"><a href="/seasons/<%= season.id %>"><%= season.name %></a> › Správa</div>
  <div class="between wrap-gap" style="gap:16px">
    <div class="ac-lhead">
      <span class="team-logo ac-logo" style="width:54px;height:54px;font-size:16px;background:linear-gradient(135deg,#0b4ea2,#06306a)<% if (season.image) { %>;background-image:url('<%= season.image %>');background-size:cover;background-position:center<% } %>"><% if (!season.image) { %><%= (season.name||'S').substring(0,2).toUpperCase() %><% } %></span>
      <div class="ac-lhead-body">
        <span class="tag <%= season.type === 'official' ? 'tag-brand' : 'tag-gold' %> ac-tag"><%= season.type === 'official' ? 'Oficiálna' : 'Community' %></span>
        <h1 class="ac-title"><%= season.name %></h1>
        <p class="muted ac-desc"><%= summary.membersCount %> hráčov · <%= summary.leaguesCount %> líg · ID <%= season.inviteCode %><% if (season.status === 'ended') { %> · <span style="color:var(--danger)">Ukončená</span><% } %></p>
      </div>
    </div>
    <a href="/seasons/<%= season.id %>" class="btn btn-secondary">Späť na sezónu</a>
  </div>
</div>

<% if (error) { %><div class="wrap" style="margin-bottom:14px"><div class="tag tag-danger" style="display:block;padding:12px 14px"><%= error %></div></div><% } %>

<div class="wrap">
  <div class="ac-tabs segment" style="display:inline-flex">
    <button class="active" data-ct="members">Členovia</button>
    <button data-ct="settings">Nastavenia</button>
    <button data-ct="danger">Nebezpečná zóna</button>
  </div>
</div>

<div class="wrap ac-layout">
  <main>
    <!-- ČLENOVIA -->
    <section data-cpanel="members">
      <div class="card card-pad2">
        <div class="mem-head">
          <h3 class="mem-title">Členovia sezóny</h3>
          <div class="input-icon search mem-search"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4" stroke-linecap="round"/></svg><input class="input" id="memSearch" placeholder="Hľadať…"></div>
          <p class="sub mem-sub">Spravuj členov sezóny — povýš na správcu, zruš správu alebo odober hráča.</p>
        </div>
        <% if (members.length === 0) { %>
          <p class="muted">Sezóna zatiaľ nemá členov.</p>
        <% } %>
        <% members.forEach(function(m){ %>
        <div class="mem-row" data-name="<%= (fullName(m) + ' ' + m.username).toLowerCase() %>">
          <span class="avatar avatar-md" style="background:linear-gradient(135deg,#3a7bd5,#1b3f72);color:#fff"><%= initials(m) %></span>
          <div class="mem-name"><div class="u-name" style="font-weight:700;color:var(--text-1)"><a class="player-link" href="/player/<%= m.id %>"><%= fullName(m) %></a><% if (m.isCreator) { %> <span class="tag tag-gold" style="padding:0 6px;font-size:10px">Zakladateľ</span><% } %></div><div class="muted" style="font-size:var(--fs-xs)"><a class="player-link" href="/player/<%= m.id %>">@<%= m.username %></a><%= m.joinedAt ? ' · pripojený ' + fmtD(m.joinedAt) : '' %></div></div>
          <div class="mem-role"><span class="chip-role <%= m.role === 'admin' ? 'role-vip' : 'role-player' %>"><%= m.role === 'admin' ? 'Správca' : 'Člen' %></span></div>
          <div class="mem-actions">
            <% if (!m.isCreator) { %>
              <% if (m.role === 'admin') { %>
              <form action="/seasons/<%= season.id %>/members/<%= m.id %>" method="POST" style="display:inline"><input type="hidden" name="action" value="demote"><button class="btn btn-secondary btn-sm">Zrušiť správu</button></form>
              <% } else { %>
              <form action="/seasons/<%= season.id %>/members/<%= m.id %>" method="POST" style="display:inline"><input type="hidden" name="action" value="promote"><button class="btn btn-secondary btn-sm">Spraviť správcom</button></form>
              <% } %>
              <form action="/seasons/<%= season.id %>/members/<%= m.id %>" method="POST" style="display:inline" onsubmit="return confirm('Odobrať tohto hráča zo sezóny?')"><input type="hidden" name="action" value="remove"><button class="btn btn-danger btn-sm">Odobrať</button></form>
            <% } else { %>
              <span class="muted" style="font-size:var(--fs-xs)">chránený</span>
            <% } %>
          </div>
        </div>
        <% }); %>
      </div>
    </section>

    <!-- NASTAVENIA -->
    <section data-cpanel="settings" hidden>
      <form action="/seasons/<%= season.id %>/manage" method="POST">
        <div class="card card-pad2">
          <h3>Základné nastavenia</h3>
          <p class="sub">Uprav názov, popis a trvanie sezóny.</p>
          <div class="stack g-4">
            <div class="field"><label class="label">Názov sezóny</label><input class="input" name="name" value="<%= season.name %>" required></div>
            <div class="field"><label class="label">Popis</label><textarea class="textarea" name="description"><%= season.description || '' %></textarea></div>
            <div class="field"><label class="label">Obrázok (URL)</label><input class="input" name="image" value="<%= season.image || '' %>" placeholder="https://…"></div>
            <div class="field-row">
              <div class="field"><label class="label">Začiatok</label><input class="input" type="date" name="startDate" value="<%= dInput(season.startDate) %>"></div>
              <div class="field"><label class="label">Koniec (nepovinné)</label><input class="input" type="date" name="endDate" value="<%= dInput(season.endDate) %>"></div>
            </div>
          </div>
        </div>

        <% if (isCommunity) { %>
        <div class="card card-pad2">
          <h3>Súkromie</h3>
          <p class="sub">Súkromná sezóna je chránená heslom a dá sa skryť zo zoznamu.</p>
          <label class="check" style="display:flex;align-items:center;gap:10px;margin-bottom:14px"><input type="checkbox" id="privToggle" name="isPrivate" <%= season.hasPassword ? 'checked' : '' %>> <span>Súkromná sezóna (chránená heslom)</span></label>
          <div id="privFields" <%= season.hasPassword ? '' : 'hidden' %>>
            <div class="field" style="margin-bottom:14px"><label class="label">Nové heslo <%= season.hasPassword ? '(nechaj prázdne pre ponechanie)' : '' %></label><input class="input" type="text" name="password" placeholder="napr. kamarati2026"></div>
            <label class="check" style="display:flex;align-items:center;gap:10px;margin-bottom:14px"><input type="checkbox" name="hidden" <%= season.hidden ? 'checked' : '' %>> <span style="color:var(--danger)">Skryť zo zoznamu sezón</span></label>
          </div>
        </div>
        <% } %>

        <div><button type="submit" class="btn btn-primary" style="margin-top:16px">Uložiť zmeny</button></div>
      </form>
    </section>

    <!-- DANGER -->
    <section data-cpanel="danger" hidden>
      <div class="danger-zone">
        <h3 style="color:var(--danger);font-size:var(--fs-h4);margin-bottom:4px">Nebezpečná zóna</h3>
        <p class="muted" style="font-size:var(--fs-sm);margin-bottom:8px">Tieto akcie ovplyvnia celú sezónu.</p>
        <div class="danger-row">
          <div><b class="hi"><%= season.status === 'ended' ? 'Znovu otvoriť sezónu' : 'Ukončiť sezónu' %></b><div class="muted" style="font-size:var(--fs-sm)"><%= season.status === 'ended' ? 'Odomkne sezónu — opäť pôjde tipovať a upravovať.' : 'Uzamkne sezónu — žiadne nové tipy, kolá ani úpravy. Dá sa vrátiť.' %></div></div>
          <form action="/seasons/<%= season.id %>/end" method="POST"><button class="btn <%= season.status === 'ended' ? 'btn-secondary' : 'btn-danger' %>"><%= season.status === 'ended' ? 'Znovu otvoriť' : 'Ukončiť sezónu' %></button></form>
        </div>
        <div class="danger-row">
          <div><b class="hi">Vymazať sezónu</b><div class="muted" style="font-size:var(--fs-sm)">Natrvalo odstráni sezónu vrátane všetkých líg, kôl, zápasov a tipov.</div></div>
          <form action="/seasons/<%= season.id %>/delete" method="POST" onsubmit="return confirm('NAOZAJ vymazať sezónu? Odstránia sa všetky ligy, kolá, zápasy a tipy. Nevratné!')"><button class="btn btn-danger">Vymazať sezónu</button></form>
        </div>
      </div>
    </section>
  </main>

  <aside style="position:sticky;top:140px">
    <div class="card card-pad">
      <div class="stat-label" style="margin-bottom:12px">Súhrn sezóny</div>
      <div class="stack g-3" style="font-size:var(--fs-sm)">
        <div class="between"><span class="muted">Členovia</span><b class="hi num"><%= summary.membersCount %></b></div>
        <div class="between"><span class="muted">Ligy</span><b class="hi num"><%= summary.leaguesCount %></b></div>
        <div class="between"><span class="muted">Typ</span><span class="tag <%= season.type === 'official' ? 'tag-brand' : 'tag-gold' %>"><%= season.type === 'official' ? 'Oficiálna' : 'Community' %></span></div>
        <div class="between"><span class="muted">Stav</span><% if (season.status === 'ended') { %><span class="tag tag-muted">Ukončená</span><% } else if (season.status === 'upcoming') { %><span class="tag tag-info">Pripravovaná</span><% } else { %><span class="tag tag-live"><span class="dot"></span>Live</span><% } %></div>
        <div class="between"><span class="muted">Zakladateľ</span><b class="hi"><%= summary.creatorName %></b></div>
        <div class="between"><span class="muted">ID sezóny</span><b class="hi num"><%= season.inviteCode %></b></div>
      </div>
    </div>
  </aside>
</div>

<script>
(function(){
  // taby
  var btns=document.querySelectorAll('.ac-tabs [data-ct]');
  btns.forEach(function(b){ b.addEventListener('click',function(){
    btns.forEach(function(x){x.classList.remove('active');}); b.classList.add('active');
    var key=b.getAttribute('data-ct');
    document.querySelectorAll('[data-cpanel]').forEach(function(p){ p.hidden = p.getAttribute('data-cpanel')!==key; });
  }); });
  // search členov
  var ms=document.getElementById('memSearch');
  if(ms) ms.addEventListener('input',function(){ var q=this.value.trim().toLowerCase(); document.querySelectorAll('.mem-row').forEach(function(r){ var n=r.getAttribute('data-name')||''; r.style.display=(!q||n.indexOf(q)>=0)?'':'none'; }); });
  // súkromie toggle
  var pt=document.getElementById('privToggle');
  if(pt) pt.addEventListener('change',function(){ document.getElementById('privFields').toggleAttribute('hidden', !this.checked); });
})();

  <% if (error) { %>
  (function(){
    // pri chybe prepni na „Nebezpečná zóna" a posuň na banner
    var d=document.querySelector('.ac-tabs [data-ct="danger"]');
    if(d) d.click();
    var b=document.querySelector('.tag-danger');
    if(b) b.scrollIntoView({behavior:'smooth',block:'center'});
  })();
  <% } %>
</script>

<%- include('partials/footer') %>
