<%- include('partials/head', { title: 'Upraviť ligu', page: 'seasons', active: 'seasons', pageStyle: `
  .form-head { padding:28px 0 8px; }
  .crumb { font-size:var(--fs-sm); color:var(--text-4); margin-bottom:12px; }
  .crumb a { color:var(--text-3); } .crumb a:hover { color:var(--brand-bright); }
  .form-layout { display:grid; grid-template-columns:1fr 340px; gap:28px; align-items:start; padding:20px 0 64px; }
  .form-card { padding:26px; }
  .form-card + .form-card { margin-top:18px; }
  .form-card h3 { font-size:var(--fs-h4); margin-bottom:4px; }
  .form-card .sub { color:var(--text-3); font-size:var(--fs-sm); margin-bottom:20px; }
  .field-row { display:grid; grid-template-columns:1fr 1fr; gap:16px; }
  .type-pick { display:grid; grid-template-columns:1fr 1fr; gap:14px; }
  .type-opt { padding:18px; border-radius:var(--r-md); border:1.5px solid var(--line); background:var(--surface-2); cursor:pointer; transition:all .15s; }
  .type-opt.sel { border-color:var(--brand); background:var(--brand-soft); }
  .type-opt .t-ic { font-size:22px; margin-bottom:8px; }
  .type-opt b { color:var(--text-1); display:block; margin-bottom:3px; }
  .id-box { display:flex; align-items:center; gap:12px; background:var(--surface-2); border:1px solid var(--line); border-radius:var(--r-md); padding:16px 18px; }
  .id-val { font-family:var(--num); font-weight:700; font-size:1.8rem; letter-spacing:.28em; color:var(--brand-bright); text-shadow:var(--text-glow-brand); }
  .score-row { display:flex; align-items:center; gap:14px; padding:12px 0; border-bottom:1px solid var(--line); }
  .score-row:last-child { border:none; }
  .score-row .desc { flex:1; }
  .score-input { width:72px; }
  .score-input input { text-align:center; font-family:var(--num); font-weight:700; }
  .sticky-side { position:sticky; top:92px; }
  .form-layout > main, .form-layout > .sticky-side { min-width:0; }
  @media (max-width:980px){ .form-layout { grid-template-columns:1fr; } .sticky-side { position:static; } }
  @media (max-width:560px){
    .field-row, .type-pick { grid-template-columns:1fr; }
    .form-card { padding:20px; }
    .id-box { flex-wrap:wrap; }
    .id-val { font-size:1.4rem; letter-spacing:.2em; word-break:break-all; }
    .id-box .btn { width:100%; }
  }
` }) %>

<%
  const s = league.scoringSystem || {};
  const lgInit = (league.name||'L').substring(0,2).toUpperCase();
%>

<div class="wrap form-head">
  <div class="crumb"><a href="/leagues/<%= league.id %>"><%= league.name %></a> › Upraviť</div>
  <h1 style="font-size:clamp(1.8rem,3vw,2.4rem)">Upraviť ligu</h1>
  <p class="muted" style="margin-top:6px">Zmeň názov, popis, prístup a bodovanie ligy.</p>
</div>

<% if (typeof error !== 'undefined' && error) { %>
<div class="wrap"><div class="tag tag-danger" style="display:block;padding:12px 14px;margin-bottom:16px"><%= error %></div></div>
<% } %>

<form class="wrap form-layout" action="/leagues/<%= league.id %>/edit" method="POST">
  <main>
    <div class="card form-card">
      <h3>ID ligy</h3>
      <p class="sub">ID ligy sa nemení. Pošli ho hráčom na pripojenie.</p>
      <div class="id-box"><span class="id-val"><%= league.joinCode %></span></div>
    </div>

    <div class="card form-card">
      <h3>Základné údaje</h3>
      <div class="stack g-4">
        <div class="field"><label class="label">Názov ligy</label><input class="input" name="name" value="<%= league.name %>" required></div>
        <div class="field"><label class="label">Popis <span class="faint">(voliteľné)</span></label><textarea class="textarea" name="description"><%= league.description || '' %></textarea></div>
      </div>
    </div>

    <div class="card form-card">
      <h3>Prístup a typ</h3>
      <% if (currentUserRole === 'admin') { %>
      <div class="type-pick" style="margin-bottom:18px">
        <label class="type-opt <%= league.type !== 'official' ? 'sel' : '' %>" data-type="custom"><input type="radio" name="type" value="custom" hidden <%= league.type !== 'official' ? 'checked' : '' %>><div class="t-ic">⚙️</div><b>Custom</b><span class="muted" style="font-size:var(--fs-sm)">Vlastné bodovanie a kolá.</span></label>
        <label class="type-opt <%= league.type === 'official' ? 'sel' : '' %>" data-type="official"><input type="radio" name="type" value="official" hidden <%= league.type === 'official' ? 'checked' : '' %>><div class="t-ic">🏆</div><b>Oficiálna</b><span class="muted" style="font-size:var(--fs-sm)">Iba admin.</span></label>
      </div>
      <% } else { %>
      <input type="hidden" name="type" value="<%= league.type %>">
      <% } %>
      <% if (league.hasPassword) { %>
        <label class="check" style="margin-bottom:14px"><input type="checkbox" name="removePassword"> Odstrániť heslo ligy</label>
      <% } %>
      <div class="field"><label class="label"><%= league.hasPassword ? 'Zmeniť heslo' : 'Pridať heslo' %> <span class="faint">(nechaj prázdne ak nemeníš)</span></label><input class="input" type="text" name="password" placeholder="<%= league.hasPassword ? '••••••' : 'napr. kava2026' %>"></div>
    </div>

    <div class="card form-card">
      <h3>Bodovanie</h3>
      <% if (league.scoringLocked) { %>
        <p class="sub" style="color:var(--warning)">Bodovanie je uzamknuté, pretože už začalo prvé kolo. Nedá sa meniť.</p>
      <% } else { %>
        <p class="sub">Nastav, koľko bodov sa prideľuje za jednotlivé presnosti tipu.</p>
      <% } %>
      <div class="score-row"><div class="desc"><b class="hi">Presný výsledok</b></div><div class="field score-input"><input class="input" type="number" min="0" name="exactScore" value="<%= s.exactScore != null ? s.exactScore : 10 %>" <%= league.scoringLocked ? 'disabled' : '' %>></div></div>
      <div class="score-row"><div class="desc"><b class="hi">Víťaz / remíza</b></div><div class="field score-input"><input class="input" type="number" min="0" name="correctWinner" value="<%= s.correctWinner != null ? s.correctWinner : 3 %>" <%= league.scoringLocked ? 'disabled' : '' %>></div></div>
      <div class="score-row"><div class="desc"><b class="hi">Gólový rozdiel</b></div><div class="field score-input"><input class="input" type="number" min="0" name="goalDifference" value="<%= s.goalDifference != null ? s.goalDifference : 2 %>" <%= league.scoringLocked ? 'disabled' : '' %>></div></div>
      <div class="score-row"><div class="desc"><b class="hi">Presný počet gólov tímu</b></div><div class="field score-input"><input class="input" type="number" min="0" name="correctGoals" value="<%= s.correctGoals != null ? s.correctGoals : 1 %>" <%= league.scoringLocked ? 'disabled' : '' %>></div></div>
    </div>
  </main>

  <aside class="sticky-side">
    <div class="card card-pad">
      <div class="stat-label" style="margin-bottom:12px">Náhľad ligy</div>
      <div class="row g-3" style="margin-bottom:12px"><span class="team-logo" style="width:48px;height:48px;font-size:16px;background:linear-gradient(135deg,#7c5cff,#3b1f8a)"><%= lgInit %></span><div><b class="hi"><%= league.name %></b></div></div>
      <div class="row g-2 wrap-gap"><span class="tag <%= league.type === 'official' ? 'tag-brand' : 'tag-gold' %>"><%= league.type === 'official' ? 'Oficiálna' : 'Custom' %></span><% if (league.hasPassword) { %><span class="tag tag-muted">🔒 Heslo</span><% } %></div>
    </div>

    <div class="card card-pad" style="margin-top:18px">
      <button type="submit" class="btn btn-primary btn-block">Uložiť zmeny</button>
      <a href="/leagues/<%= league.id %>" class="btn btn-ghost btn-block" style="margin-top:8px">Zrušiť</a>
    </div>

      <div class="card card-pad" style="border-color:var(--danger-line,rgba(220,80,80,.3));margin-top:18px">
    <% if (league.ended) { %>
    <b class="hi" style="display:block;margin-bottom:6px">Liga je ukončená</b>
    <p class="muted" style="font-size:var(--fs-sm);margin-bottom:12px">Liga je uzamknutá. Môžeš ju znovu otvoriť, alebo natrvalo zmazať.</p>
    <form action="/leagues/<%= league.id %>/end" method="POST" style="margin-bottom:10px">
      <button type="submit" class="btn btn-secondary btn-block">Znovu otvoriť ligu</button>
    </form>
    <% } else { %>
    <b class="hi" style="display:block;margin-bottom:6px">Ukončiť ligu</b>
    <p class="muted" style="font-size:var(--fs-sm);margin-bottom:12px">Uzamkne ligu — žiadne nové kolá, zápasy ani tipy. Dá sa znovu otvoriť.</p>
    <form action="/leagues/<%= league.id %>/end" method="POST" onsubmit="return confirm('Ukončiť ligu? Uzamkne sa (dá sa znovu otvoriť).');" style="margin-bottom:10px">
      <button type="submit" class="btn btn-block" style="background:var(--danger,#dc5050);color:#fff">Ukončiť ligu</button>
    </form>
    <% } %>
    <form action="/leagues/<%= league.id %>/delete" method="POST" onsubmit="return confirm('NAOZAJ ZMAZAŤ ligu? Vymažú sa kolá, zápasy aj tipy. Nevratné!');">
      <button type="submit" class="btn btn-ghost btn-block" style="color:var(--danger);margin-top:8px">Zmazať ligu (nevratné)</button>
    </form>
  </div>
  </aside>
</form>



<% if (!isClone) { %>
<!-- ===== SÚPISKA TÍMOV LIGY (mimo hlavného formulára, cez API) ===== -->
<div class="wrap" style="padding-bottom:56px">
  <div class="card form-card" style="padding:24px">
    <div class="between" style="margin-bottom:6px"><h3 style="font-size:var(--fs-h4)">Tímy ligy</h3><span class="muted" style="font-size:var(--fs-sm)"><b class="hi" id="rosterCount">0</b> v súpiske</span></div>
    <p class="sub" style="margin-bottom:18px">Tímy v súpiske sa ponúkajú pri tvorbe zápasov. Pridaj ich zo zoznamu alebo vytvor vlastný.</p>

    <!-- súpiska -->
    <div id="roster" style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:18px"></div>

    <div class="row g-2" style="margin-bottom:16px">
      <button type="button" class="btn btn-secondary btn-sm" id="btnPick">+ Pridať tímy zo zoznamu</button>
      <button type="button" class="btn btn-ghost btn-sm" id="btnCustom">+ Vytvoriť vlastný tím</button>
    </div>

    <!-- panel: výber zo zoznamu -->
    <div id="pickPanel" hidden style="border-top:1px solid var(--line);padding-top:16px">
      <div class="row g-2 wrap-gap" style="margin-bottom:12px">
        <input class="input" id="tSearch" placeholder="Hľadať…" style="max-width:200px">
        <select class="select" id="tType" style="width:auto"><option value="">Typ</option><option value="club">Kluby</option><option value="national">Národné</option></select>
        <select class="select" id="tSport" style="width:auto"><option value="">Šport</option><% sports.forEach(function(s){ %><option value="<%= s.code %>"><%= s.label %></option><% }); %></select>
        <select class="select" id="tCountry" style="width:auto"><option value="">Krajina</option><% countries.forEach(function(c){ %><option value="<%= c.code %>"><%= c.label %></option><% }); %></select>
      </div>
      <div id="availList" style="display:flex;flex-direction:column;gap:6px;max-height:320px;overflow:auto"></div>
    </div>

    <!-- panel: vlastný tím -->
    <div id="customPanel" hidden style="border-top:1px solid var(--line);padding-top:16px">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
        <div class="field"><label class="label">Názov</label><input class="input" id="cName" placeholder="napr. Náš tím"></div>
        <div class="field"><label class="label">Typ</label><select class="select" id="cType"><option value="club">Klub</option><option value="national">Národný</option></select></div>
        <div class="field" data-cclub><label class="label">Šport</label><select class="select" id="cSport"><% sports.forEach(function(s){ %><option value="<%= s.code %>"><%= s.label %></option><% }); %></select></div>
        <div class="field"><label class="label">Krajina</label><select class="select" id="cCountry"><% countries.forEach(function(c){ %><option value="<%= c.code %>"><%= c.label %></option><% }); %></select></div>
        <div class="field" style="grid-column:1/-1"><label class="label">URL loga <span class="faint">(voliteľné)</span></label><input class="input" id="cLogo" type="url" placeholder="https://…"></div>
      </div>
      <button type="button" class="btn btn-primary btn-sm" id="cCreate" style="margin-top:6px">Vytvoriť a pridať</button>
    </div>
  </div>
</div>

<div class="toast-wrap" id="toastWrap" style="position:fixed;bottom:24px;right:24px;z-index:200;display:flex;flex-direction:column;gap:10px"></div>

<script>
(function () {
  var leagueId = <%= league.id %>;
  var CURRENT_USER_ID = <%= currentUserId || 'null' %>;
  var $ = function(id){ return document.getElementById(id); };
  function toast(msg, ok){ var t=document.createElement('div'); t.textContent=msg; t.style.cssText='background:'+(ok?'var(--success)':'var(--surface-2)')+';color:'+(ok?'#fff':'var(--text-1)')+';border:1px solid var(--line);padding:10px 14px;border-radius:10px'; $('toastWrap').appendChild(t); setTimeout(function(){t.remove();},2400); }
  function abbr(n){ return (n||'?').substring(0,3).toUpperCase(); }

  // načítaj súpisku
  function loadRoster(){
    fetch('/api/leagues/'+leagueId+'/teams').then(function(r){return r.json();}).then(function(res){
      var box=$('roster'); box.innerHTML='';
      var data=res.data||[];
      $('rosterCount').textContent=data.length;
      if(!data.length){ box.innerHTML='<span class="muted" style="font-size:var(--fs-sm)">Zatiaľ žiadne tímy v súpiske.</span>'; return; }
      data.forEach(function(t){
        var chip=document.createElement('span');
        chip.style.cssText='display:inline-flex;align-items:center;gap:8px;padding:6px 10px;background:var(--surface-2);border:1px solid var(--line);border-radius:20px;font-size:var(--fs-sm)';
        var isMine = t.scope==='custom' && t.creatorId===CURRENT_USER_ID;
        var editBtn = isMine ? '<button type="button" data-edit-custom="'+t.id+'" title="Upraviť vlastný tím" style="background:none;border:none;color:var(--text-3);cursor:pointer;font-size:13px">✎</button>' : '';
        chip.innerHTML='<b>'+t.name+'</b>'+(isMine?'<span class="tag tag-gold" style="padding:0 5px;font-size:10px">vlastný</span>':'')+editBtn+'<button type="button" data-rm="'+t.id+'" title="Odobrať zo súpisky" style="background:none;border:none;color:var(--text-4);cursor:pointer;font-size:14px">✕</button>';
        box.appendChild(chip);
      });
    });
  }
  loadRoster();

  // odobrať / upraviť vlastný custom tím
  $('roster').addEventListener('click', function(e){
    var ed=e.target.closest('[data-edit-custom]');
    if(ed){
      var tid=ed.getAttribute('data-edit-custom');
      var newName=prompt('Nový názov vlastného tímu:'); if(newName===null)return;
      if(!newName.trim()){toast('Názov nemôže byť prázdny.');return;}
      var newLogo=prompt('URL loga (nechaj prázdne ak žiadne):','')||'';
      fetch('/api/teams/custom/'+tid,{method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({name:newName,teamType:'club',logo:newLogo})}).then(function(r){return r.json();}).then(function(res){
        if(res.success===false){toast(res.message||'Nepodarilo sa.');return;}
        toast('Tím upravený ✓',true); loadRoster();
      }).catch(function(){toast('Chyba.');});
      return;
    }
    var b=e.target.closest('[data-rm]'); if(!b)return;
    fetch('/api/leagues/'+leagueId+'/teams/'+b.getAttribute('data-rm'),{method:'DELETE'}).then(function(r){return r.json();}).then(function(res){
      if(res.success===false){toast(res.message||'Nedá sa odobrať.');return;}
      toast('Odobraté',true); loadRoster();
    });
  });

  // prepínanie panelov
  $('btnPick').onclick=function(){ $('pickPanel').hidden=!$('pickPanel').hidden; $('customPanel').hidden=true; if(!$('pickPanel').hidden)loadAvail(); };
  $('btnCustom').onclick=function(){ $('customPanel').hidden=!$('customPanel').hidden; $('pickPanel').hidden=true; };
  $('cType').onchange=function(){ document.querySelector('[data-cclub]').style.display=this.value==='club'?'':'none'; };

  // dostupné tímy (filter)
  function loadAvail(){
    var qs=new URLSearchParams();
    if($('tSearch').value)qs.set('search',$('tSearch').value);
    if($('tType').value)qs.set('teamType',$('tType').value);
    if($('tSport').value)qs.set('sport',$('tSport').value);
    if($('tCountry').value)qs.set('country',$('tCountry').value);
    fetch('/api/leagues/'+leagueId+'/teams/available?'+qs.toString()).then(function(r){return r.json();}).then(function(res){
      var list=$('availList'); list.innerHTML=''; var sel=res.selectedIds||[];
      (res.data||[]).forEach(function(t){
        var inRoster=sel.indexOf(t.id)>=0;
        var row=document.createElement('div');
        row.style.cssText='display:flex;align-items:center;gap:10px;padding:8px 12px;background:var(--surface-2);border-radius:8px';
        row.innerHTML='<span style="width:30px;height:30px;border-radius:8px;background:var(--surface-3);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:11px">'+abbr(t.name)+'</span><b style="flex:1">'+t.name+'</b><span class="muted" style="font-size:var(--fs-xs)">'+(t.sport||t.teamType||'')+(t.country?' · '+t.country:'')+'</span>'+(inRoster?'<span class="tag tag-success" style="font-size:var(--fs-xs)">v súpiske</span>':'<button type="button" class="btn btn-secondary btn-sm" data-add="'+t.id+'">Pridať</button>');
        list.appendChild(row);
      });
      if(!(res.data||[]).length)list.innerHTML='<span class="muted" style="font-size:var(--fs-sm)">Žiadne tímy. Skús iný filter alebo vytvor vlastný.</span>';
    });
  }
  var deb; ['tSearch','tType','tSport','tCountry'].forEach(function(id){ $(id).addEventListener('input',function(){ clearTimeout(deb); deb=setTimeout(loadAvail,300); }); });

  // pridať zo zoznamu
  $('availList').addEventListener('click', function(e){
    var b=e.target.closest('[data-add]'); if(!b)return;
    fetch('/api/leagues/'+leagueId+'/teams',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({teamId:Number(b.getAttribute('data-add'))})}).then(function(r){return r.json();}).then(function(res){
      if(res.success===false){toast(res.message||'Nepodarilo sa.');return;}
      toast('Pridané ✓',true); loadRoster(); loadAvail();
    });
  });

  // vytvoriť custom tím
  $('cCreate').onclick=function(){
    var body={ name:$('cName').value, teamType:$('cType').value, sport:$('cSport').value, country:$('cCountry').value, logo:$('cLogo').value };
    if(!body.name.trim()){toast('Zadaj názov.');return;}
    this.disabled=true;
    fetch('/api/leagues/'+leagueId+'/teams/custom',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)}).then(function(r){return r.json();}).then(function(res){
      $('cCreate').disabled=false;
      if(res.success===false){toast(res.message||'Nepodarilo sa.');return;}
      toast('Tím vytvorený a pridaný ✓',true); $('cName').value=''; $('cLogo').value=''; loadRoster();
    }).catch(function(){$('cCreate').disabled=false;toast('Chyba.');});
  };
})();
</script>
<% } %>

<script>
  document.querySelectorAll('.type-opt[data-type]').forEach(function (opt) {
    opt.addEventListener('click', function (e) {
      e.preventDefault();
      document.querySelectorAll('.type-opt[data-type]').forEach(function (o) { o.classList.remove('sel'); });
      opt.classList.add('sel');
      var r = opt.querySelector('input[type=radio]'); if (r) r.checked = true;
    });
  });
</script>

<%- include('partials/footer') %>
