    </div>
    <div class="code"><span class="cm">&lt;!-- 1 · pripoj samostatný štýl loga --&gt;</span>
<span class="tag">&lt;link</span> rel=<span class="at">"stylesheet"</span> href=<span class="at">"css/logo.css"</span><span class="tag">&gt;</span>

<span class="cm">&lt;!-- 2 · primárny lockup (transparentné PNG, bez pozadia) --&gt;</span>
<span class="tag">&lt;a</span> class=<span class="at">"tifo-lockup"</span> href=<span class="at">"/"</span><span class="tag">&gt;</span>
  <span class="tag">&lt;img</span> class=<span class="at">"tifo-logo tifo-logo--md"</span> src=<span class="at">"branding/identity/tifo-mascot-transparent.png"</span> alt=<span class="at">"tifo.sk"</span><span class="tag">&gt;</span>
  <span class="tag">&lt;span</span> class=<span class="at">"tifo-wordmark"</span><span class="tag">&gt;</span>tifo<span class="tag">&lt;span</span> class=<span class="at">"tifo-wordmark--sk"</span><span class="tag">&gt;</span>.sk<span class="tag">&lt;/span&gt;&lt;/span&gt;</span>
<span class="tag">&lt;/a&gt;</span>

<span class="cm">&lt;!-- 3 · app ikona / favicon --&gt;</span>
<span class="tag">&lt;span</span> class=<span class="at">"tifo-icon"</span> style=<span class="at">"width:64px;height:64px"</span><span class="tag">&gt;</span>
  <span class="tag">&lt;img</span> src=<span class="at">"branding/identity/tifo-mascot-transparent.png"</span> alt=<span class="at">""</span><span class="tag">&gt;</span>
<span class="tag">&lt;/span&gt;</span></div>
  </div>
</section>

