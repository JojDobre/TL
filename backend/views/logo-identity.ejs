<!doctype html>
<html lang="sk" data-theme="dark">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>tifo.sk — Logo &amp; Identita</title>
<link rel="stylesheet" href="/css/tokens.css">
<link rel="stylesheet" href="/css/logo.css">
<style>
  body { padding: 0 0 120px; }
  .wrap { width:100%; max-width:1180px; margin-inline:auto; padding-inline:32px; }
  @media(max-width:720px){ .wrap{ padding-inline:18px; } }

  /* ---------- top bar ---------- */
  .topbar { position:sticky; top:0; z-index:30; backdrop-filter:blur(14px);
    background:rgba(9,12,22,.72); border-bottom:1px solid var(--line); }
  .topbar .wrap { display:flex; align-items:center; justify-content:space-between; height:64px; }
  .topbar .wm { color:var(--text-1); }
  .topbar nav { display:flex; gap:22px; }
  .topbar nav a { font-family:var(--num); font-size:12px; color:var(--text-3); letter-spacing:.04em; text-decoration:none; }
  .topbar nav a:hover { color:var(--gold); }
  @media(max-width:760px){ .topbar nav{ display:none; } }

  /* ---------- hero ---------- */
  .hero { position:relative; overflow:hidden; padding:84px 0 70px; border-bottom:1px solid var(--line); }
  .hero .glow { position:absolute; inset:0; z-index:-1; pointer-events:none;
    background:
      radial-gradient(620px 460px at 50% 8%, rgba(250,204,21,.16), transparent 62%),
      radial-gradient(700px 520px at 12% 120%, rgba(124,92,255,.18), transparent 60%); }
  .hero .wrap { display:flex; flex-direction:column; align-items:center; text-align:center; }
  .pill { display:inline-block; font-family:var(--num); font-size:11px; font-weight:700;
    letter-spacing:.16em; text-transform:uppercase; color:var(--gold); background:var(--gold-soft);
    border:1px solid rgba(250,204,21,.35); padding:6px 14px; border-radius:999px; margin-bottom:30px; }
  .hero h1 { font-family:var(--tifo-font); font-weight:700; font-size:clamp(2.6rem,7vw,4.6rem); letter-spacing:-.04em; margin-top:14px; color:var(--text-1); }
  .hero h1 .sk { color:var(--gold); }
  .hero p { max-width:56ch; color:var(--text-2); font-size:var(--fs-lg); line-height:1.55; margin-top:14px; }
  .meaning { display:flex; flex-wrap:wrap; gap:10px; justify-content:center; margin-top:30px; }
  .meaning span { font-family:var(--num); font-size:12px; color:var(--text-3);
    border:1px solid var(--line-strong); border-radius:999px; padding:7px 14px; }
  .meaning b { color:var(--text-1); font-weight:700; }

  /* ---------- section scaffold ---------- */
  section { padding:64px 0; border-bottom:1px solid var(--line); }
  .sec-head { display:flex; align-items:baseline; gap:14px; margin-bottom:30px; }
  .sec-num { font-family:var(--num); font-size:13px; font-weight:700; color:var(--gold); }
  .sec-head h2 { font-size:var(--fs-h2); letter-spacing:-.02em; }
  .sec-head p { color:var(--text-3); font-size:var(--fs-base); margin-left:auto; max-width:40ch; text-align:right; }
  @media(max-width:720px){ .sec-head{ flex-direction:column; gap:6px; } .sec-head p{ margin-left:0; text-align:left; } }

  .grid { display:grid; gap:22px; }
  .g3 { grid-template-columns:repeat(3,1fr); }
  .g2 { grid-template-columns:repeat(2,1fr); }
  .g4 { grid-template-columns:repeat(4,1fr); }
  @media(max-width:880px){ .g3,.g4{ grid-template-columns:repeat(2,1fr); } }
  @media(max-width:560px){ .g2,.g3,.g4{ grid-template-columns:1fr; } }

  .card { background:var(--surface-1); border:1px solid var(--line); border-radius:var(--r-lg);
    padding:30px 24px 20px; display:flex; flex-direction:column; align-items:center; gap:18px; }
  .stage { width:100%; aspect-ratio:4/3; border-radius:var(--r-md); display:flex;
    align-items:center; justify-content:center; overflow:hidden; }
  .stage img { width:64%; height:auto; }
  .lbl { text-align:center; }
  .lbl .t { font-family:var(--font-display); font-weight:700; font-size:14px; color:var(--text-1); }
  .lbl .d { font-size:12.5px; color:var(--text-3); margin-top:2px; }
  .tagm { display:inline-block; font-family:var(--num); font-size:10px; font-weight:700; letter-spacing:.1em;
    text-transform:uppercase; padding:3px 8px; border-radius:6px; margin-top:8px; }
  .tagm.prim { color:var(--gold); background:var(--gold-soft); border:1px solid rgba(250,204,21,.3); }
  .tagm.sec  { color:var(--text-3); background:var(--surface-2); border:1px solid var(--line-strong); }

  .bg-dark { background:#080e14; }
  .bg-deep { background:#06080f; }
  .bg-light { background:#f4f6fc; }
  .bg-gold { background:linear-gradient(150deg,#fde047,#f5a524); }
  .bg-violet { background:linear-gradient(150deg,#7c5cff,#5b3fd6); }
  .bg-check { background:
      linear-gradient(45deg,#1a2236 25%,transparent 25%,transparent 75%,#1a2236 75%),
      linear-gradient(45deg,#1a2236 25%,#11192b 25%,#11192b 75%,#1a2236 75%);
    background-size:22px 22px; background-position:0 0,11px 11px; }

  /* ---------- logo system grid ---------- */
  .sys-stage { width:100%; aspect-ratio:16/10; background:#080e14; border-radius:var(--r-md);
    display:flex; align-items:center; justify-content:center; }
  .wmk { font-family:var(--tifo-font); font-weight:700; letter-spacing:-.03em; line-height:1; color:#eef1f9; }
  .wmk .sk { color:var(--gold); }

  /* ---------- construction / anatomy ---------- */
  .anatomy { display:grid; grid-template-columns:1fr 1fr; gap:30px; align-items:center; }
  @media(max-width:760px){ .anatomy{ grid-template-columns:1fr; } }
  .anatomy .frame { background:
      linear-gradient(var(--line) 1px, transparent 1px) 0 0/100% 12.5%,
      linear-gradient(90deg, var(--line) 1px, transparent 1px) 0 0/12.5% 100%,
      #0a0e1c;
    border:1px solid var(--line-strong); border-radius:var(--r-md); padding:8%; }
  .anatomy .frame img { width:100%; display:block; filter:drop-shadow(0 16px 30px rgba(0,0,0,.5)); }
  .anatomy ul { list-style:none; display:flex; flex-direction:column; gap:16px; }
  .anatomy li { display:flex; gap:14px; align-items:flex-start; }
  .anatomy .pin { font-family:var(--num); font-weight:700; font-size:12px; color:var(--ink, #0a0e1c);
    background:var(--gold); width:24px; height:24px; border-radius:50%; flex:none; display:flex;
    align-items:center; justify-content:center; }
  .anatomy .ttl { font-family:var(--font-display); font-weight:700; font-size:14px; color:var(--text-1); }
  .anatomy .dsc { font-size:13px; color:var(--text-3); margin-top:2px; line-height:1.5; }

  /* ---------- clearspace ---------- */
  .clear-wrap { background:var(--surface-1); border:1px solid var(--line); border-radius:var(--r-lg); padding:40px; }
  .clear-box { position:relative; width:240px; max-width:78%; margin:0 auto; }
  .clear-box img { width:100%; display:block; position:relative; z-index:2; }
  .clear-box .pad { position:absolute; inset:-22%; border:1.5px dashed rgba(250,204,21,.55); border-radius:8px; }
  .clear-note { display:flex; gap:30px; flex-wrap:wrap; margin-top:30px; }
  .clear-note div { flex:1; min-width:200px; }
  .clear-note .k { font-family:var(--num); font-size:12px; color:var(--gold); letter-spacing:.12em; text-transform:uppercase; font-weight:700; }
  .clear-note .v { color:var(--text-2); font-size:14px; margin-top:6px; line-height:1.5; }

  /* ---------- sizing / favicon ---------- */
  .sizes { display:flex; align-items:flex-end; gap:28px; flex-wrap:wrap; justify-content:center; }
  .sizes figure { display:flex; flex-direction:column; align-items:center; gap:10px; }
  .sizes figcaption { font-family:var(--num); font-size:11px; color:var(--text-3); }

  /* ---------- color palette ---------- */
  .swatch { border-radius:var(--r-md); overflow:hidden; border:1px solid var(--line); }
  .swatch .chip { height:104px; }
  .swatch .info { padding:13px 15px; background:var(--surface-1); }
  .swatch .nm { font-family:var(--font-display); font-weight:700; font-size:14px; color:var(--text-1); }
  .swatch .hex { font-family:var(--num); font-size:12px; color:var(--text-3); margin-top:2px; letter-spacing:.04em; }

  /* ---------- typography spec ---------- */
  .type-spec { display:grid; grid-template-columns:1.2fr .8fr; gap:24px; align-items:stretch; }
  @media(max-width:760px){ .type-spec{ grid-template-columns:1fr; } }
  .type-big { background:#080e14; border:1px solid var(--line); border-radius:var(--r-lg); padding:40px;
    display:flex; flex-direction:column; justify-content:center; gap:18px; }
  .type-big .big { font-family:var(--tifo-font); font-weight:700; font-size:clamp(3rem,8vw,5rem); letter-spacing:-.04em; color:#eef1f9; line-height:1; }
  .type-big .big .sk { color:var(--gold); }
  .type-big .set { font-family:var(--tifo-font); font-weight:500; font-size:18px; color:var(--text-3); letter-spacing:.02em; }
  .type-meta { display:flex; flex-direction:column; gap:1px; background:var(--line); border:1px solid var(--line); border-radius:var(--r-lg); overflow:hidden; }
  .type-meta .row { background:var(--surface-1); padding:16px 18px; }
  .type-meta .k { font-family:var(--num); font-size:11px; letter-spacing:.1em; text-transform:uppercase; color:var(--text-4); }
  .type-meta .v { font-family:var(--font-display); font-weight:700; font-size:15px; color:var(--text-1); margin-top:3px; }

  /* ---------- in-context mockups ---------- */
  .mock-grid { display:grid; grid-template-columns:1.1fr .9fr; gap:22px; }
  @media(max-width:760px){ .mock-grid{ grid-template-columns:1fr; } }
  .mock { background:var(--surface-1); border:1px solid var(--line); border-radius:var(--r-lg); padding:24px; }
  .mock .mh { font-family:var(--num); font-size:11px; letter-spacing:.14em; text-transform:uppercase; color:var(--text-3); margin-bottom:18px; }

  .browser { background:var(--bg-deep); border:1px solid var(--line); border-radius:12px; overflow:hidden; }
  .browser .bar { display:flex; align-items:center; gap:7px; padding:10px 12px; background:#11151f; }
  .browser .dot { width:11px; height:11px; border-radius:50%; }
  .browser .tabrow { display:flex; gap:6px; padding:0 10px; background:#11151f; }
  .browser .tab { display:flex; align-items:center; gap:8px; background:var(--bg-deep);
    padding:9px 16px; border-radius:9px 9px 0 0; font-size:12.5px; color:var(--text-2); }
  .browser .tab .tifo-icon { width:16px; height:16px; border-radius:5px; }
  .browser .body { padding:26px; text-align:center; color:var(--text-4); font-size:12px; }

  .phone-row { display:flex; gap:22px; align-items:flex-start; justify-content:center; padding:8px 0; }
  .phone-row .tifo-icon { width:74px; height:74px; box-shadow:var(--shadow-lg); }
  .app-name { font-size:11px; color:var(--text-2); text-align:center; margin-top:7px; }

  .avatar-row { display:flex; gap:20px; align-items:center; }
  .avatar-row .tifo-icon { width:88px; height:88px; flex:none; border:2px solid rgba(250,204,21,.35); }
  .avatar-meta .h { font-family:var(--font-display); font-weight:700; color:var(--text-1); font-size:15px; }
  .avatar-meta .u { font-size:12.5px; color:var(--text-3); }
  .avatar-meta .bio { font-size:13px; color:var(--text-2); margin-top:6px; max-width:30ch; }

  .tifo-badge { margin:0 auto; }
  .ring-txt { position:absolute; inset:0; }
  .ring-txt text { font-family:var(--font-display); font-weight:700; font-size:13px; letter-spacing:.32em; fill:var(--gold); }

  .nav-sample { display:flex; align-items:center; gap:11px; padding:13px 18px; border-radius:12px; }
  .nav-sample.on-dark { background:#080e14; border:1px solid var(--line); }
  .nav-sample.on-light { background:#fff; border:1px solid #e4e7f2; }

  /* ---------- don'ts ---------- */
  .dont-card { background:var(--surface-1); border:1px solid var(--line); border-radius:var(--r-md);
    overflow:hidden; display:flex; flex-direction:column; }
  .dont-stage { aspect-ratio:3/2; display:flex; align-items:center; justify-content:center; background:#0c1020; overflow:hidden; }
  .dont-stage img { width:54%; }
  .dont-foot { display:flex; align-items:flex-start; gap:10px; padding:14px 16px; }
  .dont-x { width:20px; height:20px; flex:none; border-radius:50%; background:var(--danger-soft);
    color:var(--danger); display:flex; align-items:center; justify-content:center; font-weight:800; font-size:12px; margin-top:1px; }
  .dont-foot .tx { font-size:13px; color:var(--text-2); line-height:1.45; }

  /* ---------- usage code ---------- */
  .code { background:var(--bg-deep); border:1px solid var(--line); border-radius:var(--r-md);
    padding:18px 20px; font-family:var(--num); font-size:12.5px; line-height:1.7; color:var(--text-2);
    overflow-x:auto; white-space:pre; }
  .code .tag { color:var(--brand-bright); }
  .code .at { color:var(--gold); }
  .code .cm { color:var(--text-4); }

  /* ---------- downloads ---------- */
  .files { display:grid; grid-template-columns:repeat(2,1fr); gap:14px; }
  @media(max-width:560px){ .files{ grid-template-columns:1fr; } }
  .file { display:flex; align-items:center; gap:14px; background:var(--surface-1);
    border:1px solid var(--line); border-radius:var(--r-md); padding:16px 18px; }
  .file .ext { font-family:var(--num); font-weight:700; font-size:12px; color:var(--gold);
    background:var(--gold-soft); border:1px solid rgba(250,204,21,.3); border-radius:8px; padding:8px 10px; min-width:46px; text-align:center; }
  .file .ext.css { color:var(--brand-bright); background:var(--brand-soft); border-color:var(--brand-line); }
  .file .fn { font-family:var(--num); font-size:13.5px; color:var(--text-1); }
  .file .fd { font-size:12px; color:var(--text-3); margin-top:2px; }
</style>
</head>
<body>
<div class="bg-field"></div>

<!-- ============ TOP BAR ============ -->
<header class="topbar">
  <div class="wrap">
    <a class="tifo-lockup" href="/">
      <img class="tifo-logo tifo-logo--sm" src="/branding/identity/tifo-mascot-transparent.png" alt="tifo.sk">
      <span class="tifo-wordmark wm">tifo<span class="tifo-wordmark--sk">.sk</span></span>
    </a>
    <nav>
      <a href="#system">Systém</a>
      <a href="#mono">Mono</a>
      <a href="#construction">Konštrukcia</a>
      <a href="#context">Kontext</a>
      <a href="#files">Súbory</a>
    </nav>
  </div>
</header>

<!-- ============ HERO ============ -->
<div class="hero" data-screen-label="Hero">
  <div class="glow"></div>
  <div class="wrap">
    <span class="pill">Vizuálna identita · v1.0</span>
    <img class="tifo-logo tifo-logo--hero" src="/branding/identity/tifo-mascot-transparent.png" alt="tifo.sk maskot s ďalekohľadom">
    <h1>tifo<span class="sk">.sk</span></h1>
    <p>Maskot s ďalekohľadom — zlatý chuligán, čo neustále sleduje ihrisko. Pozorovateľ, tipér, fanúšik kotla. Toto je kompletná logo identita značky tifo.sk.</p>
    <div class="meaning">
      <span><b>Ďalekohľad</b> — sledujeme, analyzujeme, tipujeme</span>
      <span><b>Úsmev</b> — radosť z hry a tribún</span>
      <span><b>Zlatá</b> — víťazstvo &amp; energia kotla</span>
    </div>
  </div>
</div>

<!-- ============ 01 LOGO SYSTÉM ============ -->
<section id="system" data-screen-label="Logo system">
  <div class="wrap">
    <div class="sec-head">
      <span class="sec-num">01</span>
      <h2>Logo systém</h2>
      <p>Šesť oficiálnych podôb jedného loga. Vyber podľa priestoru a kontextu.</p>
    </div>
    <div class="grid g3">
      <!-- primary horizontal -->
      <div class="card">
        <div class="sys-stage">
          <div class="tifo-lockup" style="font-size:30px;">
            <img class="tifo-logo" style="height:74px;" src="/branding/identity/tifo-mascot-transparent.png" alt="">
            <span class="tifo-wordmark wmk">tifo<span class="sk">.sk</span></span>
          </div>
        </div>
        <div class="lbl"><div class="t">Primárny lockup</div><div class="d">maskot + wordmark, horizontálne</div><span class="tagm prim">Primárne</span></div>
      </div>
      <!-- stacked -->
      <div class="card">
        <div class="sys-stage">
          <div class="tifo-lockup tifo-lockup--stack" style="font-size:24px;">
            <img class="tifo-logo" style="height:84px;" src="/branding/identity/tifo-mascot-transparent.png" alt="">
            <span class="tifo-wordmark wmk">tifo<span class="sk">.sk</span></span>
          </div>
        </div>
        <div class="lbl"><div class="t">Vertikálny lockup</div><div class="d">avatar, splash, merch</div><span class="tagm sec">Sekundárne</span></div>
      </div>
      <!-- mark only -->
      <div class="card">
        <div class="sys-stage"><img src="/branding/identity/tifo-mascot-transparent.png" style="height:104px;" alt=""></div>
        <div class="lbl"><div class="t">Brand mark</div><div class="d">samotný maskot — ikona, favicon</div><span class="tagm prim">Primárne</span></div>
      </div>
      <!-- wordmark only -->
      <div class="card">
        <div class="sys-stage"><span class="wmk" style="font-size:46px;">tifo<span class="sk">.sk</span></span></div>
        <div class="lbl"><div class="t">Wordmark</div><div class="d">len text — pätička, právne dokumenty</div><span class="tagm sec">Sekundárne</span></div>
      </div>
      <!-- with tagline -->
      <div class="card">
        <div class="sys-stage">
          <div class="tifo-lockup tifo-lockup--stack" style="font-size:24px;">
            <img class="tifo-logo" style="height:74px;" src="/branding/identity/tifo-mascot-transparent.png" alt="">
            <span class="tifo-wordmark wmk">tifo<span class="sk">.sk</span></span>
            <span class="tifo-tagline">Tipuj · Boduj · Vyhrávaj</span>
          </div>
        </div>
        <div class="lbl"><div class="t">Lockup s claimom</div><div class="d">kampane, plagáty, úvodné obrazovky</div><span class="tagm sec">Sekundárne</span></div>
      </div>
      <!-- descriptor lockup -->
      <div class="card">
        <div class="sys-stage">
          <div class="tifo-lockup" style="font-size:26px;">
            <img class="tifo-logo" style="height:64px;" src="/branding/identity/tifo-mascot-transparent.png" alt="">
            <span style="display:flex;flex-direction:column;line-height:1.05;">
              <span class="tifo-wordmark wmk">tifo<span class="sk">.sk</span></span>
              <span style="font-family:var(--num);font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--text-3);margin-top:4px;">Tipovacia liga</span>
            </span>
          </div>
        </div>
        <div class="lbl"><div class="t">Lockup s deskriptorom</div><div class="d">prvé predstavenie značky</div><span class="tagm sec">Sekundárne</span></div>
      </div>
    </div>
  </div>
</section>

<!-- ============ 02 MONOCHROME ============ -->
<section id="mono" data-screen-label="Monochrome">
  <div class="wrap">
    <div class="sec-head">
      <span class="sec-num">02</span>
      <h2>Jednofarebné verzie</h2>
      <p>Keď farba nie je možná — razba, foil, tlač na jednu farbu, vodoznak. Detail maskota ostáva čitateľný.</p>
    </div>
    <div class="grid g3">
      <div class="card">
        <div class="stage bg-dark"><img src="/branding/identity/tifo-mono-gold.png" alt=""></div>
        <div class="lbl"><div class="t">Zlatá mono</div><div class="d">na tmavej — foil, premium</div></div>
      </div>
      <div class="card">
        <div class="stage bg-light"><img src="/branding/identity/tifo-mono-navy.png" alt=""></div>
        <div class="lbl"><div class="t">Atramentová mono</div><div class="d">na svetlej — jednofarebná tlač</div></div>
      </div>
      <div class="card">
        <div class="stage bg-violet"><img src="/branding/identity/tifo-mono-white.png" alt=""></div>
        <div class="lbl"><div class="t">Knockout (biela)</div><div class="d">reverzná na plnej farbe</div></div>
      </div>
    </div>
  </div>
</section>

<!-- ============ 03 NA POZADÍ ============ -->
<section data-screen-label="Backgrounds">
  <div class="wrap">
    <div class="sec-head">
      <span class="sec-num">03</span>
      <h2>Plnofarebné na pozadí</h2>
      <p>Transparentné PNG na akomkoľvek pozadí — tmavom, svetlom aj farebnom. Bez čiernej plochy.</p>
    </div>
    <div class="grid g3">
      <div class="card">
        <div class="stage bg-dark"><img src="/branding/identity/tifo-mascot-transparent.png" alt=""></div>
        <div class="lbl"><div class="t">Na tmavej</div><div class="d">primárne — transparentné PNG, bez pozadia</div></div>
      </div>
      <div class="card">
        <div class="stage bg-light"><img src="/branding/identity/tifo-mascot-transparent.png" alt=""></div>
        <div class="lbl"><div class="t">Na svetlej · PNG</div><div class="d">transparentný — obrys drží na bielej</div></div>
      </div>
      <div class="card">
        <div class="stage bg-violet"><img src="/branding/identity/tifo-mascot-transparent.png" alt=""></div>
        <div class="lbl"><div class="t">Na fialovej · PNG</div><div class="d">brand violet #7C5CFF</div></div>
      </div>
      <div class="card">
        <div class="stage bg-deep"><img src="/branding/identity/tifo-mascot-transparent.png" alt=""></div>
        <div class="lbl"><div class="t">Na hĺbkovej</div><div class="d">#06080F — app pozadie</div></div>
