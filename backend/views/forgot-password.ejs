<%- include('partials/auth-head', { title: 'Obnova hesla', pageStyle: `
  .auth { min-height:100vh; display:grid; grid-template-columns: 1.05fr 1fr; }
  .auth-brand { position:relative; overflow:hidden; padding:48px; display:flex; flex-direction:column; justify-content:space-between;
    background: linear-gradient(150deg,#140a2e,#1d1140 50%,#0a1130); border-right:1px solid var(--line); }
  .auth-brand::before { content:""; position:absolute; inset:0; background:
    radial-gradient(600px 400px at 20% 10%, rgba(124,92,255,.35), transparent 60%),
    radial-gradient(500px 360px at 90% 90%, rgba(250,204,21,.14), transparent 55%); }
  .auth-brand > * { position:relative; z-index:1; }
  .auth-logo { display:flex; align-items:center; gap:11px; }
  .auth-tagline { font-family:var(--font-display); font-weight:700; font-size:clamp(2rem,3vw,2.9rem); line-height:1.05; letter-spacing:-.02em; color:#fff; }
  .auth-feat { display:flex; gap:11px; align-items:flex-start; margin-top:16px; }
  .auth-feat .ic { width:34px; height:34px; border-radius:10px; flex:none; display:flex; align-items:center; justify-content:center; background:rgba(255,255,255,.08); font-size:16px; }
  .auth-form { display:flex; align-items:center; justify-content:center; padding:40px 24px; }
  .auth-card { width:100%; max-width:400px; }
  .auth-card h1 { font-size:1.8rem; }
  .phase { display:none; }
  .phase.active { display:block; animation:dd-in .22s var(--ease-out); }
  .steps { display:flex; align-items:center; gap:6px; margin-bottom:24px; }
  .step-pip { height:5px; flex:1; border-radius:99px; background:var(--surface-3); transition:background .25s; }
  .step-pip.on { background:var(--brand); box-shadow:var(--glow-brand); }
  .mail-ico { width:64px; height:64px; border-radius:var(--r-lg); display:flex; align-items:center; justify-content:center; background:var(--brand-soft); color:var(--brand-bright); margin-bottom:18px; }
  .pw-meter { height:6px; border-radius:99px; background:var(--surface-3); overflow:hidden; margin-top:8px; }
  .pw-meter > i { display:block; height:100%; width:0; border-radius:99px; background:var(--danger); transition:width .25s, background .25s; }
  @media (max-width: 860px){ .auth { grid-template-columns:1fr; } .auth-brand { display:none; } }
` }) %>

<div class="auth">
  <!-- BRAND PANEL -->
  <div class="auth-brand">
    <%- include('partials/brand-lockup', { variant: 'horizontal', size: 40, fontSize: 22, href: '/', wordColor: '#fff' }) %>
    <div>
      <div class="auth-tagline">Zabudnuté heslo?<br>Žiadny problém.</div>
      <div style="max-width:380px;margin-top:24px">
        <div class="auth-feat"><span class="ic">✉️</span><div><b style="color:#fff">Pošleme ti odkaz</b><div style="color:rgba(255,255,255,.6);font-size:var(--fs-sm)">Na e-mail dostaneš bezpečný odkaz na obnovu.</div></div></div>
        <div class="auth-feat"><span class="ic">🔒</span><div><b style="color:#fff">Nastav nové heslo</b><div style="color:rgba(255,255,255,.6);font-size:var(--fs-sm)">Vytvor si silné heslo a pokračuj v tipovaní.</div></div></div>
        <div class="auth-feat"><span class="ic">⚡</span><div><b style="color:#fff">Hotovo za minútu</b><div style="color:rgba(255,255,255,.6);font-size:var(--fs-sm)">Celý proces zaberie len pár sekúnd.</div></div></div>
      </div>
    </div>
    <div style="color:rgba(255,255,255,.4);font-size:var(--fs-sm)">© 2026 Tifo.sk</div>
  </div>

  <!-- FORM -->
  <div class="auth-form">
    <div class="auth-card">
      <% var fpStep = (typeof sent !== 'undefined' && sent) ? 2 : 1; %>
      <div class="steps">
        <span class="step-pip on" data-pip="1"></span>
        <span class="step-pip<%= fpStep >= 2 ? ' on' : '' %>" data-pip="2"></span>
        <span class="step-pip<%= fpStep >= 3 ? ' on' : '' %>" data-pip="3"></span>
      </div>

      <!-- PHASE 1: request -->
      <div class="phase<%= (typeof sent !== 'undefined' && sent) ? '' : ' active' %>" id="p1">
        <h1>Obnova hesla</h1>
        <p class="muted" style="margin:8px 0 26px">Zadaj e-mail, ktorým sa prihlasuješ. Pošleme ti odkaz na nastavenie nového hesla.</p>
        <!-- Reálne odoslanie na backend (POST /forgot-password). Backend vygeneruje
             token, pošle e-mail s odkazom a vráti túto stránku s fázou 2. -->
        <form method="POST" action="/forgot-password">
          <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
          <div class="field" style="margin-bottom:18px"><label class="label">E-mailová adresa</label>
            <div class="input-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg><input class="input" type="email" id="fpEmail" name="email" placeholder="meno@email.sk" required></div>
          </div>
          <button class="btn btn-primary btn-lg btn-block" type="submit">Poslať odkaz na obnovu</button>
        </form>
        <p class="muted center" style="margin-top:22px;font-size:var(--fs-sm)"><a href="/login" class="brand" style="font-weight:700">← Späť na prihlásenie</a></p>
      </div>

      <!-- PHASE 2: sent -->
      <div class="phase<%= (typeof sent !== 'undefined' && sent) ? ' active' : '' %>" id="p2">
        <div class="mail-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" style="width:30px;height:30px"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg></div>
        <h1>Skontroluj e-mail</h1>
        <p class="muted" style="margin:8px 0 18px">Ak účet s touto adresou existuje, poslali sme naň odkaz na obnovu hesla. Klikni naň do 60 minút.</p>
        <div class="card card-pad" style="background:var(--surface-2);padding:14px 16px;margin-bottom:18px">
          <p class="muted" style="font-size:var(--fs-sm)">Neprišiel e-mail? Skontroluj priečinok spam alebo skús poslať znova.</p>
        </div>
        <div class="row g-2 wrap-gap" style="margin-top:12px">
          <a class="btn btn-ghost btn-sm" href="/forgot-password">← Iný e-mail</a>
          <a class="btn btn-ghost btn-sm" href="/forgot-password">Poslať znova</a>
        </div>
      </div>

      <!-- PHASE 3: reset -->
      <div class="phase" id="p3">
        <h1>Nastav nové heslo</h1>
        <p class="muted" style="margin:8px 0 24px">Vyber si silné heslo, ktoré nepoužívaš na iných stránkach.</p>
        <form onsubmit="event.preventDefault();submitReset()">
          <div class="field" style="margin-bottom:16px"><label class="label">Nové heslo</label>
            <input class="input" type="password" id="np" placeholder="••••••••" required oninput="meter()">
            <div class="pw-meter"><i id="pwBar"></i></div>
            <span class="hint" id="pwHint">Min. 8 znakov, kombinuj písmená a čísla.</span>
          </div>
          <div class="field" style="margin-bottom:22px"><label class="label">Potvrdiť heslo</label><input class="input" type="password" id="np2" placeholder="••••••••" required></div>
          <button class="btn btn-primary btn-lg btn-block" type="submit">Uložiť nové heslo</button>
        </form>
      </div>

      <!-- DONE -->
      <div class="phase" id="pdone">
        <div class="mail-ico" style="background:var(--success-soft);color:var(--success)"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" style="width:30px;height:30px"><path d="M20 6L9 17l-5-5" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
        <h1>Heslo zmenené 🎉</h1>
        <p class="muted" style="margin:8px 0 24px">Tvoje heslo bolo úspešne aktualizované. Teraz sa môžeš prihlásiť s novým heslom.</p>
        <a href="/login" class="btn btn-primary btn-lg btn-block">Prihlásiť sa</a>
      </div>
    </div>
  </div>
</div>

<script>
  // Prepínanie fáz (čisto vizuálne — e-mailový backend pribudne neskôr).
  function goPhase(n){
    document.querySelectorAll('.phase').forEach(function(p){ p.classList.remove('active'); });
    var id = n === 'done' ? 'pdone' : 'p' + n;
    var el = document.getElementById(id);
    if (el) el.classList.add('active');
    // pip indikátor (done = všetky tri)
    var pipN = n === 'done' ? 3 : Number(n);
    document.querySelectorAll('[data-pip]').forEach(function(pip){
      pip.classList.toggle('on', Number(pip.getAttribute('data-pip')) <= pipN);
    });
    // pri prechode na fázu 2 zobraz zadaný e-mail
    if (Number(n) === 2) {
      var email = (document.getElementById('fpEmail').value || '').trim();
      var out = document.getElementById('fpEmailOut');
      if (out) out.textContent = email || 'tvojho účtu';
    }
  }

  // sila hesla (jednoduchý meter)
  function meter(){
    var v = document.getElementById('np').value || '';
    var score = 0;
    if (v.length >= 8) score++;
    if (/[A-Z]/.test(v)) score++;
    if (/[0-9]/.test(v)) score++;
    if (/[^A-Za-z0-9]/.test(v)) score++;
    var bar = document.getElementById('pwBar');
    var hint = document.getElementById('pwHint');
    var pct = [10, 35, 60, 80, 100][score];
    var col = score <= 1 ? 'var(--danger)' : score === 2 ? 'var(--warning)' : score === 3 ? 'var(--brand)' : 'var(--success)';
    bar.style.width = pct + '%';
    bar.style.background = col;
    hint.textContent = score <= 1 ? 'Slabé heslo — pridaj dĺžku a znaky.' : score === 2 ? 'Priemerné heslo.' : score === 3 ? 'Dobré heslo.' : 'Silné heslo 💪';
  }

  // odoslanie resetu (zatiaľ len UI: overí zhodu hesiel a prejde na hotovo)
  function submitReset(){
    var a = document.getElementById('np').value || '';
    var b = document.getElementById('np2').value || '';
    if (a.length < 8) { document.getElementById('pwHint').textContent = 'Heslo musí mať aspoň 8 znakov.'; return; }
    if (a !== b) { document.getElementById('pwHint').textContent = 'Heslá sa nezhodujú.'; return; }
    goPhase('done');
  }

  // "Poslať znova" tlačidlo bolo nahradené odkazom na /forgot-password,
  // takže tu už nič neviažeme. Funkcie meter()/submitReset() ostávajú pre
  // prípadné staršie prepojenia, no reálny reset prebieha na /reset-password.
</script>
<script src="/js/enhance.js"></script>
</body>
</html>
