<%- include('partials/head', { title: 'Rebríčky', page: 'leaderboards', active: 'leaderboards', pageStyle: `
  .lb-head { padding:32px 0 8px; }
  .podium { display:grid; grid-template-columns: 1fr 1.15fr 1fr; gap:16px; align-items:end; margin:24px 0 30px; }
  .pod { text-align:center; border-radius: var(--r-xl); padding:24px 16px 22px; position:relative; overflow:hidden; cursor:pointer; }
  .pod:hover { outline:1px solid var(--brand-line); }
  .pod .avatar { margin:0 auto 12px; }
  .pod-name { font-weight:800; color:var(--text-1); font-size:var(--fs-lg); }
  .pod-sub { font-size:var(--fs-xs); color:var(--text-4); margin-bottom:12px; }
  .pod-pts { font-family:var(--num); font-weight:700; font-size:2rem; line-height:1; font-variant-numeric:tabular-nums; white-space:nowrap; }
  .pod-rank { position:absolute; top:14px; left:14px; font-family:var(--num); font-weight:800; font-size:1.4rem; opacity:.5; }
  .pod1 { background: linear-gradient(180deg, color-mix(in srgb,var(--gold) 18%, var(--surface-1)), var(--surface-1)); border:1px solid rgba(250,204,21,.4); box-shadow: var(--glow-gold); }
  .pod1 .pod-pts { color:var(--gold); text-shadow:var(--text-glow-gold); }
  .pod2 { background: linear-gradient(180deg, color-mix(in srgb,#cdd6e6 14%, var(--surface-1)), var(--surface-1)); border:1px solid var(--line-strong); }
  .pod3 { background: linear-gradient(180deg, color-mix(in srgb,#e0935a 16%, var(--surface-1)), var(--surface-1)); border:1px solid rgba(224,147,90,.35); }
  .pod-crown { position:absolute; top:-2px; right:14px; font-size:22px; }
  .lb-layout { display:grid; grid-template-columns: 1fr 320px; gap:26px; align-items:start; padding-bottom:64px; }
  /* filtre: vždy 100% šírky. Search sa naťahuje, selecty majú min. šírku.
     Keď sa 3 do riadku nezmestia, search skočí na celý riadok sám a oba
     selecty pod neho, každý na 50 %. */
  .filters { display:flex; flex-wrap:wrap; gap:10px; align-items:center; margin-bottom:18px; width:100%; }
  .filters .search { flex:1 1 260px; min-width:260px; max-width:none; }
  .filters .select { flex:1 1 200px; min-width:180px; width:auto; }
  /* zlom: search sám na 100 %, selecty 50/50 vedľa seba */
  @media (max-width: 640px){
    .filters .search { flex:1 1 100%; min-width:0; }
    .filters .select { flex:1 1 calc(50% - 5px); min-width:0; }
  }
  .lb-table .lb-row { border-top:1px solid var(--line); border-radius:0; grid-template-columns: 52px 1fr auto 96px; border-bottom:1px solid var(--line); border-radius:0; padding:13px 14px; cursor:pointer; transition:background .14s; }
  .lb-table .lb-row:hover { background:var(--surface-2); }
  .lb-table .lb-row:last-child { border-top:1px solid var(--line); border-radius:0; border-bottom:none; }
  /* zvýraznený hráč: zaoblený „chip" s vlastným orámovaním a medzerou,
     aby sa jeho okraje nekryli s deliacimi čiarami susedných riadkov. */
  .lb-table .lb-row.me { background:color-mix(in srgb,var(--brand) 8%,transparent); border:1px solid var(--brand-line); border-radius:var(--r-md); margin:6px 0; }
  
  .lb-table .lb-row { grid-template-columns: 52px 1fr auto 96px; border-bottom:1px solid var(--line); border-radius:0; padding:13px 14px; cursor:pointer; transition:background .14s; }
  .lb-table .lb-row.me:hover { background:var(--surface-3); }

  .lb-head-row { grid-template-columns: 52px 1fr auto 96px; display:grid; gap:14px; padding:10px 14px; align-items:center; }
  .lb-head-row span { font-size:var(--fs-xs); text-transform:uppercase; letter-spacing:.1em; color:var(--text-4); font-weight:700; }
  .ta-r { text-align:right; }
  .lb-row { display:grid; gap:14px; align-items:center; }
  .lb-user { display:flex; align-items:center; gap:11px; min-width:0; }
  .lb-name { font-weight:700; color:var(--text-1); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
  .lb-sub { font-size:var(--fs-xs); color:var(--text-4); }
  .lb-pts { font-family:var(--num); font-weight:700; font-variant-numeric:tabular-nums; }
  .lb-rank { font-family:var(--num); font-weight:800; font-variant-numeric:tabular-nums; text-align:center; }
  .lb-rank.top1 { color:var(--gold); } .lb-rank.top2 { color:#cdd6e6; } .lb-rank.top3 { color:#e0935a; }
  .sticky-side { position:sticky; top:92px; }
  .sticky-side > * + * { margin-top:18px; }
  .lb-empty { text-align:center; color:var(--text-3); padding:48px 0; }
  @media (max-width: 980px){ .lb-layout { grid-template-columns:1fr; } .sticky-side { position:static; } }
  @media (max-width: 720px){
    .podium { grid-template-columns:1fr; gap:12px; }
    .pod1 { order:0; } .pod2 { order:1; } .pod3 { order:2; }
    .pod .avatar { width:64px; height:64px; font-size:24px; }
    .lb-table .lb-row, .lb-head-row { grid-template-columns: 28px 1fr auto; gap:9px; padding:11px 8px; }
    .col-hide { display:none; }
    .lb-table .avatar.avatar-md { width:32px; height:32px; font-size:12px; }
    .lb-name { font-size:var(--fs-sm); }
    .lb-sub { font-size:10px; }
    .lb-pts { font-size:1rem; }
    .lb-rank { font-size:.95rem; }
  }
` }) %>

<%
  var GRADS = ['135deg,#3a7bd5,#1b3f72','135deg,#16a085,#0c5f4d','135deg,#c0392b,#7d2018','135deg,#8e44ad,#522963','135deg,#2c3e50,#1a252f','135deg,#d35400,#8a3700','135deg,#27ae60,#155d33','135deg,#7c5cff,#5b3fd6'];
  function grad(id){ return GRADS[(Number(id)||0) % GRADS.length]; }
  function roleTag(role){
    if (role === 'vip') return '<span class="chip-role role-vip" style="vertical-align:middle">VIP</span>';
    if (role === 'admin') return '<span class="chip-role role-admin" style="vertical-align:middle">Admin</span>';
    return '';
  }
%>

<div class="wrap lb-head">
  <div class="between wrap-gap" style="gap:16px">
    <div>
      <div class="eyebrow">Rebríčky</div>
      <h1 style="font-size:clamp(2rem,3.4vw,2.8rem)">Najlepší tipéri</h1>
      <p class="muted" style="margin-top:6px">Globálne poradie z oficiálnych líg · <%= periodLabel %></p>
    </div>
  </div>

  <% if (board.length === 0) { %>
    <div class="card card-pad lb-empty">Zatiaľ žiadne vyhodnotené tipy v oficiálnych ligách za posledný rok.</div>
  <% } else { %>

  <!-- PODIUM -->
  <div class="podium">
    <% var p2 = podium[1], p1 = podium[0], p3 = podium[2]; %>
    <% if (p2) { %>
    <div class="pod pod2" data-uid="<%= p2.userId %>" data-player-link="<%= p2.userId %>" data-me="<%= (meId && p2.userId === meId) ? '1' : '0' %>">
      <span class="pod-rank top2">2</span>
      <%- include('partials/avatar', { image: p2.profileImage, initials: p2.initials, cls: 'avatar-xl', grad: 'linear-gradient('+grad(p2.userId)+')' }) %>
      <div class="pod-name"><%= p2.name %></div>
      <div class="pod-sub">@<%= p2.username %> · <%= p2.evaluated %> tipov</div>
      <div class="pod-pts" style="color:#cdd6e6"><%= p2.totalPoints %></div>
    </div>
    <% } else { %><div></div><% } %>

    <% if (p1) { %>
    <div class="pod pod1" data-uid="<%= p1.userId %>" data-player-link="<%= p1.userId %>" data-me="<%= (meId && p1.userId === meId) ? '1' : '0' %>">
      <span class="pod-crown">👑</span>
      <span class="pod-rank top1">1</span>
      <%- include('partials/avatar', { image: p1.profileImage, initials: p1.initials, cls: 'avatar-xl avatar-ring', grad: 'linear-gradient(135deg,var(--gold-bright),var(--gold-dim))', ink: 'var(--gold-ink)' }) %>
      <div class="pod-name"><%= p1.name %></div>
      <div class="pod-sub">@<%= p1.username %> · <%= p1.evaluated %> tipov</div>
      <div class="pod-pts"><%= p1.totalPoints %></div>
    </div>
    <% } %>

    <% if (p3) { %>
    <div class="pod pod3" data-uid="<%= p3.userId %>" data-player-link="<%= p3.userId %>" data-me="<%= (meId && p3.userId === meId) ? '1' : '0' %>">
      <span class="pod-rank top3">3</span>
      <%- include('partials/avatar', { image: p3.profileImage, initials: p3.initials, cls: 'avatar-xl', grad: 'linear-gradient('+grad(p3.userId)+')' }) %>
      <div class="pod-name"><%= p3.name %></div>
      <div class="pod-sub">@<%= p3.username %> · <%= p3.evaluated %> tipov</div>
      <div class="pod-pts" style="color:#e0935a"><%= p3.totalPoints %></div>
    </div>
    <% } else { %><div></div><% } %>
  </div>
  <% } %>
</div>

<% if (board.length > 0) { %>
<div class="wrap lb-layout">
  <main>
    <div class="filters">
      <div class="input-icon search">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4" stroke-linecap="round"/></svg>
        <input class="input" id="lbSearch" placeholder="Hľadať hráča…">
      </div>
      <select class="select" id="lbSeason">
        <option value="">Všetky oficiálne sezóny</option>
        <% officialLeagues.forEach(function(l){ %>
          <option value="<%= l.id %>"<%= (seasonFilter && seasonFilter === l.id) ? ' selected' : '' %>><%= l.name %></option>
        <% }); %>
      </select>
      <select class="select" id="lbSort">
        <option value="points">Zoradiť: Body</option>
        <option value="accuracy">Zoradiť: Presnosť %</option>
      </select>
    </div>

    <div class="card" style="padding:8px">
      <div class="lb-head-row">
        <span>#</span><span>Hráč</span><span class="col-hide">Presnosť</span><span class="ta-r">Body</span>
      </div>
      <div class="hr"></div>
      <div class="lb-table" id="lbTable">
        <% board.forEach(function(r){ %>
          <div class="lb-row<%= (meId && r.userId === meId) ? ' me' : '' %>" data-uid="<%= r.userId %>" data-player-link="<%= r.userId %>" data-me="<%= (meId && r.userId === meId) ? '1' : '0' %>" data-name="<%= (r.name + ' @' + r.username).toLowerCase() %>" data-points="<%= r.totalPoints %>" data-accuracy="<%= r.accuracy || 0 %>">
            <span class="lb-rank<%= r.rank === 1 ? ' top1' : (r.rank === 2 ? ' top2' : (r.rank === 3 ? ' top3' : '')) %>"><%= r.rank %></span>
            <div class="lb-user">
              <%- include('partials/avatar', { image: r.profileImage, initials: r.initials, cls: 'avatar-md', grad: 'linear-gradient('+(r.rank === 1 ? '135deg,var(--gold-bright),var(--gold-dim)' : grad(r.userId))+')', ink: (r.rank === 1 ? 'var(--gold-ink)' : '#fff') }) %>
              <div style="min-width:0"><div class="lb-name"><%= r.name %> <%- roleTag(r.role) %><% if (meId && r.userId === meId) { %> <span class="tag tag-brand" style="vertical-align:middle;padding:1px 6px">Ty</span><% } %></div><div class="lb-sub">@<%= r.username %> · <%= r.evaluated %> tipov</div></div>
            </div>
            <span class="col-hide num" style="font-weight:700;color:<%= (r.accuracy||0) >= 60 ? 'var(--success)' : 'var(--text-2)' %>"><%= r.accuracy != null ? r.accuracy + ' %' : '—' %></span>
            <span class="lb-pts ta-r<%= r.rank === 1 ? ' gold' : '' %>"><%= r.totalPoints %></span>
          </div>
        <% }); %>
      </div>
      <div class="lb-empty" id="lbNoRes" hidden>Žiadny hráč nevyhovuje hľadaniu.</div>
      <div class="row g-2" id="lbPager" hidden style="justify-content:center;margin-top:16px;padding-bottom:8px">
        <button type="button" class="btn btn-secondary btn-sm" id="lbPrev">← Predošlé</button>
        <span class="muted" id="lbPageInfo" style="font-size:var(--fs-sm);align-self:center"></span>
        <button type="button" class="btn btn-secondary btn-sm" id="lbNext">Ďalšie →</button>
      </div>
    </div>
  </main>

  <aside class="sticky-side">
    <% if (myRow) { %>
    <div class="card card-pad card-glow">
      <div class="stat-label">Tvoja pozícia</div>
      <div class="row g-3" style="margin:12px 0 6px"><span class="stat-value brand" style="font-size:2.6rem">#<%= myRow.rank %></span><span class="muted" style="font-size:var(--fs-sm)">z <%= board.length %> hráčov</span></div>
      <p class="muted" style="font-size:var(--fs-sm)"><b class="hi num"><%= myRow.totalPoints %></b> bodov · presnosť <b class="hi"><%= myRow.accuracy != null ? myRow.accuracy + ' %' : '—' %></b></p>
      <% if (myRow.rank > 1) { var ahead = board[myRow.rank - 2]; %>
        <p class="muted" style="font-size:var(--fs-sm);margin-top:8px">Na <%= myRow.rank - 1 %>. miesto ti chýba <b class="hi num"><%= ahead.totalPoints - myRow.totalPoints %></b> bodov.</p>
      <% } %>
      <a href="/my" class="btn btn-brand btn-block btn-sm" style="margin-top:14px">Moje súťaže →</a>
    </div>
    <% } else if (meId) { %>
    <div class="card card-pad">
      <div class="stat-label" style="margin-bottom:8px">Tvoja pozícia</div>
      <p class="muted" style="font-size:var(--fs-sm)">Zatiaľ nemáš body v oficiálnych ligách za posledný rok. Pridaj sa do oficiálnej sezóny a začni tipovať.</p>
      <a href="/seasons" class="btn btn-secondary btn-block btn-sm" style="margin-top:12px">Objaviť súťaže →</a>
    </div>
    <% } %>

    <% if (movers && movers.length) { %>
    <div class="card card-pad">
      <div class="stat-label" style="margin-bottom:12px">📈 Najväčší skokani týždňa</div>
      <div class="stack g-2">
        <% movers.forEach(function(m){ %>
          <div class="row between" style="padding:8px 4px">
            <span class="row g-2" style="min-width:0">
              <%- include('partials/avatar', { image: m.profileImage, initials: m.initials, cls: 'avatar-sm', grad: 'linear-gradient('+grad(m.userId)+')' }) %>
              <span style="min-width:0"><span style="font-weight:700;color:var(--text-1);font-size:var(--fs-sm);display:block;white-space:nowrap;overflow:hidden;text-overflow:ellipsis"><%= m.name %></span><span class="muted" style="font-size:var(--fs-xs)">+<%= m.gained %> b za týždeň · teraz #<%= m.rank %></span></span>
            </span>
            <% if (m.climb > 0) { %><span class="tag tag-success" style="flex:none">▲ <%= m.climb %></span><% } else { %><span class="muted" style="font-size:var(--fs-xs);flex:none">—</span><% } %>
          </div>
        <% }); %>
      </div>
      <p class="muted" style="font-size:var(--fs-xs);margin-top:10px">Porovnanie oproti stavu spred 7 dní.</p>
    </div>
    <% } %>

    <% if (officialLeagues.length) { %>
    <div class="card card-pad">
      <div class="stat-label" style="margin-bottom:10px">Rebríčky podľa sezóny</div>
      <div class="stack g-2">
        <% var seen = {}; officialLeagues.forEach(function(l){ if (seen[l.id]) return; seen[l.id] = 1; %>
          <a href="/seasons/<%= l.id %>/leaderboard" class="row between" style="padding:9px 11px;border-radius:var(--r-sm);background:var(--surface-2)"><span class="row g-2"><span class="team-logo" style="width:24px;height:24px;font-size:10px;<% if (l.image) { %>background:var(--surface-3);overflow:hidden<% } else { %>background:linear-gradient(<%= grad(l.id) %>)<% } %>"><% if (l.image) { %><img src="<%= l.image %>" alt="" style="width:100%;height:100%;object-fit:cover"><% } else { %><%= (l.name||'S').substring(0,2).toUpperCase() %><% } %></span><span style="font-weight:600;color:var(--text-1);font-size:var(--fs-sm)"><%= l.name %></span></span><span class="faint">›</span></a>
        <% }); %>
      </div>
    </div>
    <% } %>
  </aside>
</div>
<% } %>

<script>
(function(){
  // Klik na riadok/pódium → profil hráča rieši centrálny helper v enhance.js
  // (initPlayerRows) cez atribút data-player-link. Tu už netreba viazať klik.

  // hľadanie
  var s = document.getElementById('lbSearch');
  var noRes = document.getElementById('lbNoRes');
  if (s) s.addEventListener('input', function(){
    var q = this.value.trim().toLowerCase(); var any = false;
    // Pri hľadaní sa stránkovanie vypína — filtruje sa naprieč VŠETKÝMI riadkami,
    // inak by zhoda mimo aktuálnej strany ostala skrytá. Po vymazaní dopytu sa
    // stránkovanie obnoví cez window.lbRepage (definované nižšie).
    document.querySelectorAll('.lb-table .lb-row').forEach(function(r){
      var show = !q || (r.dataset.name || '').indexOf(q) >= 0;
      r.style.display = show ? '' : 'none'; if (show) any = true;
    });
    if (noRes) noRes.hidden = any;
    var pg = document.getElementById('lbPager');
    if (q) { if (pg) pg.hidden = true; }
    else if (window.lbRepage) window.lbRepage();
  });

  // filter podľa sezóny → reload s ?season=
  var seasonSel = document.getElementById('lbSeason');
  if (seasonSel) seasonSel.addEventListener('change', function(){
    var v = this.value;
    location.href = v ? ('/leaderboards?season=' + encodeURIComponent(v)) : '/leaderboards';
  });

  // zoradenie
  var sortSel = document.getElementById('lbSort');
  var table = document.getElementById('lbTable');
  if (sortSel && table) sortSel.addEventListener('change', function(){
    var key = this.value;
    var rows = Array.prototype.slice.call(table.querySelectorAll('.lb-row'));
    rows.sort(function(a,b){ return (+b.dataset[key]) - (+a.dataset[key]); });
    rows.forEach(function(r){ table.appendChild(r); });
  });
})();
</script>

<script>
(function(){
  // Stránkovanie rebríčka — 40 riadkov na stranu. Prebieha na klientovi, takže
  // funguje spolu s existujúcim triedením (riadky sa len skrývajú/zobrazujú).
  var PAGE_SIZE = 40;
  var table = document.getElementById('lbTable');
  var pager = document.getElementById('lbPager');
  if (!table || !pager) return;

  var info = document.getElementById('lbPageInfo');
  var prev = document.getElementById('lbPrev');
  var next = document.getElementById('lbNext');
  var page = 1;

  function rows() { return Array.prototype.slice.call(table.querySelectorAll('.lb-row')); }

  function render() {
    var all = rows();
    var pages = Math.max(1, Math.ceil(all.length / PAGE_SIZE));
    if (page > pages) page = pages;
    if (page < 1) page = 1;

    all.forEach(function (r, i) {
      var from = (page - 1) * PAGE_SIZE;
      r.style.display = (i >= from && i < from + PAGE_SIZE) ? '' : 'none';
    });

    pager.hidden = all.length <= PAGE_SIZE;
    if (info) {
      var first = (page - 1) * PAGE_SIZE + 1;
      var last = Math.min(page * PAGE_SIZE, all.length);
      info.textContent = first + '–' + last + ' z ' + all.length;
    }
    if (prev) prev.disabled = page <= 1;
    if (next) next.disabled = page >= pages;
  }

  // umožní vyhľadávaniu obnoviť stránkovanie po vymazaní dopytu
  window.lbRepage = function () { page = 1; render(); };

  if (prev) prev.addEventListener('click', function () { page--; render(); if (table.scrollIntoView) table.scrollIntoView({ behavior: 'smooth', block: 'start' }); });
  if (next) next.addEventListener('click', function () { page++; render(); if (table.scrollIntoView) table.scrollIntoView({ behavior: 'smooth', block: 'start' }); });

  // po zmene triedenia sa vráť na prvú stranu a prekresli
  var sortSel = document.getElementById('lbSort');
  if (sortSel) sortSel.addEventListener('change', function () { page = 1; setTimeout(render, 0); });

  render();
})();
</script>


<%- include('partials/footer') %>
