<%- include('partials/head', { title: 'Vyhodnotenie zápasov', page: 'seasons', active: 'seasons', pageStyle: `
  .ad-head { padding:24px 0 16px; }
  .crumb { font-size:var(--fs-sm); color:var(--text-4); margin-bottom:12px; }
  .crumb a { color:var(--text-3); } .crumb a:hover { color:var(--brand-bright); }
  .ev-layout { display:grid; grid-template-columns:1fr 320px; gap:26px; align-items:start; padding-bottom:64px; }
  .ev-match { padding:20px 22px; margin-bottom:14px; transition:border-color .15s; }
  .ev-match.done { border-color:var(--success-line); }
  .ev-match.canceled { opacity:.7; }
  .ev-top { display:flex; align-items:center; justify-content:space-between; gap:14px; margin-bottom:18px; flex-wrap:wrap; }
  .ev-teams { display:grid; grid-template-columns:1fr auto 1fr; gap:18px; align-items:center; }
  .ev-team { display:flex; align-items:center; gap:12px; }
  .ev-team.r { flex-direction:row-reverse; }
  .ev-team .nm { font-family:var(--font-display); font-weight:700; font-size:var(--fs-lg); color:var(--text-1); }
  .ev-score { display:flex; align-items:center; gap:12px; }
  .ev-score input { width:62px; height:62px; text-align:center; font-family:var(--num); font-weight:700; font-size:1.8rem; padding:0; border-radius:var(--r-md); }
  .ev-colon { font-family:var(--num); font-weight:700; font-size:1.6rem; color:var(--text-4); }
  .ev-actions { display:flex; gap:10px; align-items:center; margin-top:18px; padding-top:16px; border-top:1px solid var(--line); flex-wrap:wrap; }
  .ev-meta { font-size:var(--fs-sm); color:var(--text-4); }
  .info-banner { display:flex; gap:12px; align-items:flex-start; padding:14px 16px; border-radius:var(--r-md); background:var(--info-soft); border:1px solid rgba(58,160,255,.25); margin-bottom:20px; }
  @media (max-width:980px){ .ev-layout { grid-template-columns:1fr; } }
  @media (max-width:560px){
    .ev-match { padding:18px; }
    /* tag + date centered, stacked (tag first, then date · place) */
    .ev-top { flex-direction:column-reverse; align-items:center; text-align:center; gap:8px; margin-bottom:16px; }
    /* teams: logo above name, centered, side by side with the score field between */
    .ev-teams { grid-template-columns:1fr auto 1fr; gap:10px; align-items:start; }
    .ev-team { flex-direction:column; align-items:center; text-align:center; gap:7px; }
    .ev-team.r { flex-direction:column; }
    .ev-team .nm { font-size:var(--fs-sm); line-height:1.15; }
    .ev-score { gap:6px; align-self:center; }
    .ev-score input { width:46px; height:46px; font-size:1.35rem; }
    /* actions stacked: save (full), cancel below, meta text last & centered */
    .ev-actions { flex-direction:column; align-items:stretch; gap:10px; }
    .ev-actions .btn { width:100%; }
    .ev-actions .tag { align-self:center; }
    .ev-actions .grow { flex:none; }
    .ev-actions .ev-meta { text-align:center !important; }
  }
` }) %>

<%- include('partials/season-subnav', { seasonId: league.seasonId, seasonName: (league.Season && league.Season.name) || 'Sezóna', active: 'leagues' }) %>

<%
  function fmtDT(d){ if(!d) return ''; var dt=new Date(d); return dt.toLocaleDateString('sk-SK',{day:'numeric',month:'short'})+' · '+dt.toLocaleTimeString('sk-SK',{hour:'2-digit',minute:'2-digit'}); }
%>

<div class="wrap ad-head">
  <div class="crumb"><a href="/leagues/<%= league.id %>"><%= league.name %></a> › <a href="/rounds/<%= round.id %>"><%= round.name %></a> › Vyhodnotenie</div>
  <div class="between wrap-gap" style="gap:16px">
    <div><h1 style="font-size:clamp(1.8rem,3vw,2.4rem)">Vyhodnotenie zápasov</h1><p class="muted" style="margin-top:6px">Zadaj výsledné skóre. Body sa hráčom pridelia automaticky po uložení.</p></div>
  </div>
</div>

<div class="wrap ev-layout">
  <main>
    <div class="info-banner">
      <span style="font-size:17px">🔒</span>
      <div style="font-size:var(--fs-sm);color:var(--text-2)">Výsledky zadávaš <b class="hi">oddelene od tipov hráčov</b> — ich tipy nevidíš, kým výsledok neuložíš. Tým je zaručená férovosť. Zrušený zápas neprideľuje žiadne body.</div>
    </div>

    <% if (matches.length === 0) { %>
      <div class="card card-pad" style="text-align:center;padding:40px"><p class="muted">V tomto kole nie sú žiadne zápasy.</p></div>
    <% } %>

    <% matches.forEach(function (m) { var done = m.status === 'finished'; var canceled = m.status === 'canceled'; %>
    <div class="card ev-match<%= done ? ' done' : '' %><%= canceled ? ' canceled' : '' %>" data-match-id="<%= m.id %>">
      <div class="ev-top"><span class="ev-meta"><%= fmtDT(m.matchTime) %></span>
        <% if (done) { %><span class="tag tag-success" data-status><span class="dot"></span>Vyhodnotené</span>
        <% } else if (canceled) { %><span class="tag tag-muted" data-status><span class="dot" style="background:var(--text-4)"></span>Zrušený</span>
        <% } else { %><span class="tag tag-warning" data-status><span class="dot"></span>Čaká na výsledok</span><% } %>
      </div>
      <div class="ev-teams">
        <div class="ev-team"><span class="team-logo" style="width:42px;height:42px;font-size:13px;background:var(--surface-3)"><%= m.homeAbbr %></span><span class="nm"><%= m.homeTeam ? m.homeTeam.name : '—' %></span></div>
        <% if (done) { %>
          <div class="ev-score"><span class="num" style="font-size:1.9rem;font-weight:700;color:var(--success)" data-hs><%= m.homeScore %></span><span class="ev-colon">:</span><span class="num" style="font-size:1.9rem;font-weight:700;color:var(--text-1)" data-as><%= m.awayScore %></span></div>
        <% } else if (canceled) { %>
          <div class="ev-score"><span class="ev-colon">—</span></div>
        <% } else { %>
          <div class="ev-score"><input class="input" inputmode="numeric" placeholder="0" data-home><span class="ev-colon">:</span><input class="input" inputmode="numeric" placeholder="0" data-away></div>
        <% } %>
        <div class="ev-team r"><span class="team-logo" style="width:42px;height:42px;font-size:13px;background:var(--surface-3)"><%= m.awayAbbr %></span><span class="nm"><%= m.awayTeam ? m.awayTeam.name : '—' %></span></div>
      </div>
      <div class="ev-actions">
        <% if (done) { %>
          <span class="tag tag-success">✓ Body pridelené</span><button class="btn btn-secondary btn-sm" data-edit>Upraviť výsledok</button>
        <% } else if (canceled) { %>
          <span class="tag tag-muted">Žiadne body sa neprideľujú</span><button class="btn btn-secondary btn-sm" data-restore>Obnoviť zápas</button>
        <% } else { %>
          <button class="btn btn-primary" data-save>Uložiť výsledok</button><button class="btn btn-ghost" data-cancel>Označiť ako zrušený</button>
        <% } %>
        <span class="ev-meta grow" style="text-align:right"><%= m.tipsCount %> hráčov tipovalo tento zápas</span>
      </div>
    </div>
    <% }); %>
  </main>

  <aside style="position:sticky;top:140px">
    <div class="card card-pad">
      <div class="stat-label" style="margin-bottom:12px">Stav kola</div>
      <div class="row g-3" style="margin-bottom:14px"><span class="stat-value" style="font-size:2.2rem"><%= stats.pending %><span style="color:var(--text-4);font-size:1.2rem">/<%= stats.total %></span></span><div style="align-self:center"><div class="muted" style="font-size:var(--fs-sm)">zostáva vyhodnotiť</div></div></div>
      <div class="progress" style="margin-bottom:16px"><i style="width:<%= stats.total ? Math.round((stats.evaluated+stats.canceled)/stats.total*100) : 0 %>%"></i></div>
      <div class="stack g-2" style="font-size:var(--fs-sm)">
        <div class="between"><span class="status-dot" style="color:var(--success)"><span class="d" style="width:7px;height:7px;border-radius:50%;background:var(--success)"></span>Vyhodnotené</span><b class="hi num"><%= stats.evaluated %></b></div>
        <div class="between"><span class="status-dot" style="color:var(--warning)"><span class="d" style="width:7px;height:7px;border-radius:50%;background:var(--warning)"></span>Čaká</span><b class="hi num"><%= stats.pending %></b></div>
        <div class="between"><span class="status-dot" style="color:var(--text-4)"><span class="d" style="width:7px;height:7px;border-radius:50%;background:var(--text-4)"></span>Zrušené</span><b class="hi num"><%= stats.canceled %></b></div>
      </div>
    </div>
    <div class="card card-pad" style="margin-top:18px;background:var(--surface-2)">
      <b class="hi" style="display:block;margin-bottom:6px">💡 Tip</b>
      <p class="muted" style="font-size:var(--fs-sm)">Po uložení výsledku sa body okamžite prepočítajú všetkým hráčom, ktorí zápas tipovali.</p>
    </div>
  </aside>
</div>

<div class="toast-wrap" id="toastWrap" style="position:fixed;bottom:24px;right:24px;z-index:200;display:flex;flex-direction:column;gap:10px"></div>

<script>
(function () {
  function toast(msg, ok){ var t=document.createElement('div'); t.textContent=msg; t.style.cssText='background:'+(ok?'var(--success)':'var(--surface-2)')+';color:'+(ok?'#fff':'var(--text-1)')+';border:1px solid var(--line);padding:10px 14px;border-radius:10px'; document.getElementById('toastWrap').appendChild(t); setTimeout(function(){t.remove();},2500); }

  function evaluate(card, body, okMsg) {
    var id = card.getAttribute('data-match-id');
    fetch('/api/matches/'+id+'/evaluate', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(body) })
      .then(function(r){ return r.json(); })
      .then(function(res){ if (res.success === false) { toast(res.message || 'Nepodarilo sa uložiť.'); return; } toast(okMsg, true); setTimeout(function(){ location.reload(); }, 700); })
      .catch(function(){ toast('Chyba pri ukladaní.'); });
  }

  document.addEventListener('click', function (e) {
    var card = e.target.closest('[data-match-id]'); if (!card) return;

    if (e.target.closest('[data-save]')) {
      var h = card.querySelector('[data-home]').value, a = card.querySelector('[data-away]').value;
      if (h === '' || a === '') { toast('Zadaj obe skóre.'); return; }
      evaluate(card, { homeScore: Number(h), awayScore: Number(a), status: 'finished' }, 'Výsledok uložený, body pridelené ✓');
    }
    else if (e.target.closest('[data-cancel]')) {
      if (!confirm('Označiť zápas ako zrušený? Body sa nikomu nepridelia.')) return;
      evaluate(card, { status: 'canceled' }, 'Zápas zrušený');
    }
    else if (e.target.closest('[data-edit]') || e.target.closest('[data-restore]')) {
      // prepni kartu späť na zadávanie skóre
      var teams = card.querySelector('.ev-score');
      teams.innerHTML = '<input class="input" inputmode="numeric" placeholder="0" data-home><span class="ev-colon">:</span><input class="input" inputmode="numeric" placeholder="0" data-away>';
      var actions = card.querySelector('.ev-actions');
      var meta = actions.querySelector('.ev-meta');
      actions.innerHTML = '<button class="btn btn-primary" data-save>Uložiť výsledok</button><button class="btn btn-ghost" data-cancel>Označiť ako zrušený</button>';
      if (meta) actions.appendChild(meta);
      card.classList.remove('done','canceled');
    }
  });
})();
</script>

<%- include('partials/footer') %>
