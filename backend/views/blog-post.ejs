<%- include('partials/head', { title: article.title, page: 'blog', active: 'blog', pageStyle: `
  .art-hero { min-height:340px; position:relative; display:flex; align-items:flex-end; overflow:hidden; }
  .art-hero::after { position:absolute; right:6%; top:50%; transform:translateY(-50%); font-size:160px; opacity:.18; z-index:0; }
  .art-hero::before { content:""; position:absolute; inset:0; background:linear-gradient(180deg, rgba(9,12,22,.12) 0%, transparent 32%, rgba(9,12,22,.92) 100%); z-index:1; }
  .art-hero-inner { position:relative; z-index:2; padding-block:36px 32px; }
  .art-layout { display:grid; grid-template-columns: 1fr 240px; gap:40px; align-items:start; padding-block:36px 64px; }
  .article { max-width:680px; }
  .article p { color:var(--text-2); font-size:1.075rem; line-height:1.75; margin-bottom:22px; }
  .article h2 { font-size:var(--fs-h3); margin:38px 0 14px; scroll-margin-top:92px; }
  .article h3 { font-size:var(--fs-h4); margin:28px 0 10px; color:var(--text-1); }
  .article ul { margin:0 0 22px; padding-left:4px; list-style:none; }
  .article li { color:var(--text-2); font-size:1.075rem; line-height:1.7; padding-left:28px; position:relative; margin-bottom:10px; }
  .article li::before { content:"\\203A"; position:absolute; left:8px; color:var(--brand-bright); font-weight:700; }
  .article a { color:var(--brand-bright); }
  .article strong, .article b { color:var(--text-1); }
  .pull { border-left:3px solid var(--brand); padding:6px 0 6px 22px; margin:28px 0; font-family:var(--font-display); font-size:1.35rem; color:var(--text-1); line-height:1.4; }
  .art-side { position:sticky; top:92px; }
  .toc a { display:block; padding:7px 0; font-size:var(--fs-sm); color:var(--text-3); border-left:2px solid var(--line); padding-left:14px; transition:all .15s; text-decoration:none; }
  .toc a:hover, .toc a.active { color:var(--brand-bright); border-left-color:var(--brand); }
  .share-btn { width:40px; height:40px; border-radius:var(--r-sm); display:flex; align-items:center; justify-content:center; background:var(--surface-2); border:1px solid var(--line); color:var(--text-3); }
  .share-btn:hover { color:var(--text-1); border-color:var(--brand-line); }
  @media (max-width:900px){ .art-layout { grid-template-columns:1fr; } .art-side { position:static; }     .toc-block { display:none; }
    .share-block { text-align:center; }
    .share-row { justify-content:center; }}
  @media (max-width:720px){
    .art-hero { min-height:0; }
    .art-hero-inner { padding-block:24px 26px; }
    .art-hero::after { font-size:118px; right:-18px; top:-6px; transform:none; opacity:.13; }
    .art-hero::before { background:linear-gradient(180deg, rgba(9,12,22,.30) 0%, rgba(9,12,22,.55) 55%, rgba(9,12,22,.95) 100%); }
    .article h2 { margin:30px 0 12px; }
    .toc-block { display:none; }
    .share-block { text-align:center; }
    .share-row { justify-content:center; }
    .post-grid { grid-template-columns:1fr !important; }
  }
` }) %>
<%
  const SK_M = ['jan','feb','mar','apr','máj','jún','júl','aug','sep','okt','nov','dec'];
  function fmtDate(d) { const x = new Date(d); return x.getDate() + '. ' + SK_M[x.getMonth()] + ' ' + x.getFullYear(); }
  function catTag(c){ switch(c){case 'Stratégia':return 'tag-brand';case 'Novinky':return 'tag-info';case 'Rozhovory':return 'tag-brand';case 'Návody':return 'tag-gold';default:return 'tag-info';} }
  const authorName = article.author && article.author.username ? article.author.username : '—';
  const authorInit = authorName !== '—' ? authorName.substring(0,2).toUpperCase() : '?';
%>

<!-- HERO -->
<header class="art-hero" style="background:<%= article.coverGradient %>">
  <style>.art-hero::after{content:"<%= article.coverEmoji %>";}</style>
  <div class="wrap art-hero-inner">
    <a href="/blog" class="muted" style="font-size:var(--fs-sm);display:inline-block;margin-bottom:14px">← Späť na blog</a>
    <div class="row g-2 wrap-gap" style="margin-bottom:14px"><span class="tag <%= catTag(article.category) %>"><%= article.category %></span><span class="muted" style="font-size:var(--fs-sm)"><%= article.readMinutes %> min čítania</span></div>
    <h1 style="font-size:clamp(1.9rem,3.6vw,3rem);max-width:18ch;color:#fff"><%= article.title %></h1>
    <div class="row g-3" style="margin-top:20px"><span class="avatar avatar-md" style="background:linear-gradient(135deg,#7c5cff,#5b3fd6);color:#fff;overflow:hidden"><% if (article.author && article.author.profileImage) { %><img src="<%= article.author.profileImage %>" alt="<%= authorName %>" style="width:100%;height:100%;object-fit:cover"><% } else { %><%= authorInit %><% } %></span><div><b style="color:#fff"><%= authorName %></b><div style="color:rgba(255,255,255,.65);font-size:var(--fs-sm)"><%= fmtDate(article.createdAt) %></div></div></div>
  </div>
</header>

<div class="wrap art-layout">
  <!-- ARTICLE -->
  <article class="article">
    <% if (article.excerpt) { %><p><b class="hi"><%= article.excerpt %></b></p><% } %>
    <%- contentHtml %>

    <div class="hr" style="margin:34px 0"></div>
    <div class="row g-3"><span class="avatar avatar-lg" style="background:linear-gradient(135deg,#7c5cff,#5b3fd6);color:#fff;overflow:hidden"><% if (article.author && article.author.profileImage) { %><img src="<%= article.author.profileImage %>" alt="<%= authorName %>" style="width:100%;height:100%;object-fit:cover"><% } else { %><%= authorInit %><% } %></span><div><b class="hi"><%= authorName %></b><p class="muted" style="font-size:var(--fs-sm);margin:0">Autor článku na Tiperlige.</p></div></div>
  </article>

  <!-- SIDE -->
  <aside class="art-side">
    <div class="toc-block">
      <div class="stat-label" style="margin-bottom:12px">Obsah článku</div>
      <nav class="toc" style="margin-bottom:28px">
        <% (toc || []).forEach(function(h){ %>
          <a href="#<%= h.id %>"><%= h.text %></a>
        <% }); %>
      </nav>
    </div>
    <div class="share-block">
      <div class="stat-label" style="margin-bottom:10px">Zdieľať</div>
      <div class="row g-2 share-row" style="margin-bottom:28px">
        <a class="share-btn" data-share="x" target="_blank" rel="noopener" title="Zdieľať na X">𝕏</a>
        <a class="share-btn" data-share="fb" target="_blank" rel="noopener" title="Zdieľať na Facebooku">f</a>
        <a class="share-btn" data-share="in" target="_blank" rel="noopener" title="Zdieľať na LinkedIn">in</a>
        <button type="button" class="share-btn" data-share="native" title="Zdieľať (Instagram a ďalšie)" style="cursor:pointer" hidden>📲</button>
        <button type="button" class="share-btn" data-share="copy" title="Kopírovať odkaz" style="cursor:pointer">🔗</button>
      </div>
    </div>
    <div class="card card-pad" style="background:linear-gradient(135deg,var(--surface-1),color-mix(in srgb,var(--brand) 9%,var(--surface-1)))">
      <b class="hi" style="display:block;margin-bottom:6px">Otestuj to v praxi</b>
      <p class="muted" style="font-size:var(--fs-sm);margin-bottom:12px">Pozri otvorené sezóny a tipuj.</p>
      <a href="/seasons" class="btn btn-brand btn-block btn-sm">Tipovať teraz →</a>
    </div>
  </aside>
</div>

<!-- RELATED -->
<% if (related && related.length) { %>
<div class="wrap" style="padding-bottom:64px">
  <h3 style="font-size:var(--fs-h3);margin-bottom:18px">Ďalšie články</h3>
  <div class="post-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px">
    <% related.forEach(function(r){ %>
      <a href="/blog/<%= r.slug %>" class="card card-hover" style="overflow:hidden"><div style="position:relative;height:140px;background:<%= r.coverGradient %>;display:flex;align-items:center;justify-content:center;font-size:40px"><%= r.coverEmoji %><span class="tag <%= catTag(r.category) %>" style="position:absolute;top:12px;left:12px"><%= r.category %></span></div><div style="padding:16px 18px 20px"><h4><%= r.title %></h4></div></a>
    <% }); %>
  </div>
</div>
<% } %>

<script>
(function () {
  var url = location.origin + location.pathname;
  var title = document.title;
  var links = {
    x: 'https://twitter.com/intent/tweet?url=' + encodeURIComponent(url) + '&text=' + encodeURIComponent(title),
    fb: 'https://www.facebook.com/sharer/sharer.php?u=' + encodeURIComponent(url),
    in: 'https://www.linkedin.com/sharing/share-offsite/?url=' + encodeURIComponent(url)
  };
  document.querySelectorAll('[data-share]').forEach(function (el) {
    var k = el.getAttribute('data-share');
    if (links[k]) { el.href = links[k]; return; }
    if (k === 'native') {
      // systémový share sheet (mobil) — cesta k IG Story: používateľ vyberie
      // Instagram v sheete. Priamy web intent do Stories neexistuje.
      if (navigator.share) {
        el.hidden = false;
        el.addEventListener('click', function () {
          navigator.share({ title: title, url: url }).catch(function () {});
        });
      }
      return;
    }
    if (k === 'copy') el.addEventListener('click', function () {
      (navigator.clipboard ? navigator.clipboard.writeText(url) : Promise.reject()).then(function () {
        var t = el.textContent; el.textContent = '✓';
        setTimeout(function () { el.textContent = t; }, 1400);
      }).catch(function () { window.prompt('Skopíruj odkaz:', url); });
    });
  });
})();
</script>
<%- include('partials/footer') %>
