<%- include('partials/head', { title: 'Kontakt', page: '', active: '', pageStyle: `
  .ct-head { padding:36px 0 10px; text-align:center; }
  .ct-head h1 { font-size:clamp(2rem,3.4vw,2.8rem); }
  .ct-layout { display:grid; grid-template-columns:1.3fr 1fr; gap:26px; align-items:start; padding:18px 0 72px; }
  .field-row { display:grid; grid-template-columns:1fr 1fr; gap:16px; }
  .ct-card { display:flex; gap:14px; align-items:flex-start; padding:16px 18px; }
  .ct-ic { width:44px; height:44px; border-radius:var(--r-md); flex:none; display:flex; align-items:center; justify-content:center; background:var(--brand-soft); color:var(--brand-bright); }
  .ct-ic svg { width:21px; height:21px; }
  .ct-card b { color:var(--text-1); font-size:var(--fs-base); }
  .ct-card .v { color:var(--text-2); font-size:var(--fs-sm); }
  .ct-card a.v:hover { color:var(--brand-bright); }
  .topic-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:8px; }
  .topic { text-align:center; padding:10px 6px; border-radius:var(--r-sm); background:var(--surface-2); border:1px solid var(--line); font-size:var(--fs-sm); font-weight:600; color:var(--text-3); cursor:pointer; transition:all .14s; }
  .topic:hover { color:var(--text-1); border-color:var(--brand-line); }
  .topic.active { color:var(--brand-bright); background:var(--brand-soft); border-color:var(--brand-line); }
  .faq-q { padding:14px 0; border-bottom:1px solid var(--line); cursor:pointer; }
  .faq-q:last-child { border-bottom:none; }
  .faq-q summary { font-weight:600; color:var(--text-1); font-size:var(--fs-base); list-style:none; display:flex; justify-content:space-between; gap:12px; }
  .faq-q summary::-webkit-details-marker { display:none; }
  .faq-q summary::after { content:"+"; color:var(--text-4); font-size:1.2rem; line-height:1; }
  .faq-q[open] summary::after { content:"\\2013"; }
  .faq-q p { color:var(--text-3); font-size:var(--fs-sm); margin-top:8px; }
  @media (max-width:820px){ .ct-layout { grid-template-columns:1fr; } }
  @media (max-width:520px){ .field-row { grid-template-columns:1fr; } .topic-grid { grid-template-columns:1fr 1fr; } }
` }) %>

<div class="wrap ct-head">
  <div class="eyebrow" style="justify-content:center;display:flex">Kontakt</div>
  <h1>Ozvi sa nám</h1>
  <p class="muted" style="margin-top:6px;max-width:50ch;margin-inline:auto">Máš otázku, nápad alebo si narazil na chybu? Napíš nám — väčšinou odpovedáme do 24 hodín.</p>
</div>

<div class="wrap ct-layout">
  <!-- FORM -->
  <main>
    <div class="card card-pad">
      <h3 style="font-size:var(--fs-h4);margin-bottom:6px">Napíš nám správu</h3>
      <p class="muted" style="font-size:var(--fs-sm);margin-bottom:18px">Vyber tému a popíš, s čím ti môžeme pomôcť.</p>

      <% if (typeof sent !== 'undefined' && sent) { %>
      <div class="card card-pad" style="background:var(--success-soft);color:var(--success);padding:12px 14px;margin-bottom:16px;font-size:var(--fs-sm)">Správa odoslaná. Ďakujeme! Ozveme sa čo najskôr.</div>
      <% } %>
      <% if (typeof error !== 'undefined' && error) { %>
      <div class="card card-pad" style="background:var(--danger-soft);color:var(--danger);padding:12px 14px;margin-bottom:16px;font-size:var(--fs-sm)"><%= error %></div>
      <% } %>

      <!-- Reálne odoslanie na backend (POST /kontakt). Tému prenáša skryté pole,
           ktoré aktualizuje existujúci topic-grid JS. -->
      <form method="POST" action="/kontakt">
      <input type="hidden" name="topic" id="topicInput" value="Všeobecná otázka">

      <div class="field" style="margin-bottom:16px">
        <label class="label">Téma</label>
        <div class="topic-grid" id="topics">
          <span class="topic active">Všeobecná otázka</span>
          <span class="topic">Nahlásiť chybu</span>
          <span class="topic">Návrh / nápad</span>
          <span class="topic">Problém s účtom</span>
          <span class="topic">Spolupráca</span>
          <span class="topic">Iné</span>
        </div>
      </div>

      <div class="stack g-4">
        <div class="field-row">
          <div class="field"><label class="label">Meno</label><input class="input" name="name" placeholder="Tvoje meno" value="<%= typeof contactName !== 'undefined' && contactName ? contactName : '' %>"></div>
          <div class="field"><label class="label">E-mail</label><input class="input" type="email" name="email" placeholder="meno@email.sk" required value="<%= typeof contactEmail !== 'undefined' && contactEmail ? contactEmail : '' %>"></div>
        </div>
        <div class="field"><label class="label">Predmet</label><input class="input" name="subject" placeholder="Stručne, o čo ide"></div>
        <div class="field"><label class="label">Správa</label><textarea class="textarea" name="message" rows="6" required placeholder="Popíš svoju otázku alebo problém čo najpodrobnejšie…"></textarea></div>
        <label class="check" style="font-size:var(--fs-sm)"><input type="checkbox" name="consent" required checked> Súhlasím so spracovaním údajov za účelom vybavenia podnetu.</label>
        <div><button class="btn btn-primary" id="sendBtn" type="submit">Odoslať správu</button></div>
      </div>
      </form>
    </div>
  </main>

  <!-- ASIDE -->
  <aside class="stack g-4">
    <div class="card ct-card">
      <span class="ct-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg></span>
      <div><b>E-mail</b><br><a class="v" href="mailto:podpora@tiperliga.sk">podpora@tiperliga.sk</a></div>
    </div>
    <div class="card ct-card">
      <span class="ct-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg></span>
      <div><b>Live chat</b><br><span class="v">Po–Pia · 9:00 – 18:00</span></div>
    </div>
    <div class="card ct-card">
      <span class="ct-ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="10" r="3"/><path d="M12 2a8 8 0 0 0-8 8c0 5.5 8 12 8 12s8-6.5 8-12a8 8 0 0 0-8-8z"/></svg></span>
      <div><b>Adresa</b><br><span class="v">Tiperliga s.r.o.<br>Mlynské Nivy 12, 821 09 Bratislava</span></div>
    </div>
    <div class="card card-pad">
      <div class="stat-label" style="margin-bottom:6px">Sleduj nás</div>
      <div class="row g-2 wrap-gap">
        <a href="#" class="btn btn-secondary btn-sm">Instagram</a>
        <a href="#" class="btn btn-secondary btn-sm">Facebook</a>
        <a href="#" class="btn btn-secondary btn-sm">X / Twitter</a>
      </div>
    </div>
  </aside>
</div>

<!-- FAQ -->
<div class="wrap" style="padding-bottom:72px">
  <div class="section-head"><div><div class="eyebrow">Časté otázky</div><h2 style="font-size:var(--fs-h3)">Možno to vyriešiš hneď</h2></div></div>
  <div class="card card-pad" style="max-width:760px">
    <details class="faq-q" open><summary>Ako sa pripojím do súkromnej ligy?</summary><p>Na stránke <a href="/join" class="brand">Pripojiť sa</a> zadaj 6-miestne ID, ktoré ti poslal organizátor. Ak je liga chránená, doplň aj heslo.</p></details>
    <details class="faq-q"><summary>Zabudol som heslo, čo teraz?</summary><p>Použi <a href="/forgot-password" class="brand">obnovu hesla</a> — pošleme ti na e-mail odkaz na nastavenie nového hesla.</p></details>
    <details class="faq-q"><summary>Ako opustím súťaž?</summary><p>V detaile ligy nájdeš v bočnom paneli tlačidlo „Opustiť súťaž". Pred odhlásením ti ukážeme, čo sa stane, a vyžiadame potvrdenie.</p></details>
    <details class="faq-q"><summary>Je Tiperliga zadarmo?</summary><p>Áno. Registrácia, tipovanie aj vytváranie komunitných líg sú úplne zadarmo.</p></details>
  </div>
</div>

<div class="toast-wrap" id="toastWrap" style="position:fixed;bottom:24px;right:24px;z-index:200;display:flex;flex-direction:column;gap:10px"></div>

<script>
  // prepínanie aktívnej témy + zápis do skrytého poľa (odosiela sa s formulárom)
  document.querySelectorAll('#topics .topic').forEach(t => t.addEventListener('click', () => {
    document.querySelectorAll('#topics .topic').forEach(x => x.classList.toggle('active', x === t));
    var hidden = document.getElementById('topicInput');
    if (hidden) hidden.value = t.textContent.trim();
  }));
  // Formulár sa odosiela natívne (POST /kontakt); backend pošle e-mail cez Resend
  // a vráti stránku s potvrdzovacím/erorovým bannerom.
</script>

<%- include('partials/footer') %>
