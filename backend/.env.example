# ========================================================
# backend/.env.example
# Skopíruj ako backend/.env a vyplň hodnoty:  cp .env.example .env
# ========================================================

# Prostredie: 'development' zapne automatickú synchronizáciu DB pri štarte.
NODE_ENV=development

# Režim synchronizácie DB (číta db.sync.js):
#   force = pri štarte ZMAŽE a vytvorí tabuľky nanovo + seed
#   alter = zachová dáta, len upraví štruktúru
# Pri PRVOM spustení daj 'force' (vytvorí tabuľky + testovací seed),
# potom prepni späť na 'alter'. POZOR: 'force' pri každom štarte vymaže dáta —
# NIKDY ho nenechávaj zapnuté v produkcii.
DB_SYNC=alter

# Port, na ktorom beží aplikácia (EJS aj API)
PORT=5000

# --- Pripojenie k MariaDB (musí sedieť s docker-compose.yml) ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=tiperliga
DB_PASSWORD=tiperliga_dev
DB_NAME=tiperliga

# --- Bezpečnosť ---
# Tajný kľúč pre podpisovanie session cookie. Vygeneruj:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=zmen_ma_na_dlhy_nahodny_retazec

# Voliteľné: tajný kľúč pre JWT. Aplikácia beží na session-auth, takže JWT
# nie je potrebný pre bežnú prevádzku. Nastav ho LEN ak používaš JWT-chránené
# API endpointy (/api/auth/profile, /api/seasons, /api/teams) cez Bearer token.
# Ak ostane prázdny, register/login fungujú normálne (len bez tokenu v odpovedi).
# JWT_SECRET=


# Google Analytics 4 — Measurement ID z GA (Správa → Dátové toky), tvar G-XXXXXXXXXX.
# Keď je prázdne, do stránok sa nevloží žiadny analytický skript (vhodné pre dev).
# GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google AdSense — client ID z AdSense účtu, tvar ca-pub-XXXXXXXXXXXXXXXX.
# Keď je prázdne: žiadny reklamný skript a /ads.txt vracia 404 (vhodné pre dev).
# ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX


# --- Web Push (mobilné/desktopové notifikácie) ---
# Vygeneruj pár kľúčov jednorazovo príkazom:
#   npx web-push generate-vapid-keys
# alebo:  node -e "console.log(require('web-push').generateVAPIDKeys())"
# Vlož výstup sem. Ak ostanú prázdne, push je vypnutý (appka funguje bez neho).
# VAPID_PUBLIC_KEY sa posiela do prehliadača, VAPID_PRIVATE_KEY drž v tajnosti.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Kontakt pre push službu (mailto: alebo https adresa prevádzkovateľa).
# Ak nie je nastavený, odvodí sa z EMAIL_FROM.
VAPID_SUBJECT=mailto:podpora@tiperliga.sk

# Resend
RESEND_API_KEY=dopln_tvoj_kluc
EMAIL_FROM=priklad.sk <noreply@priklad.sk>
CONTACT_TO=podpora@priklad.sk

# Verejná adresa webu (používa sa v sitemape, canonical URL a e-mailoch)
APP_URL=http://localhost:5000

# --- Časová zóna zobrazovania ---
# Do DB sa vždy ukladá UTC; toto ovplyvňuje len zobrazenie používateľom.
APP_TZ=Europe/Bratislava

# --- Plánovač notifikácií ---
# Beží v procese aplikácie, žiadny cron netreba.
# SCHEDULER_ENABLED=false        # odkomentuj len na vypnutie
SCHEDULER_INTERVAL_MIN=5         # kontrola kôl a sezón (min)
ADMIN_CHECK_MIN=30               # kontrola admin upozornení (min)
DEADLINE_REMINDER_MIN=60         # pripomienka pred uzávierkou (min)

# --- Masové notifikácie (oficiálne sezóny a ligy) ---
BROADCAST_BATCH=100              # príjemcov v jednej dávke
BROADCAST_PAUSE_MS=10000         # pauza medzi dávkami (ms)

# --- TheSportsDB (len pre: npm run seed:teams) ---
# '123' = verejný testovací kľúč
TSDB_API_KEY=123   
 # pauza medzi volaniami API (ms)              
TSDB_DELAY_MS=2200               