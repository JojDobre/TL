# ========================================================
# backend/.env.example
# Skopíruj tento súbor ako  backend/.env  a vyplň hodnoty.
#   cp .env.example .env
# Súbor .env NIKDY necommituj do gitu (je v .gitignore).
# ========================================================

# Prostredie: 'development' zapne automatickú synchronizáciu DB pri štarte.
NODE_ENV=development

# Režim synchronizácie databázy (číta ho src/config/db.sync.js):
#   force = pri každom štarte ZMAŽE a vytvorí tabuľky nanovo + vloží počiatočné dáta
#   alter = zachová dáta, len upraví štruktúru tabuliek podľa modelov
# Pri ÚPLNE PRVOM spustení nastav 'force', potom prepni na 'alter'.
DB_SYNC=force

# Port, na ktorom beží backend API
PORT=5000

# --- Pripojenie k PostgreSQL (musí sedieť s docker-compose.yml) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=tiperliga
DB_PASSWORD=tiperliga_dev
DB_NAME=tiperliga

# --- Bezpečnosť ---
# Vygeneruj si silný náhodný reťazec, napr. príkazom:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=zmen_ma_na_dlhy_nahodny_retazec
